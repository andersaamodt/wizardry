#!/bin/sh
# collect-prioritized-rows [DIR]
# Emit one tab-separated row per prioritized direct child in DIR:
#   path<TAB>echelon<TAB>priority<TAB>checked
set -eu
. env-clear

dir=${1:-.}
if [ ! -d "$dir" ]; then
  exit 1
fi

collect_rows_xattr() {
  directory=$1
  out_file=$2

  # shellcheck disable=SC2039
  set -- "$directory"/*
  [ -e "${1-}" ] || return 0

  tmp_e=$(mktemp "${TMPDIR:-/tmp}/priority-e.XXXXXX")
  tmp_p=$(mktemp "${TMPDIR:-/tmp}/priority-p.XXXXXX")
  tmp_c=$(mktemp "${TMPDIR:-/tmp}/priority-c.XXXXXX")
  tmp_ep=$(mktemp "${TMPDIR:-/tmp}/priority-ep.XXXXXX")

  xattr -p user.echelon "$@" 2>/dev/null | awk '
    {
      sep = index($0, ": ")
      if (sep == 0) next
      path = substr($0, 1, sep - 1)
      val = substr($0, sep + 2)
      if (val ~ /^[0-9]+$/) {
        printf "%s\t%s\n", path, val
      }
    }
  ' | LC_ALL=C sort -t "$(printf '\t')" -k1,1 > "$tmp_e"

  if [ ! -s "$tmp_e" ]; then
    rm -f "$tmp_e" "$tmp_p" "$tmp_c" "$tmp_ep"
    return 0
  fi

  xattr -p user.priority "$@" 2>/dev/null | awk '
    {
      sep = index($0, ": ")
      if (sep == 0) next
      path = substr($0, 1, sep - 1)
      val = substr($0, sep + 2)
      if (val ~ /^[0-9]+$/) {
        printf "%s\t%s\n", path, val
      }
    }
  ' | LC_ALL=C sort -t "$(printf '\t')" -k1,1 > "$tmp_p"

  xattr -p user.checked "$@" 2>/dev/null | awk '
    {
      sep = index($0, ": ")
      if (sep == 0) next
      path = substr($0, 1, sep - 1)
      val = substr($0, sep + 2)
      if (val ~ /^[0-9]+$/) {
        printf "%s\t%s\n", path, val
      }
    }
  ' | LC_ALL=C sort -t "$(printf '\t')" -k1,1 > "$tmp_c"

  tab=$(printf '\t')
  join -t "$tab" -a 1 -e 0 -o '1.1,1.2,2.2' "$tmp_e" "$tmp_p" > "$tmp_ep"
  join -t "$tab" -a 1 -e 0 -o '1.1,1.2,1.3,2.2' "$tmp_ep" "$tmp_c" > "$out_file"

  rm -f "$tmp_e" "$tmp_p" "$tmp_c" "$tmp_ep"
}

collect_rows_getfattr() {
  directory=$1
  out_file=$2

  # shellcheck disable=SC2039
  set -- "$directory"/*
  [ -e "${1-}" ] || return 0

  tmp_e=$(mktemp "${TMPDIR:-/tmp}/priority-e.XXXXXX")
  tmp_p=$(mktemp "${TMPDIR:-/tmp}/priority-p.XXXXXX")
  tmp_c=$(mktemp "${TMPDIR:-/tmp}/priority-c.XXXXXX")
  tmp_ep=$(mktemp "${TMPDIR:-/tmp}/priority-ep.XXXXXX")

  getfattr -n user.echelon --absolute-names "$@" 2>/dev/null | awk '
    /^# file: / { path = substr($0, 9); next }
    /^user\.echelon=/ {
      val = $0
      sub(/^user\.echelon=/, "", val)
      gsub(/^"|"$/, "", val)
      if (val ~ /^[0-9]+$/ && path != "") {
        printf "%s\t%s\n", path, val
      }
    }
  ' | LC_ALL=C sort -t "$(printf '\t')" -k1,1 > "$tmp_e"

  if [ ! -s "$tmp_e" ]; then
    rm -f "$tmp_e" "$tmp_p" "$tmp_c" "$tmp_ep"
    return 0
  fi

  getfattr -n user.priority --absolute-names "$@" 2>/dev/null | awk '
    /^# file: / { path = substr($0, 9); next }
    /^user\.priority=/ {
      val = $0
      sub(/^user\.priority=/, "", val)
      gsub(/^"|"$/, "", val)
      if (val ~ /^[0-9]+$/ && path != "") {
        printf "%s\t%s\n", path, val
      }
    }
  ' | LC_ALL=C sort -t "$(printf '\t')" -k1,1 > "$tmp_p"

  getfattr -n user.checked --absolute-names "$@" 2>/dev/null | awk '
    /^# file: / { path = substr($0, 9); next }
    /^user\.checked=/ {
      val = $0
      sub(/^user\.checked=/, "", val)
      gsub(/^"|"$/, "", val)
      if (val ~ /^[0-9]+$/ && path != "") {
        printf "%s\t%s\n", path, val
      }
    }
  ' | LC_ALL=C sort -t "$(printf '\t')" -k1,1 > "$tmp_c"

  tab=$(printf '\t')
  join -t "$tab" -a 1 -e 0 -o '1.1,1.2,2.2' "$tmp_e" "$tmp_p" > "$tmp_ep"
  join -t "$tab" -a 1 -e 0 -o '1.1,1.2,1.3,2.2' "$tmp_ep" "$tmp_c" > "$out_file"

  rm -f "$tmp_e" "$tmp_p" "$tmp_c" "$tmp_ep"
}

collect_rows_fallback() {
  directory=$1
  out_file=$2

  # shellcheck disable=SC2039
  set -- "$directory"/*
  [ -e "${1-}" ] || return 0

  : > "$out_file"
  for f in "$@"; do
    [ -e "$f" ] || continue
    attrs=$(get-attribute-batch "$f" echelon priority checked 2>/dev/null || true)
    file_echelon=""
    file_priority="0"
    checked_value="0"
    for pair in $attrs; do
      case "$pair" in
        echelon=*) file_echelon=${pair#echelon=} ;;
        priority=*) file_priority=${pair#priority=} ;;
        checked=*) checked_value=${pair#checked=} ;;
      esac
    done
    case "$file_echelon" in
      ''|*Error*|*[!0-9]*) continue ;;
    esac
    case "$file_priority" in
      ''|*Error*|*[!0-9]*) file_priority=0 ;;
    esac
    case "$checked_value" in
      ''|*Error*|*[!0-9]*) checked_value=0 ;;
    esac
    printf '%s\t%s\t%s\t%s\n' "$f" "$file_echelon" "$file_priority" "$checked_value" >> "$out_file"
  done
}

tmp_out=$(mktemp "${TMPDIR:-/tmp}/priority-rows.XXXXXX")
trap 'rm -f "$tmp_out"' EXIT HUP INT TERM

# In test mode we prefer the fallback path so test stubs for get-attribute-batch
# are honored consistently.
if [ "${WIZARDRY_TEST_HELPERS_ONLY-0}" = "1" ]; then
  collect_rows_fallback "$dir" "$tmp_out"
elif command -v xattr >/dev/null 2>&1; then
  collect_rows_xattr "$dir" "$tmp_out"
elif command -v getfattr >/dev/null 2>&1; then
  collect_rows_getfattr "$dir" "$tmp_out"
else
  collect_rows_fallback "$dir" "$tmp_out"
fi

cat "$tmp_out"
