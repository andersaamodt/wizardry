#!/bin/sh
# disambiguate CMD [ARGS...] - resolve ambiguous command and execute
# When a command has multiple meanings, presents a menu to choose.
# Saves choice in $SPELLBOOK_DIR/.disambiguations for future use.

set -eu

if [ $# -eq 0 ]; then
  exit 0
fi

dis_cmd=$1
shift

dis_newline='
'
dis_carriage_return=$(printf '\r')
case "$dis_cmd" in
  ''|.|..|*/*|*"$dis_newline"*|*"$dis_carriage_return"*)
    printf '%s\n' "disambiguate: invalid command name: $dis_cmd" >&2
    exit 2
    ;;
esac

dis_spellbook_dir="${SPELLBOOK_DIR:-$HOME/.spellbook}"
dis_disambig_dir="$dis_spellbook_dir/.disambiguations"

dis_count=0
dis_spell_path=""
dis_sys_cmd=""

dis_wizardry_dir="${WIZARDRY_DIR:-$HOME/.wizardry}"
if [ -d "$dis_wizardry_dir/spells" ]; then
  dis_spell_path=$(
    find "$dis_wizardry_dir/spells" -name "$dis_cmd" -type f 2>/dev/null |
      while IFS= read -r dis_candidate_path; do
        if [ -x "$dis_candidate_path" ]; then
          printf '%s\n' "$dis_candidate_path"
          break
        fi
      done
  )
  if [ -n "$dis_spell_path" ]; then
    dis_count=$((dis_count + 1))
  fi
fi

# Get system command, excluding wizardry from PATH
dis_remaining_path=$PATH
dis_clean_path=""
while :; do
  case "$dis_remaining_path" in
    *:*)
      dis_path_part=${dis_remaining_path%%:*}
      dis_remaining_path=${dis_remaining_path#*:}
      ;;
    *)
      dis_path_part=$dis_remaining_path
      dis_remaining_path=""
      ;;
  esac

  case "$dis_path_part" in
    *wizardry*) ;;
    *)
      if [ -z "$dis_clean_path" ]; then
        dis_clean_path=$dis_path_part
      else
        dis_clean_path="${dis_clean_path}:$dis_path_part"
      fi
      ;;
  esac

  [ -n "$dis_remaining_path" ] || break
done
dis_sys_cmd=$(PATH="$dis_clean_path" command -v "$dis_cmd" 2>/dev/null || true)

if [ -n "$dis_sys_cmd" ]; then
  dis_count=$((dis_count + 1))
fi

if [ -f "$dis_disambig_dir/$dis_cmd" ]; then
  dis_saved_choice=$(cat "$dis_disambig_dir/$dis_cmd")
  if [ -n "$dis_saved_choice" ] &&
    { [ "$dis_saved_choice" = "$dis_spell_path" ] || [ "$dis_saved_choice" = "$dis_sys_cmd" ]; }; then
    "$dis_saved_choice" "$@"
    exit $?
  fi
  rm -f "$dis_disambig_dir/$dis_cmd"
fi

if [ "$dis_count" -eq 0 ]; then
  "$dis_cmd" "$@"
  exit $?
fi

if [ "$dis_count" -eq 1 ]; then
  if [ -n "$dis_spell_path" ]; then
    dis_choice_path=$dis_spell_path
  else
    dis_choice_path=$dis_sys_cmd
  fi
  "$dis_choice_path" "$@"
  exit $?
fi

printf '%s\n' "Multiple commands match '$dis_cmd':" >&2
printf '  [1] %s (wizardry spell)\n' "$dis_spell_path" >&2
printf '  [2] %s (system command)\n' "$dis_sys_cmd" >&2

printf '%s' "Choose [1-$dis_count, or 'r' to remember]: " >&2
read -r dis_choice

dis_remember=0
case $dis_choice in
  *r|*R)
    dis_remember=1
    dis_choice=$(printf '%s' "$dis_choice" | tr -d 'rR ')
    ;;
esac

if ! printf '%s' "$dis_choice" | grep -qE '^[0-9]+$'; then
  printf '%s\n' "Invalid choice." >&2
  exit 1
fi

if [ "$dis_choice" -lt 1 ] || [ "$dis_choice" -gt "$dis_count" ]; then
  printf '%s\n' "Choice out of range." >&2
  exit 1
fi

case $dis_choice in
  1) dis_chosen_path=$dis_spell_path ;;
  2) dis_chosen_path=$dis_sys_cmd ;;
esac

if [ "$dis_remember" -eq 1 ]; then
  mkdir -p "$dis_disambig_dir"
  printf '%s\n' "$dis_chosen_path" > "$dis_disambig_dir/$dis_cmd"
  printf '%s\n' "Remembered: '$dis_cmd' → '$dis_chosen_path'" >&2
fi

"$dis_chosen_path" "$@"
