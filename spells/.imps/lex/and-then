#!/bin/sh
# and-then CMD CMD_ARGS MORE... - execute prior command, continue if it succeeded (&&)
# Canonical linking word for shell's && operator.
# Receives: $1=command, $2=command_args, $3+=remaining args


at_cmd=${1:-}
at_cmd_args=${2:-}
if [ $# -ge 2 ]; then
  shift 2
elif [ $# -gt 0 ]; then
  shift $#
fi

if [ -n "$at_cmd" ]; then
  at_had_noglob=0
  case $- in
    *f*) at_had_noglob=1 ;;
    *) set -f ;;
  esac
  # shellcheck disable=SC2086
  "$at_cmd" $at_cmd_args
  at_status=$?
  if [ "$at_had_noglob" -eq 0 ]; then
    set +f
  fi
  if [ "$at_status" -ne 0 ]; then
    exit "$at_status"
  fi
fi

if [ $# -eq 0 ]; then
  exit 0
fi

at_lex_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$at_lex_dir/parse"
