#!/bin/sh
# parse CMD... - recursively parse and execute written imperatives
# Reconstructs multi-word commands from space-separated arguments.
# For "env or VAR DEFAULT", tries env-or first, then falls back to env.
#
# The parse imp is automatically used by glosses to enable natural language
# command invocation like "read magic" instead of "read-magic".
#
# Usage (via glosses): Any wizardry command with spaces
# Usage (direct): . parse <word1> <word2> ... <args>
#
# Examples:
#   . parse env or VAR DEFAULT    # Tries env-or-VAR-DEFAULT, env-or-VAR, env-or, then env
#   . parse read magic file.txt   # Tries read-magic-file.txt, read-magic, then read
#   . parse temp file             # Tries temp-file, then temp
#
# RECURSION PREVENTION: Uses WIZARDRY_PARSE_DEPTH to prevent infinite loops
#
# NOTE: This imp must be SOURCED, not executed. It modifies the calling shell
# to preserve context for uncastable spells that change directories, etc.

# Uncastable pattern - ensures this imp is sourced, not executed
parse_sourced=0
if eval '[ -n "${ZSH_VERSION+x}" ]' 2>/dev/null; then
  case "${ZSH_EVAL_CONTEXT-}" in
    *:file) parse_sourced=1 ;;
  esac
else
  parse_base=${0##*/}
  case "$parse_base" in
    sh|dash|bash|zsh|ksh|mksh) parse_sourced=1 ;;
    parse) parse_sourced=0 ;;
    *) parse_sourced=1 ;;
  esac
fi

if [ "$parse_sourced" -eq 0 ]; then
  printf '%s\n' "parse: This imp must be sourced, not executed. Use: . parse <args>" >&2
  exit 1
fi

wizardry_parse_main() {
# Check if parse is enabled in config BEFORE doing any work (defaults to enabled when unset)
parse_spell_home="${SPELLBOOK_DIR:-${HOME:-.}/.spellbook}"
parse_config_file="$parse_spell_home/.mud"
parse_enabled=""
if [ -f "$parse_config_file" ]; then
  parse_enabled=$(
    grep "^parse-enabled=" "$parse_config_file" 2>/dev/null | cut -d= -f2- | tr -d '\r' || printf ''
  )
fi
# Default to enabled (1) if not set
if [ -z "$parse_enabled" ]; then
  parse_enabled=$(mud-defaults parse-enabled 2>/dev/null || printf '1')
fi
# If parse-enabled is explicitly set to 0, fail immediately before any parsing
if [ "$parse_enabled" = "0" ]; then
  # Parse is disabled - don't do any parsing work, just fail
  printf 'parse: command not found (parsing is disabled)\n' >&2
  return 127
fi

# Increment recursion depth
parse_depth=${WIZARDRY_PARSE_DEPTH:-0}
parse_depth=$((parse_depth + 1))

# Prevent infinite recursion
if [ "$parse_depth" -gt 10 ]; then
  printf 'parse: Maximum recursion depth exceeded\n' >&2
  return 1
fi

# If no arguments, just succeed
if [ $# -eq 0 ]; then
  return 0
fi

# Get WIZARDRY_DIR
parse_wizardry_dir=${WIZARDRY_DIR:-${HOME:-.}/.wizardry}
if [ ! -d "$parse_wizardry_dir/spells" ]; then
  # Fall back to detecting from script location if needed
  if command -v dirname >/dev/null 2>&1 && command -v pwd >/dev/null 2>&1; then
    parse_script_dir=$(CDPATH= cd -- "$(dirname "$0")" 2>/dev/null && pwd -P) || :
    if [ -n "$parse_script_dir" ]; then
      parse_wiz_root=$(CDPATH= cd -- "$parse_script_dir/../../.." 2>/dev/null && pwd -P) || :
      if [ -n "$parse_wiz_root" ] && [ -d "$parse_wiz_root/spells" ]; then
        parse_wizardry_dir=$parse_wiz_root
      fi
    fi
  fi
fi

# Extract command words (non-flag args from the beginning)
parse_cmd_word_count=0
parse_first_word=""

# Count how many leading args are command words (not flags or pure numbers)
for parse_loop_arg in "$@"; do
  case "$parse_loop_arg" in
    -*) break ;;
    *[!0-9]*) 
      # Contains non-numeric characters - it's a command word
      if [ -z "$parse_first_word" ]; then
        parse_first_word=$parse_loop_arg
      fi
      parse_cmd_word_count=$((parse_cmd_word_count + 1))
      ;;
    *)
      # Pure numeric argument - stop counting command words
      break
      ;;
  esac
done

# If no command words, nothing to do
if [ $parse_cmd_word_count -eq 0 ]; then
  printf 'parse: no command specified\n' >&2
  return 1
fi

# Try progressively longer combinations (from max down to 1)
parse_attempt_len=$parse_cmd_word_count
while [ $parse_attempt_len -gt 0 ]; do
  # Build command name from first N words joined with hyphens
  # IMPORTANT: Only use command words (skip flags and pure numbers)
  parse_cmd_name=""
  parse_i=0
  for parse_loop_arg in "$@"; do
    # Skip flags and pure numeric arguments (same logic as counting loop)
    case "$parse_loop_arg" in
      -*) break ;;
      *[!0-9]*) ;;  # Contains non-numeric - it's a command word, use it
      *) break ;;    # Pure numeric - stop
    esac
    
    if [ $parse_i -ge $parse_attempt_len ]; then
      break
    fi
    if [ -z "$parse_cmd_name" ]; then
      parse_cmd_name=$parse_loop_arg
    else
      parse_cmd_name="${parse_cmd_name}-${parse_loop_arg}"
    fi
    parse_i=$((parse_i + 1))
  done
  
  # Try all possible spell locations
  parse_spell_path=""
  
  # Try imp directories
  for parse_imp_dir in sys cond out fs str paths text input menu pkg test lang; do
    if [ -x "$parse_wizardry_dir/spells/.imps/$parse_imp_dir/$parse_cmd_name" ]; then
      # Skip parse in lex to avoid recursion
      if [ "$parse_imp_dir" = "lex" ] && [ "$parse_cmd_name" = "parse" ]; then
        continue
      fi
      parse_spell_path="$parse_wizardry_dir/spells/.imps/$parse_imp_dir/$parse_cmd_name"
      break
    fi
  done
  
  # Try lex separately (but avoid parse recursion)
  if [ -z "$parse_spell_path" ] && [ "$parse_cmd_name" != "parse" ]; then
    if [ -x "$parse_wizardry_dir/spells/.imps/lex/$parse_cmd_name" ]; then
      parse_spell_path="$parse_wizardry_dir/spells/.imps/lex/$parse_cmd_name"
    fi
  fi
  
  # Try .wizardry directory
  if [ -z "$parse_spell_path" ] && [ -x "$parse_wizardry_dir/spells/.wizardry/$parse_cmd_name" ]; then
    parse_spell_path="$parse_wizardry_dir/spells/.wizardry/$parse_cmd_name"
  fi

  # Try explicit spell-relative paths used by some synonyms, such as
  # translocation/jump-to-marker or .arcana/web-wizardry/web-wizardry-menu.
  if [ -z "$parse_spell_path" ]; then
    case "$parse_cmd_name" in
      /*|..|../*|*/..|*/../*|*//*) ;;
      */*)
        if [ -x "$parse_wizardry_dir/spells/$parse_cmd_name" ]; then
          parse_spell_path="$parse_wizardry_dir/spells/$parse_cmd_name"
        fi
        ;;
    esac
  fi
  
  # Try spell category directories
  if [ -z "$parse_spell_path" ]; then
    for parse_category_dir in "$parse_wizardry_dir/spells"/*; do
      [ -d "$parse_category_dir" ] || continue
      case "$parse_category_dir" in
        */.|*/..|*/.imps|*/.wizardry) continue ;;
      esac
      if [ -x "$parse_category_dir/$parse_cmd_name" ]; then
        parse_spell_path="$parse_category_dir/$parse_cmd_name"
        break
      fi
    done
  fi
  
  # Also try .arcana subdirectories if not found yet
  if [ -z "$parse_spell_path" ] && [ -d "$parse_wizardry_dir/spells/.arcana" ]; then
    for parse_category_dir in "$parse_wizardry_dir/spells/.arcana"/*; do
      [ -d "$parse_category_dir" ] || continue
      if [ -x "$parse_category_dir/$parse_cmd_name" ]; then
        parse_spell_path="$parse_category_dir/$parse_cmd_name"
        break
      fi
    done
  fi
  
  # Check if this command name is a synonym
  if [ -z "$parse_spell_path" ]; then
    parse_spell_home=${SPELLBOOK_DIR:-${HOME:-.}/.spellbook}
    parse_synonym_target=""
    
    # Check user synonyms first
    if [ -f "$parse_spell_home/.synonyms" ]; then
      parse_synonym_match=$(
        awk -F= -v key="$parse_cmd_name" '$1 == key { print; exit }' "$parse_spell_home/.synonyms" 2>/dev/null || true
      )
      parse_synonym_target=$(printf '%s' "$parse_synonym_match" | sed 's/^[^=]*=//' | tr -d '\r')
    fi
    
    # Check default synonyms if not found in user synonyms
    if [ -z "$parse_synonym_target" ] && [ -f "$parse_spell_home/.default-synonyms" ]; then
      parse_synonym_match=$(
        awk -F= -v key="$parse_cmd_name" '$1 == key { print; exit }' "$parse_spell_home/.default-synonyms" 2>/dev/null || true
      )
      parse_synonym_target=$(printf '%s' "$parse_synonym_match" | sed 's/^[^=]*=//' | tr -d '\r')
    fi
    
    # If synonym found, check if target is uncastable before recursing
    if [ -n "$parse_synonym_target" ]; then
      # Check if synonym target is an uncastable spell that needs sourcing
      parse_synonym_target_path=""
      
      # Search for the synonym target in spell directories
      for parse_category_dir in "$parse_wizardry_dir/spells"/*; do
        [ -d "$parse_category_dir" ] || continue
        case "$parse_category_dir" in
          */.|*/..|*/.imps|*/.wizardry|*/.arcana) continue ;;
        esac
        if [ -f "$parse_category_dir/$parse_synonym_target" ]; then
          if grep -q "^# Uncastable pattern" "$parse_category_dir/$parse_synonym_target" 2>/dev/null; then
            # Found uncastable synonym target - source it with remaining args
            parse_synonym_target_path="$parse_category_dir/$parse_synonym_target"
            break
          fi
        fi
      done
      
      # If synonym target is uncastable, source it
      if [ -n "$parse_synonym_target_path" ]; then
        # Skip first $parse_attempt_len args (the synonym name parts)
        parse_shift_count=0
        while [ $parse_shift_count -lt $parse_attempt_len ] && [ $# -gt 0 ]; do
          shift
          parse_shift_count=$((parse_shift_count + 1))
        done
        # Source the uncastable spell
        . "$parse_synonym_target_path"
        return $?
      fi
      
      # Synonym target is castable - recursively source parse
      # Skip first $parse_attempt_len args (the synonym name parts)
      parse_shift_count=0
      while [ $parse_shift_count -lt $parse_attempt_len ] && [ $# -gt 0 ]; do
        shift
        parse_shift_count=$((parse_shift_count + 1))
      done
      # Source parse recursively to handle the synonym target
      # Find parse using the same method as glosses
      parse_had_depth=0
      parse_saved_depth=${WIZARDRY_PARSE_DEPTH-}
      if [ "${WIZARDRY_PARSE_DEPTH+x}" = x ]; then
        parse_had_depth=1
      fi
      WIZARDRY_PARSE_DEPTH=$parse_depth
      export WIZARDRY_PARSE_DEPTH
      parse_had_noglob=0
      case $- in
        *f*) parse_had_noglob=1 ;;
        *) set -f ;;
      esac
      # shellcheck disable=SC2086
      set -- $parse_synonym_target "$@"
      if [ "$parse_had_noglob" -eq 0 ]; then
        set +f
      fi
      if command -v parse >/dev/null 2>&1; then
        . parse
        parse_status=$?
      elif [ -f "${WIZARDRY_DIR:-./.wizardry}/spells/.imps/lex/parse" ]; then
        . "${WIZARDRY_DIR:-./.wizardry}/spells/.imps/lex/parse"
        parse_status=$?
      else
        printf '%s\n' "parse: cannot find parse to handle synonym $parse_cmd_name" >&2
        return 127
      fi
      if [ "$parse_had_depth" -eq 1 ]; then
        WIZARDRY_PARSE_DEPTH=$parse_saved_depth
        export WIZARDRY_PARSE_DEPTH
      else
        unset WIZARDRY_PARSE_DEPTH
      fi
      return "$parse_status"
    fi
  fi
  
  # If found, source or execute the spell
  if [ -n "$parse_spell_path" ]; then
    # Skip first $parse_attempt_len args to get remaining args for the spell
    parse_shift_count=0
    while [ $parse_shift_count -lt $parse_attempt_len ]; do
      if [ $# -gt 0 ]; then
        shift
      fi
      parse_shift_count=$((parse_shift_count + 1))
    done
    
    # Check if spell is uncastable (must be sourced)
    if grep -q "^# Uncastable pattern" "$parse_spell_path" 2>/dev/null; then
      # Source the uncastable spell
      . "$parse_spell_path"
      return $?
    fi
    
    # Castable spell - execute it, unsetting any function with the same name first
    # This prevents recursive loops when glosses create functions with the same name
    unset -f "$parse_cmd_name" 2>/dev/null || true
    "$parse_spell_path" "$@"
    return $?
  fi
  
  # Try next shorter combination
  parse_attempt_len=$((parse_attempt_len - 1))
done

# Last resort: try first word as system command (but not functions or aliases)
parse_cmd_type=$(command -v "$parse_first_word" 2>/dev/null || true)
if [ -n "$parse_cmd_type" ]; then
  parse_system_word=$parse_first_word
  [ $# -gt 0 ] && shift
  # Check if it's an actual executable file (not a function or alias)
  # command -v returns path for executables, name for builtins/functions/aliases
  case "$parse_cmd_type" in
    */*)
      # Contains a slash - it's a path to an executable file
      if [ -f "$parse_cmd_type" ] && [ -x "$parse_cmd_type" ]; then
        # It's a real executable command, run it
        # Unset any gloss function first to prevent recursion
        unset -f "$parse_system_word" 2>/dev/null || true
        "$parse_system_word" "$@"
        return $?
      fi
      ;;
    *)
      # No slash - could be a builtin, function, or alias
      # Unset any gloss function first to prevent infinite recursion
      unset -f "$parse_system_word" 2>/dev/null || true
      command "$parse_system_word" "$@"
      parse_cmd_status=$?
      if [ "$parse_cmd_status" -ne 127 ]; then
        return "$parse_cmd_status"
      fi
      ;;
  esac
  set -- "$parse_system_word" "$@"
fi

# Check synonyms as final fallback
parse_spell_home=${SPELLBOOK_DIR:-${HOME:-.}/.spellbook}
parse_synonym_target=""

# Check user synonyms first
if [ -f "$parse_spell_home/.synonyms" ]; then
  parse_synonym_match=$(
    awk -F= -v key="$parse_first_word" '$1 == key { print; exit }' "$parse_spell_home/.synonyms" 2>/dev/null || true
  )
  parse_synonym_target=$(printf '%s' "$parse_synonym_match" | sed 's/^[^=]*=//' | tr -d '\r')
fi

# Check default synonyms if not found in user synonyms
if [ -z "$parse_synonym_target" ] && [ -f "$parse_spell_home/.default-synonyms" ]; then
  parse_synonym_match=$(
    awk -F= -v key="$parse_first_word" '$1 == key { print; exit }' "$parse_spell_home/.default-synonyms" 2>/dev/null || true
  )
  parse_synonym_target=$(printf '%s' "$parse_synonym_match" | sed 's/^[^=]*=//' | tr -d '\r')
fi

# If synonym found, recursively source parse with the target
if [ -n "$parse_synonym_target" ]; then
  [ $# -gt 0 ] && shift  # Remove the synonym word itself
  # Source parse recursively to handle the synonym target
  # Find parse using the same method as glosses
  parse_had_depth=0
  parse_saved_depth=${WIZARDRY_PARSE_DEPTH-}
  if [ "${WIZARDRY_PARSE_DEPTH+x}" = x ]; then
    parse_had_depth=1
  fi
  WIZARDRY_PARSE_DEPTH=$parse_depth
  export WIZARDRY_PARSE_DEPTH
  parse_had_noglob=0
  case $- in
    *f*) parse_had_noglob=1 ;;
    *) set -f ;;
  esac
  # shellcheck disable=SC2086
  set -- $parse_synonym_target "$@"
  if [ "$parse_had_noglob" -eq 0 ]; then
    set +f
  fi
  if command -v parse >/dev/null 2>&1; then
    . parse
    parse_status=$?
  elif [ -f "${WIZARDRY_DIR:-./.wizardry}/spells/.imps/lex/parse" ]; then
    . "${WIZARDRY_DIR:-./.wizardry}/spells/.imps/lex/parse"
    parse_status=$?
  else
    printf '%s\n' "parse: cannot find parse to handle synonym $parse_first_word" >&2
    return 127
  fi
  if [ "$parse_had_depth" -eq 1 ]; then
    WIZARDRY_PARSE_DEPTH=$parse_saved_depth
    export WIZARDRY_PARSE_DEPTH
  else
    unset WIZARDRY_PARSE_DEPTH
  fi
  return "$parse_status"
fi

printf 'parse: %s: command not found\n' "$parse_first_word" >&2
return 127
}

wizardry_parse_main "$@"
parse_status=$?
unset -f wizardry_parse_main 2>/dev/null || true
return "$parse_status"
