#!/bin/sh
# run-with-pty COMMAND [ARGS...] - run command with real PTY using socat
# Environment variables:
#   PTY_INPUT - raw input to send to the command (default: single newline)
#   PTY_KEYS - symbolic keys to send (e.g., "up up enter") - converted to escape sequences
#   PTY_SEND_DELAY - whole-second delay before sending input (default: 1)
#   PATH - inherited for command execution
#
# This helper uses socat to create a real PTY for interactive command testing.
# Use PTY_KEYS for symbolic key names (more readable) or PTY_INPUT for raw bytes.

set -eu

if [ "$#" -lt 1 ]; then
  printf 'run-with-pty: command required\n' >&2
  exit 1
fi

# Check if socat is available
if ! command -v socat >/dev/null 2>&1; then
  printf 'run-with-pty: socat not found\n' >&2
  exit 1
fi

# Create temporary directory
tmpdir=${TMPDIR:-/tmp}
test_dir=$(mktemp -d "$tmpdir/run-pty.XXXXXX")
trap 'rm -rf "$test_dir"' EXIT INT TERM

# Determine input data
if [ -n "${PTY_KEYS:-}" ]; then
  # Convert symbolic keys to escape sequences using socat-send-keys
  socat_send_keys_bin=$(command -v socat-send-keys 2>/dev/null || true)
  if [ -z "$socat_send_keys_bin" ]; then
    printf 'run-with-pty: socat-send-keys not found\n' >&2
    exit 1
  fi
  # Execute via /bin/sh for consistent exit behavior across shells.
  # Direct execution can return non-zero on some environments even on success.
  # shellcheck disable=SC2086
  input_data=$(/bin/sh "$socat_send_keys_bin" $PTY_KEYS)
elif [ -n "${PTY_INPUT:-}" ]; then
  # Use raw input as-is
  input_data="$PTY_INPUT"
else
  # Default to single newline
  input_data='
'
fi

# Create a script that runs the exact command
# Properly quote each argument
{
  printf '#!/bin/sh\n'
  # Set environment variables by prefixing the exec command
  # This passes them to the command without using export
  printf 'PATH=%s AWAIT_KEYPRESS_DEVICE=$(tty 2>/dev/null || printf "/dev/stdin") exec' "'$PATH'"
  for arg in "$@"; do
    # Escape single quotes in the argument
    escaped=$(printf '%s' "$arg" | sed "s/'/'\\\\''/g")
    printf " '%s'" "$escaped"
  done
  printf '\n'
} > "$test_dir/cmd.sh"
chmod +x "$test_dir/cmd.sh"

# Resolve timeout command across platforms (GNU coreutils on macOS may install gtimeout)
timeout_cmd=''
if command -v timeout >/dev/null 2>&1; then
  timeout_cmd='timeout'
elif command -v gtimeout >/dev/null 2>&1; then
  timeout_cmd='gtimeout'
fi

# Use socat with stdin as input side and EXEC with PTY on output side.
# -T 5 applies socat's own inactivity timeout so PTY tests do not hang when
# GNU timeout is unavailable (common on macOS).
# Add a short delay before sending input so the command has time to initialize
# the terminal mode; this avoids losing early keypresses in PTY tests.
send_delay=${PTY_SEND_DELAY:-1}
case "$send_delay" in
  ''|*[!0-9]*)
    send_delay=1
    ;;
esac

if [ -n "$timeout_cmd" ]; then
  {
    if [ "$send_delay" -gt 0 ]; then
      sleep "$send_delay"
    fi
    printf '%s' "$input_data"
  } | "$timeout_cmd" 7 socat -T 5 - "EXEC:$test_dir/cmd.sh,pty,stderr" 2>&1 || true
else
  {
    if [ "$send_delay" -gt 0 ]; then
      sleep "$send_delay"
    fi
    printf '%s' "$input_data"
  } | socat -T 5 - "EXEC:$test_dir/cmd.sh,pty,stderr" 2>&1 || true
fi
