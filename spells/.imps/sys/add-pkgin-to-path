#!/bin/sh
# add-pkgin-to-path - Add pkgin bin and sbin directories to PATH if not already available

set -eu

pkgin_candidates=${PKGIN_CANDIDATES:-/usr/pkg/bin/pkgin /opt/pkg/bin/pkgin /usr/local/pkg/bin/pkgin}
pkgin_path=""

for candidate in $pkgin_candidates; do
  if [ -x "$candidate" ]; then
    pkgin_path=$candidate
    break
  fi
done

if [ -z "$pkgin_path" ] && command -v pkgin >/dev/null 2>&1; then
  pkgin_path=$(command -v pkgin 2>/dev/null || printf '')
fi

if [ -n "$pkgin_path" ] && [ -x "$pkgin_path" ]; then
  pkg_base=$(dirname "$(dirname "$pkgin_path")")
  case ":$PATH:" in
    *":$pkg_base/sbin:"*) ;;
    *) PATH="$pkg_base/sbin:$PATH" ;;
  esac
  case ":$PATH:" in
    *":$pkg_base/bin:"*) ;;
    *) PATH="$pkg_base/bin:$PATH" ;;
  esac
  export PATH
fi
