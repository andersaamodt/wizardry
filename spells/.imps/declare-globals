#!/bin/sh
# Centralized declaration of allowed global environment variables.
# Each global requires two comment lines: description and justification.
# ENFORCEMENT: Tests verify exact global count, 'set -u' usage, no undeclared exports.

# Explicitly use permissive mode - this file is sourced into other scripts


# Installation root directory path.
# Required for spells to locate resources relative to install location.
: "${WIZARDRY_DIR:=}"

# User's personal spellbook directory.
# Required for coordinating custom spell storage across multiple spells.
: "${SPELLBOOK_DIR:=}"

# MUD configuration directory.
# Required for MUD features to share room descriptions and settings.
: "${MUD_DIR:=}"

# Web wizardry sites root directory.
# Required for all web-related spells to consistently locate site directories.
: "${WIZARDRY_SITES_DIR:=$HOME/sites}"

# wizardry-apps repository root directory.
# Required so web templates/apps can live outside the wizardry installation.
: "${WIZARDRY_APPS_DIR:=$HOME/git/wizardry-apps}"

# Logging verbosity level (0=quiet, 1=info, 2=debug).
# Required for consistent logging behavior across all spells.
: "${WIZARDRY_LOG_LEVEL:=0}"
