#!/bin/sh
# has-ancestor COMMAND - test if command is running in process ancestry
# Example: has-ancestor banish && echo "running inside banish"
# Example: has-ancestor vim && echo "running inside vim"


search_cmd=${1-}

# Require command argument
if [ -z "$search_cmd" ]; then
  exit 1
fi

# Check if ps command is available
if ! command -v ps >/dev/null 2>&1; then
  # Without ps, we can't detect, so assume not in ancestry
  exit 1
fi

is_shell_name() {
  case "$1" in
    sh|dash|bash|zsh|ksh|mksh) return 0 ;;
    *) return 1 ;;
  esac
}

# Some macOS sandboxed contexts deny ps process inspection.
# Fallback: if searching for a shell ancestor, assume true because this imp
# itself is always executed by a shell.
if ! ps -o comm= -p "$$" >/dev/null 2>&1; then
  if is_shell_name "$search_cmd"; then
    exit 0
  fi
  exit 1
fi

# Match a command token by basename.
matches_cmd() {
  token=$1
  [ -n "$token" ] || return 1
  token_base=${token##*/}
  [ "$token_base" = "$search_cmd" ]
}

# Walk up the process tree checking current process and each ancestor.
pid=$$
while [ "$pid" -gt 1 ]; do
  comm=$(ps -o comm= -p "$pid" 2>/dev/null | tr -d ' ')
  if matches_cmd "$comm"; then
    exit 0
  fi

  # Fallback check: scan command arguments tokens.
  args=$(ps -o args= -p "$pid" 2>/dev/null | sed 's/^ *//')
  for token in $args; do
    if matches_cmd "$token"; then
      exit 0
    fi
  done

  ppid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
  [ -z "$ppid" ] && break
  [ "$ppid" = "$pid" ] && break
  case "$ppid" in
    ''|*[!0-9]*) break ;;
  esac
  [ "$ppid" -le 1 ] && break
  pid=$ppid
done

exit 1
