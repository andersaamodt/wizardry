#!/bin/sh

# This spell displays the menu for adminning hosting a MUD server.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE' >&2
Usage: mud-admin-menu

Opens the MUD admin menu so you can manage authorized players, review shared rooms, and oversee your hosted server.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

# Catch Ctrl-C and TERM signal to exit 1 cleanly
# Catch Ctrl-C and TERM signal to exit cleanly
# INT (Ctrl-C) should exit 130, TERM should exit 0
trap 'exit 130' INT
trap 'exit 0' TERM

# Load color palette (colors handles terminal capability detection internally)
# shellcheck source=/dev/null
. "$(command -v colors)"

if ! require menu "The MUD Admin menu needs the 'menu' command to present options."; then
  exit 1
fi

mud_admin_menu_display_menu() {
  create_identity="Create player SSH identity%new-player"
  add="Authorize player on this host%add-player"
  promote_blog_admin="Promote player to blog admin (sudo)%promote-admin"
  list_players="List players%list-players"
  player_status="Player status%player-status"
  list_rooms="List shared rooms%list-rooms"
  exit_label=$(exit-label)
  # Exit button kills this menu script via TERM signal
  # Menu (child process) evals: kill -TERM $PPID → kills its parent (this script)
  exit_item="${exit_label}%kill -TERM \$PPID"

  set -- "$create_identity" "$add" "$promote_blog_admin" "$list_players" "$player_status" "$list_rooms" "$exit_item"
  menu "MUD Admin:" "$@"
}

loop_limit=${MENU_LOOP_LIMIT:-}
first_run=1

while true; do
  if [ "$first_run" -eq 0 ]; then
    :
  else
    first_run=0
  fi

  mud_admin_menu_display_menu || menu_status=$?
  menu_status=${menu_status:-0}
  
  # ESC causes menu to exit with 130 - handle gracefully by exiting
  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi

  # Support MENU_LOOP_LIMIT for testing
  if [ -n "$loop_limit" ]; then
    loop_limit=$((loop_limit - 1))
    if [ "$loop_limit" -le 0 ]; then
      break
    fi
  fi
done
