#!/bin/sh

# This spell presents a menu of options for managing users on the system.
# Use it to manage passwords, groups, and user accounts.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: users-menu

Display an interactive menu for user and group management, covering password changes, group memberships, and user account administration.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

# Load color palette (colors handles terminal capability detection internally)
# shellcheck source=/dev/null
. "$(command -v colors)"

if ! require menu "The Users menu needs the 'menu' command to present options."; then
  exit 1
fi
if ! require ask-text "The Users menu needs the 'ask-text' command for prompts."; then
  exit 1
fi

# Catch Ctrl-C and TERM signal to exit 1 cleanly
# Catch Ctrl-C and TERM signal to exit cleanly
# INT (Ctrl-C) should exit 130, TERM should exit 0
trap 'exit 130' INT
trap 'exit 0' TERM

users_menu_display_menu() {
  kernel=$(uname -s 2>/dev/null || printf 'unknown')

  change_my_password="Change my password%passwd"
  view_my_groups="View my group memberships%id -Gn"
  change_other_password="Change another user's password%username=\$(ask-text 'Enter username:') && sudo passwd \"\$username\""
  view_other_groups="View another user's groups%username=\$(ask-text 'Enter username:') && id -Gn \"\$username\""

  case "$kernel" in
    Darwin)
      list_users="List local users%dscl . -list /Users"
      list_groups="List local groups%dscl . -list /Groups"
      create_group="Create new group%groupname=\$(ask-text 'Enter new group name:') && sudo dseditgroup -o create \"\$groupname\""
      delete_group="Delete group%groupname=\$(ask-text 'Enter group to delete:') && sudo dseditgroup -o delete \"\$groupname\""
      join_group="Join group%groupname=\$(ask-text 'Enter group name to join:') && sudo dseditgroup -o edit -a \"$USER\" -t user \"\$groupname\""
      leave_group="Leave group%groupname=\$(ask-text 'Enter group name to leave:') && sudo dseditgroup -o edit -d \"$USER\" -t user \"\$groupname\""
      list_users_in_group="List users in group%groupname=\$(ask-text 'Enter group name to inspect:') && dscl . -read \"/Groups/\$groupname\" GroupMembership"
      add_user_to_group="Add another user to a group%username=\$(ask-text 'Enter username:') && groupname=\$(ask-text 'Enter group name:') && sudo dseditgroup -o edit -a \"\$username\" -t user \"\$groupname\""
      remove_user_from_group="Remove another user from a group%username=\$(ask-text 'Enter username:') && groupname=\$(ask-text 'Enter group name:') && sudo dseditgroup -o edit -d \"\$username\" -t user \"\$groupname\""
      create_user="Create new user%username=\$(ask-text 'Enter new username:') && sudo sysadminctl -addUser \"\$username\" -password -"
      delete_user="Delete user%username=\$(ask-text 'Enter username of user to delete:') && sudo sysadminctl -deleteUser \"\$username\" -keepHome"
      ;;
    *)
      list_users="List all users%cut -d: -f1 /etc/passwd"
      list_groups="List all groups%cut -d: -f1 /etc/group"
      create_group="Create new group%groupname=\$(ask-text 'Enter new group name:') && sudo groupadd \"\$groupname\""
      delete_group="Delete group%groupname=\$(ask-text 'Enter group to delete:') && sudo groupdel \"\$groupname\""
      join_group="Join group%groupname=\$(ask-text 'Enter group name to join:') && sudo usermod -a -G \"\$groupname\" \"$USER\""
      leave_group="Leave group%groupname=\$(ask-text 'Enter group name to leave:') && sudo gpasswd -d \"$USER\" \"\$groupname\""
      list_users_in_group="List users in group%groupname=\$(ask-text 'Enter group name to inspect:') && getent group \"\$groupname\""
      add_user_to_group="Add another user to a group%username=\$(ask-text 'Enter username:') && groupname=\$(ask-text 'Enter group name:') && sudo usermod -a -G \"\$groupname\" \"\$username\""
      remove_user_from_group="Remove another user from a group%username=\$(ask-text 'Enter username:') && groupname=\$(ask-text 'Enter group name:') && sudo gpasswd -d \"\$username\" \"\$groupname\""
      create_user="Create new user%username=\$(ask-text 'Enter new username:') && sudo useradd \"\$username\" && printf 'The new user still needs a password. Use Change another user''s password.\\n'"
      delete_user="Delete user%username=\$(ask-text 'Enter username of user to delete:') && sudo userdel \"\$username\""
      ;;
  esac

  # Exit button kills this menu script via TERM signal
  # Menu (child process) evals: kill -TERM $PPID → kills its parent (this script)
  exit_label=$(exit-label)
  exit_item="${exit_label}%kill -TERM \$PPID"

  set -- "$change_my_password" "$list_users" "$change_other_password" "$view_my_groups" "$view_other_groups" "$list_groups" "$create_group" "$delete_group" "$join_group" "$leave_group" "$list_users_in_group" "$add_user_to_group" "$remove_user_from_group" "$create_user" "$delete_user" "$exit_item"
  menu "Users Menu:" "$@"
}

first_run=1

while true; do
  if [ "$first_run" -eq 0 ]; then
    :
  else
    first_run=0
  fi

  users_menu_display_menu || menu_status=$?
  menu_status=${menu_status:-0}
  
  # ESC causes menu to exit with 130 - handle gracefully by exiting
  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi
done
