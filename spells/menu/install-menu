#!/bin/sh

# Present a menu of spells that can install supporting software.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE' >&2
Usage: install-menu

Opens the installation menu so you can browse and launch installer spells for wizardry's optional software.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
spells_dir=$(CDPATH= cd -- "$script_dir/.." && pwd)
install_dir=${INSTALL_MENU_ROOT:-$spells_dir/.arcana}

# Load color palette (colors handles terminal capability detection internally)
# shellcheck source=/dev/null
. "$(command -v colors)"

if ! require menu "The install-menu spell needs the 'menu' command to present choices."; then
    exit 1
fi

# Catch Ctrl-C and TERM signal to exit cleanly
# INT (Ctrl-C) should exit 130, TERM should exit 0
trap 'exit 130' INT
trap 'exit 0' TERM

list_entries() {
    # INSTALL_MENU_DIRS can override discovery for tests or custom menus.
    if [ -n "${INSTALL_MENU_DIRS-}" ]; then
        for name in $INSTALL_MENU_DIRS; do
            printf '%s\n' "$name"
        done
        return
    fi

    if [ ! -d "$install_dir" ]; then
        return
    fi

    preferred_entries="
      core mud web-wizardry wizardry-projects voice ai-dev
      crossposting openstreetmaps wizardry-apps docker yt-dlp webcam
      tor syncthing simplex-chat nostr bitcoin lightning btcpay
    "
    for entry_name in $preferred_entries; do
        if [ -e "$install_dir/$entry_name" ]; then
            printf '%s\n' "$entry_name"
        fi
    done
    
    # Then output all other entries alphabetically
    for entry in "$install_dir"/*; do
        [ -e "$entry" ] || continue
        entry_name=$(basename "$entry")
        # Skip entries we already listed
        listed=0
        for preferred_name in $preferred_entries; do
            if [ "$entry_name" = "$preferred_name" ]; then
                listed=1
                break
            fi
        done
        [ "$listed" -eq 1 ] && continue
        # Gazeta is managed from web wizardry so the root menu keeps a minimum
        # number of submenus while preserving accurate status for standalone apps.
        [ "$entry_name" = "gazeta" ] && continue
        # Theurgy and voice subcomponents stay reachable through their parent
        # submenus so root status stays meaningful without duplicating entries.
        [ "$entry_name" = "theurgy" ] && continue
        [ "$entry_name" = "voice-recognition" ] && continue
        [ "$entry_name" = "voice-audio" ] && continue
        [ "$entry_name" = "import-arcanum" ] && continue
        printf '%s\n' "$entry_name"
    done
}

first_run=1

while :; do
    entries=$(list_entries)

    if [ -z "$entries" ]; then
        die 'install-menu: no installable spells found'
        exit 1
    fi

    if [ "$first_run" -eq 0 ]; then
        :
    else
        first_run=0
    fi

    set --
    for name in $entries; do
        status_cmd=""
        if [ -x "$install_dir/$name-status" ] && [ ! -d "$install_dir/$name-status" ]; then
            status_cmd="$install_dir/$name-status"
        elif [ -x "$install_dir/$name/$name-status" ] && [ ! -d "$install_dir/$name/$name-status" ]; then
            status_cmd="$install_dir/$name/$name-status"
        elif command -v "${name}-status" >/dev/null 2>&1; then
            status_cmd="${name}-status"
        fi

        if [ -n "$status_cmd" ]; then
            status=$($status_cmd)
        else
            status="${GREY}coming soon${RESET}"
        fi

        if [ -x "$install_dir/$name-menu" ] && [ ! -d "$install_dir/$name-menu" ]; then
            cmd="$install_dir/$name-menu"
            # Special handling for mud-menu which must be sourced
            if [ "$name" = "mud" ]; then
                cmd=". $install_dir/$name-menu"
            fi
        elif [ -x "$install_dir/$name/$name-menu" ] && [ ! -d "$install_dir/$name/$name-menu" ]; then
            cmd="$install_dir/$name/$name-menu"
            # Special handling for mud-menu which must be sourced
            if [ "$name" = "mud" ]; then
                cmd=". $install_dir/$name/$name-menu"
            fi
        elif [ -x "$install_dir/$name" ] && [ -f "$install_dir/$name" ]; then
            cmd="$install_dir/$name"
        elif [ -x "$install_dir/$name/$name" ] && [ -f "$install_dir/$name/$name" ]; then
            cmd="$install_dir/$name/$name"
        elif [ -x "$install_dir/$name/install-$name" ] && [ -f "$install_dir/$name/install-$name" ]; then
            cmd="$install_dir/$name/install-$name"
        elif command -v "${name}-menu" >/dev/null 2>&1; then
            cmd="${name}-menu"
            # Special handling for mud-menu which must be sourced
            if [ "$name" = "mud" ]; then
                cmd=". mud-menu"
            fi
        else
            cmd='printf "This entry is not ready yet.\n"'
        fi

        label="$name"
        # Rename labels for better display
        case "$name" in
            core) label="core wizardry" ;;
            mud) label="wizardry MUD" ;;
            web-wizardry) label="web wizardry" ;;
            openstreetmaps) label="OpenStreetMap" ;;
            wizardry-projects) label="wizardry projects" ;;
            wizardry-apps) label="wizardry apps" ;;
            ai-dev) label="AI dev" ;;
            docker) label="Docker" ;;
            yt-dlp) label="yt-dlp" ;;
            webcam) label="webcam" ;;
            voice) label="voice" ;;
            tor) label="Tor" ;;
            syncthing) label="Syncthing" ;;
            simplex-chat) label="SimpleX" ;;
            nostr) label="Nostr" ;;
            crossposting) label="crossposting" ;;
            bitcoin) label="Bitcoin" ;;
            lightning) label="Lightning" ;;
            btcpay) label="BTCPay Server" ;;
        esac
        
        if [ -n "$status" ]; then
            label="$label - $status"
        fi

        # Build the menu entry using the name%command convention expected by
        # the menu cantrip.
        set -- "$@" "${label}%$cmd"
    done

    # Exit button kills this menu script via TERM signal
    # Menu (child process) evals: kill -TERM $PPID → kills its parent (this script)
    exit_label=$(exit-label)
    set -- "$@" "${exit_label}%kill -TERM \$PPID"

    menu "Install Menu:" "$@" || menu_status=$?
    menu_status=${menu_status:-0}
    
    # ESC causes menu to exit with 130 - handle gracefully by exiting
    if [ "$menu_status" -eq 130 ]; then
        printf 'ESC\n' >&2
        exit 0
    fi
done
