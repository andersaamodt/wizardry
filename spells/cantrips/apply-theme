#!/bin/sh

# This spell defines semantic color names for the wizardry interface.
# It imports the base colors palette and maps them to named UI purposes.
# You must source this script with '. apply-theme' to use it.
# Example: printf '%sSelect an option:%s\n' "$MENU_HIGHLIGHT" "$RESET"

set -eu

# Source the base colors palette.
# This gives us access to RED, GREEN, BLUE, CYAN, YELLOW, PURPLE, etc.
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
if [ -f "$SCRIPT_DIR/colors" ]; then
	. "$SCRIPT_DIR/colors"
elif command -v colors >/dev/null 2>&1; then
	. "$(command -v colors)"
else
	# Fallback: define empty values so scripts don't break.
	RESET='' RED='' GREEN='' YELLOW='' BLUE='' PURPLE='' CYAN='' WHITE=''
	BOLD='' BRIGHT_CYAN='' BRIGHT_YELLOW='' GREY=''
fi

# Semantic color mappings for menu interface.
# These names describe purpose rather than appearance, making it easy
to change the theme by editing this one file.

MENU_COMMAND="$CYAN"
MENU_HIGHLIGHT="$BRIGHT_CYAN"
MENU_TITLE="$BOLD"
MENU_BORDER="$GREY"
MENU_DISABLED="$GREY"

# Semantic color mappings for feedback messages.

ERROR_TEXT="$RED"
SUCCESS_TEXT="$GREEN"
WARNING_TEXT="$YELLOW"

# Semantic color mappings for interactive elements.

PROMPT_TEXT="$BRIGHT_YELLOW"
SPELL_NAME="$PURPLE"