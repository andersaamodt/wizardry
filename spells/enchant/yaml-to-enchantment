#!/bin/sh

# This spell reads a YAML front matter block and restores its keys as attributes.
# After the transfer, it trims the prologue so the file holds only its content.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: yaml-to-enchantment <path-to-file>

Parse a YAML front matter header, write each key/value into the file's extended attributes, and rewrite the file without the header.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

if [ "$#" -ne 1 ]; then
    printf '%s\n' "Error: incorrect number of arguments" >&2
    cat >&2 <<'USAGE'
Usage: yaml-to-enchantment <path-to-file>

Parse a YAML front matter header, write each key/value into the file's extended attributes, and rewrite the file without the header.
USAGE
    exit 1
fi

scroll=$1
if [ ! -f "$scroll" ]; then
  printf '%s\n' "Error: file does not exist" >&2
  exit 1
fi

header_count=$(awk '/^---$/{c++} END{print c}' "$scroll")
if [ "$header_count" -lt 2 ]; then
    printf '%s\n' "Error: file does not have a YAML header" >&2
    exit 1
fi

yaml_header=$(awk '
    /^---$/ {delim++; next}
    delim==1 {print}
' "$scroll")

if [ -z "$yaml_header" ]; then
  printf '%s\n' "Error: file does not have a YAML header" >&2
  exit 1
fi

if ! check-attribute-tool attr \
  && ! check-attribute-tool setfattr \
  && ! check-attribute-tool xattr; then
  printf '%s\n' "Error: requires attr, setfattr, or xattr to restore enchantments" >&2
  exit 1
fi

header_tmp=$(temp-file wizardry-header) || exit 1
body_dir=$(dirname "$scroll")
body_name=${scroll##*/}
body_tmp=$(mktemp "$body_dir/.${body_name}.body.XXXXXX") || exit 1
trap 'rm -f "$header_tmp" "$body_tmp"' EXIT HUP INT TERM
printf '%s\n' "$yaml_header" >"$header_tmp"

awk '
    /^---$/ && delim<2 {delim++; next}
    delim<2 {next}
    {print}
' "$scroll" >"$body_tmp"

while IFS= read -r line || [ -n "$line" ]; do
    key=${line%%:*}
    value=${line#*:}
    value=${value# }
    [ -z "$key" ] && continue

    if ! set-attribute "$key" "$value" "$body_tmp" >/dev/null 2>&1; then
        printf '%s\n' "Error: failed to set attribute $key" >&2
        exit 1
    fi
done <"$header_tmp"

mv "$body_tmp" "$scroll"

trap - EXIT HUP INT TERM
rm -f "$header_tmp" "$body_tmp"
