#!/bin/sh

# This spell creates a text file listing all filenames in a folder.
# Use it to generate an index of files in a directory.

case "${1-}" in
--help|--usage|-h)
  cat << 'USAGE'
Usage: file-list <folder>

Create a text file named after the folder that lists all files inside it.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

# Check that a folder path was provided as an argument
if [ "$#" -ne 1 ]; then
  cat >&2 <<'USAGE'
Usage: file-list <folder>

Create a text file named after the folder that lists all files inside it.
USAGE
  exit 2
fi

# Create a text file with the same name as the folder
folder=$1
if [ ! -d "$folder" ]; then
  printf '%s\n' "file-list: not a directory: $folder" >&2
  exit 1
fi

folder_name=$(basename "$folder")
text_file="$folder_name.txt"

# Read all the filenames in the folder and put them in the text file
> "$text_file"
for filename in "$folder"/*; do
  [ -e "$filename" ] || continue
  filename="${filename#./}"
  printf '%s\n' "$(basename "$filename")" >> "$text_file"
done

printf 'Text file created: %s\n' "$text_file"
