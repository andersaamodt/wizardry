#!/bin/sh
# Install Python 3 for Wizardry site helpers.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-python3

Ensures python3 is installed for Wizardry site helpers.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

python3_say() {
  printf '%s\n' "$1"
}

python3_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

python3_run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if command -v run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if python3_has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

if python3_has_cmd python3; then
  python3_say "python3 is already installed"
  exit 0
fi

if python3_has_cmd apt-get; then
  python3_run_privileged apt-get update -y >/dev/null
  python3_run_privileged env DEBIAN_FRONTEND=noninteractive apt-get install -y python3 >/dev/null
elif python3_has_cmd dnf; then
  python3_run_privileged dnf install -y python3 >/dev/null
elif python3_has_cmd brew; then
  brew install python >/dev/null
else
  python3_say "install-python3: no supported package manager found." >&2
  exit 1
fi

if python3_has_cmd python3; then
  python3_say "Installed python3"
  exit 0
fi

python3_say "install-python3: installation incomplete. Ensure python3 is on PATH." >&2
exit 1
