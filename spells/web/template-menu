#!/bin/sh

# Present template selection menu for creating sites.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: template-menu

Displays a menu to select and create a site from templates.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear
. colors

if ! require menu "The template-menu needs the 'menu' command."; then
  exit 1
fi

# Catch Ctrl-C and TERM signal to exit cleanly
trap 'exit 130' INT
trap 'exit 0' TERM

# Ensure Gazeta is installed when the blog template is needed. Other template
# sources are discovered directly from installed project checkouts.
WIZARDRY_DIR=${WIZARDRY_DIR:-$HOME/.wizardry}
ensure_gazeta_cmd="$WIZARDRY_DIR/spells/.arcana/gazeta/install-gazeta"
if ! create-from-template --resolve-template-dir blog >/dev/null 2>&1 && \
  [ -x "$ensure_gazeta_cmd" ]; then
  "$ensure_gazeta_cmd"
fi

# Prompt for site name
printf 'Enter name for new site: '
read -r site_name

if [ -z "$site_name" ]; then
  warn "template-menu: no site name entered"
  exit 1
fi

# Check if site already exists
WEB_ROOT=${WEB_WIZARDRY_ROOT:-$HOME/sites}
if [ -d "$WEB_ROOT/$site_name" ]; then
  die "template-menu: site '$site_name' already exists"
fi

# Template menu
exit_label=$(exit-label)
available_templates=$(create-from-template --list-templates 2>/dev/null || printf '')

if [ -z "$available_templates" ]; then
  die "template-menu: no templates available"
fi

set --
for template_name in $available_templates; do
  case "$template_name" in
    demo)
      set -- "$@" \
        "Demo Site (Interactive CGI demos)%web-wizardry create-from-template \"$site_name\" demo"
      ;;
    blog)
      set -- "$@" \
        "Personal Blog (Content-addressable posts)%web-wizardry create-from-template \"$site_name\" blog"
      ;;
    unix-settings)
      set -- "$@" \
        "UNIX Settings (Local system authority UI)%web-wizardry create-from-template \"$site_name\" unix-settings"
      ;;
    artificer)
      set -- "$@" \
        "Artificer (Local coding assistant)%web-wizardry create-from-template \"$site_name\" artificer"
      ;;
  esac
done
set -- "$@" "${exit_label}%kill -TERM \$PPID"

menu "${BOLD}${CYAN}Select Template for '$site_name'" "$@" || menu_status=$?
menu_status=${menu_status:-0}

# ESC causes menu to exit with 130 - handle gracefully by exiting
if [ "$menu_status" -eq 130 ]; then
  printf 'ESC\n' >&2
  exit 0
fi
