#!/bin/sh

# Create a site from a template.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: create-from-template SITENAME TEMPLATE

Creates a new site by copying a template.

Templates:
  demo    - Interactive demo site with 15+ CGI examples
  unix-settings - Local system authority dashboard (read-only)
  blog    - Personal blog with content-addressable posts
  artificer - Local coding assistant UI + agent backend

Example: create-from-template mysite demo
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

site_name=${1-}
template=${2-}

if [ -z "$site_name" ]; then
  die 2 "create-from-template: SITENAME required"
fi

if [ -z "$template" ]; then
  die 2 "create-from-template: TEMPLATE required"
fi

WEB_ROOT=${WEB_WIZARDRY_ROOT:-$HOME/sites}
SITES_DIR="$WEB_ROOT"
SITE_DIR="$SITES_DIR/$site_name"
WIZARDRY_DIR=${WIZARDRY_DIR:-$HOME/.wizardry}
WIZARDRY_APPS_DIR=${WIZARDRY_APPS_DIR:-$HOME/git/wizardry-apps}

# Check if site already exists
if [ -d "$SITE_DIR" ]; then
  die "create-from-template: site '$site_name' already exists"
fi

# Offer to install web templates if missing or if .web is a symlink (unsupported).
templates_root="$WIZARDRY_APPS_DIR/web"
if [ ! -d "$templates_root" ]; then
  templates_root="$WIZARDRY_APPS_DIR/.web"
fi
if [ ! -d "$templates_root" ]; then
  ensure_templates_cmd="$WIZARDRY_DIR/spells/.arcana/wizardry-apps/ensure-wizardry-apps-component"
  if [ -x "$ensure_templates_cmd" ]; then
    "$ensure_templates_cmd" web-templates
  fi
  if [ -d "$WIZARDRY_APPS_DIR/web" ]; then
    templates_root="$WIZARDRY_APPS_DIR/web"
  elif [ -d "$WIZARDRY_APPS_DIR/.web" ]; then
    templates_root="$WIZARDRY_APPS_DIR/.web"
  fi
fi

template_dir="$templates_root/$template"
shared_theme_dir="$templates_root/.themes"

if [ ! -d "$template_dir" ]; then
  ensure_templates_cmd="$WIZARDRY_DIR/spells/.arcana/wizardry-apps/ensure-wizardry-apps-component"
  if [ -x "$ensure_templates_cmd" ]; then
    "$ensure_templates_cmd" web-templates
  fi
  if [ -d "$WIZARDRY_APPS_DIR/web" ]; then
    templates_root="$WIZARDRY_APPS_DIR/web"
  elif [ -d "$WIZARDRY_APPS_DIR/.web" ]; then
    templates_root="$WIZARDRY_APPS_DIR/.web"
  fi
  template_dir="$templates_root/$template"
  shared_theme_dir="$templates_root/.themes"
fi

if [ ! -d "$template_dir" ]; then
  dev_blog_dir="$HOME/git/nostr-blog"
  if [ "$template" = "blog" ] && [ -d "$dev_blog_dir/pages" ] && [ -d "$dev_blog_dir/static" ] && [ -d "$dev_blog_dir/cgi" ]; then
    template_dir="$dev_blog_dir"
    shared_theme_dir="$dev_blog_dir/static/themes"
  else
    die "create-from-template: template '$template' not found"
  fi
fi

step "Creating site '$site_name' from template '$template'..."

# Copy template to site directory
mkdir -p "$SITE_DIR"
cp -r "$template_dir"/* "$SITE_DIR/"

# Rename to match expected structure
if [ -d "$SITE_DIR/pages" ]; then
  mkdir -p "$SITE_DIR/site"
  mv "$SITE_DIR/pages" "$SITE_DIR/site/"
fi

if [ -d "$SITE_DIR/static" ]; then
  [ ! -d "$SITE_DIR/site" ] && mkdir -p "$SITE_DIR/site"
  mv "$SITE_DIR/static" "$SITE_DIR/site/"
fi

if [ -d "$SITE_DIR/includes" ]; then
  [ ! -d "$SITE_DIR/site" ] && mkdir -p "$SITE_DIR/site"
  mv "$SITE_DIR/includes" "$SITE_DIR/site/"
fi

# Sync shared theme catalog into every site template.
if [ -d "$shared_theme_dir" ]; then
  mkdir -p "$SITE_DIR/site/static/themes"
  cp -f "$shared_theme_dir"/*.css "$SITE_DIR/site/static/themes/" 2>/dev/null || true
fi

# Create additional required directories
mkdir -p "$SITE_DIR/site/uploads"
mkdir -p "$SITE_DIR/build"

# Create site config
cat > "$SITE_DIR/site.conf" <<EOF
# Site configuration for $site_name
site-name=$site_name
site-user=
template=$template
port=8080
domain=localhost
https=false
EOF

cat > "$SITE_DIR/site.allowlist" <<EOF
# List additional absolute paths this site may access.
# One path per line. Lines starting with # are ignored.
EOF

if [ "${WIZARDRY_TEST_HELPERS_ONLY:-0}" = "1" ]; then
  info "Skipping fix-site-security in test mode"
else
  step "Securing site directories for $site_name"
  fix-site-security "$site_name"
fi

success "Site '$site_name' created from template '$template'"
info "Site directory: $SITE_DIR"
info ""
info "Next steps:"
info "  1. Build: web-wizardry build $site_name"
info "  2. Serve: web-wizardry serve $site_name"
info "  3. Visit: http://localhost:8080"
