#!/bin/sh

# Configure nginx for a wizardry web site.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: configure-nginx SITENAME [OPTIONS]

Generates nginx configuration for a website.

Options:
  --port PORT              Port number (default: 8080)
  --domain DOMAIN          Domain name (default: localhost)
  --domain-aliases LIST    Space-separated additional hostnames
  --https                  Enable HTTPS with Let's Encrypt

Examples:
  web-configure-nginx mysite
  web-configure-nginx mysite --port 80 --domain example.com --https
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

site_name=${1-}
if [ -z "$site_name" ]; then
  die 2 "configure-nginx: SITENAME required"
fi

case "$site_name" in
  .|..|*[!a-zA-Z0-9._-]*)
    die 2 "configure-nginx: invalid site name"
    ;;
esac
shift

# Parse options
port=8080
domain=localhost
domain_aliases=
use_https=false

configure_nginx_valid_port() {
  port_value=$1
  case "$port_value" in
    ''|*[!0-9]*|??????*)
      return 1
      ;;
  esac
  [ "$port_value" -ge 1 ] && [ "$port_value" -le 65535 ]
}

configure_nginx_valid_domain() {
  domain_value=$1
  case "$domain_value" in
    ''|.|..|.*|*.|*..*|*[!A-Za-z0-9._-]*)
      return 1
      ;;
  esac
}

valid_nginx_quoted_path() {
  path_value=$1
  newline='
'
  carriage_return=$(printf '\r')
  case "$path_value" in
    ''|*\"*|*\\*|*';'*|*'{'*|*'}'*|*"$newline"*|*"$carriage_return"*)
      return 1
      ;;
  esac
}

configure_nginx_hidden_service_line_matches_site() {
  line=$1
  case "$line" in
    HiddenServiceDir*)
      hidden_service_match_dir=$(printf '%s\n' "$line" | awk '{print $2; exit}')
      hidden_service_match_dir=${hidden_service_match_dir%/}
      [ "${hidden_service_match_dir##*/}" = "$site_name" ]
      ;;
    *)
      return 1
      ;;
  esac
}

while [ $# -gt 0 ]; do
  case "$1" in
    --port)
      port=${2-}
      if [ -z "$port" ]; then
        die 2 "configure-nginx: --port requires value"
      fi
      shift 2
      ;;
    --domain)
      domain=${2-}
      if [ -z "$domain" ]; then
        die 2 "configure-nginx: --domain requires value"
      fi
      shift 2
      ;;
    --domain-aliases)
      domain_aliases=${2-}
      if [ -z "$domain_aliases" ]; then
        die 2 "configure-nginx: --domain-aliases requires value"
      fi
      shift 2
      ;;
    --https)
      use_https=true
      shift
      ;;
    *)
      die 2 "configure-nginx: unknown option '$1'"
      ;;
  esac
done

web_root=${WEB_WIZARDRY_ROOT:-$HOME/sites}
sites_dir="$web_root"
site_dir="$sites_dir/$site_name"

if [ ! -d "$site_dir" ]; then
  die "configure-nginx: site '$site_name' not found"
fi

site_user_default="ww_$(printf '%s' "$site_name" | tr 'A-Z' 'a-z' | tr '.-' '__')"
site_user=$(config-get "$site_dir/site.conf" site-user 2>/dev/null || printf '')
[ -z "$site_user" ] && site_user="$site_user_default"
case "$site_user" in
  ''|.|..|-*|*[!a-zA-Z0-9._-]*)
    die 2 "configure-nginx: invalid site-user in site.conf"
    ;;
esac

site_template=$(config-get "$site_dir/site.conf" template 2>/dev/null || printf '')

# Note: configure-nginx runs as actual user to modify both nginx.conf and site.conf
# nginx.conf is owned by site user, but we can write to it as actual user
# site.conf is owned by actual user (per ownership model)
# This aligns with update-from-template which also modifies source files

# Read existing values from site.conf if options were not provided
# This preserves existing configuration when rebuilding nginx.conf
if [ "$port" = "8080" ] && [ -f "$site_dir/site.conf" ]; then
  # No --port option was given, use existing port from config
  existing_port=$(config-get "$site_dir/site.conf" port 2>/dev/null || echo "")
  if [ -n "$existing_port" ]; then
    port=$existing_port
  fi
fi

if [ "$domain" = "localhost" ] && [ -f "$site_dir/site.conf" ]; then
  # No --domain option was given, use existing domain from config
  existing_domain=$(config-get "$site_dir/site.conf" domain 2>/dev/null || echo "")
  if [ -n "$existing_domain" ]; then
    domain=$existing_domain
  fi
fi

if [ -z "$domain_aliases" ] && [ -f "$site_dir/site.conf" ]; then
  existing_domain_aliases=$(config-get "$site_dir/site.conf" domain-aliases 2>/dev/null || printf '')
  if [ -z "$existing_domain_aliases" ]; then
    existing_domain_aliases=$(config-get "$site_dir/site.conf" domain_aliases 2>/dev/null || printf '')
  fi
  if [ -n "$existing_domain_aliases" ]; then
    domain_aliases=$existing_domain_aliases
  fi
fi

desk_domain=
if [ -f "$site_dir/site.conf" ]; then
  desk_domain=$(config-get "$site_dir/site.conf" desk_domain 2>/dev/null || printf '')
fi

if [ "$use_https" = "false" ] && [ -f "$site_dir/site.conf" ]; then
  # No --https option was given, use existing https setting from config
  existing_https=$(config-get "$site_dir/site.conf" https 2>/dev/null || echo "")
  if [ "$existing_https" = "true" ]; then
    use_https=true
  fi
fi

if ! configure_nginx_valid_port "$port"; then
  die 2 "configure-nginx: invalid port"
fi

if ! configure_nginx_valid_domain "$domain"; then
  die 2 "configure-nginx: invalid domain"
fi

for domain_alias in $domain_aliases; do
  if ! configure_nginx_valid_domain "$domain_alias"; then
    die 2 "configure-nginx: invalid domain-aliases"
  fi
done
if [ -n "$desk_domain" ] && ! configure_nginx_valid_domain "$desk_domain"; then
  die 2 "configure-nginx: invalid desk_domain"
fi

server_names=$domain
seen_server_names=" $domain "
for domain_alias in $domain_aliases; do
  case "$seen_server_names" in
    *" $domain_alias "*)
      continue
      ;;
  esac
  server_names="$server_names $domain_alias"
  seen_server_names="$seen_server_names$domain_alias "
done
if [ -n "$desk_domain" ]; then
  case "$seen_server_names" in
    *" $desk_domain "*)
      ;;
    *)
      server_names="$server_names $desk_domain"
      seen_server_names="$seen_server_names$desk_domain "
      ;;
  esac
fi
server_names="$server_names *.onion"

desk_route_host=
if [ "$site_template" = "desk" ]; then
  desk_route_host=$domain
elif [ -n "$desk_domain" ]; then
  desk_route_host=$desk_domain
fi

desk_host_root_rewrite=
desk_host_path_rewrite=
if [ -n "$desk_route_host" ]; then
  desk_host_root_rewrite="            if (\$host = $desk_route_host) {
                rewrite ^ /pages/desk.html last;
            }"
  desk_host_path_rewrite="            if (\$host = $desk_route_host) {
                rewrite ^ /pages/desk.html last;
            }"
fi

# Create nginx config directory
nginx_conf_dir="$site_dir/nginx"
mkdir -p "$nginx_conf_dir"

# Ensure nginx temp directories exist with proper permissions
# nginx/ is owned by actual user, but may have stale permissions from old sites
# Call fix-site-security to fix ownership/permissions before creating
if [ ! -d "$nginx_conf_dir/temp/client_body" ] || \
   [ ! -d "$nginx_conf_dir/temp/proxy" ] || \
   [ ! -d "$nginx_conf_dir/temp/fastcgi" ] || \
   [ ! -d "$nginx_conf_dir/temp/uwsgi" ] || \
   [ ! -d "$nginx_conf_dir/temp/scgi" ]; then
  # Fix permissions first (handles stale ownership from old wizardry versions)
  has fix-site-security && fix-site-security "$site_name" >/dev/null 2>&1 || true
  # Now create temp directories (fix-site-security may have already created them)
  mkdir -p "$nginx_conf_dir/temp/client_body" 2>/dev/null || true
  mkdir -p "$nginx_conf_dir/temp/proxy" 2>/dev/null || true
  mkdir -p "$nginx_conf_dir/temp/fastcgi" 2>/dev/null || true
  mkdir -p "$nginx_conf_dir/temp/uwsgi" 2>/dev/null || true
  mkdir -p "$nginx_conf_dir/temp/scgi" 2>/dev/null || true
fi

# Path to CGI scripts (site-specific first, then shared)
WIZARDRY_DIR=${WIZARDRY_DIR:-$HOME/.wizardry}
cgi_dir="$WIZARDRY_DIR/spells/.imps/cgi"
site_cgi_dir=$(config-get "$site_dir/site.conf" cgi-dir 2>/dev/null || printf '')
if [ -z "$site_cgi_dir" ]; then
  site_cgi_dir="$site_dir/cgi"
elif [ "${site_cgi_dir#/*}" = "$site_cgi_dir" ]; then
  site_cgi_dir="$site_dir/$site_cgi_dir"
fi
if ! valid_nginx_quoted_path "$site_cgi_dir"; then
  die 2 "configure-nginx: invalid cgi-dir"
fi
if ! valid_nginx_quoted_path "$cgi_dir"; then
  die 2 "configure-nginx: invalid wizardry cgi path"
fi

# Copy mime.types to local directory if not exists
# nginx/ is owned by actual user, so we can write directly
mime_types="$nginx_conf_dir/mime.types"
if [ ! -f "$mime_types" ]; then
  if [ -f /etc/nginx/mime.types ]; then
    cp /etc/nginx/mime.types "$mime_types"
  else
    # Create minimal mime.types if system one doesn't exist
    cat > "$mime_types" <<'MIMETYPES'
types {
    text/html                                        html htm shtml;
    text/css                                         css;
    text/xml                                         xml;
    image/gif                                        gif;
    image/jpeg                                       jpeg jpg;
    application/javascript                           js mjs;
    application/json                                 json;
    text/plain                                       txt;
    image/png                                        png;
    image/svg+xml                                    svg svgz;
    image/webp                                       webp;
    application/pdf                                  pdf;
    application/zip                                  zip;
}
MIMETYPES
  fi
fi

# Generate nginx configuration
nginx_conf="$nginx_conf_dir/nginx.conf"

step "Generating nginx configuration for $site_name"

cat > "$nginx_conf" <<EOF
# nginx configuration for $site_name
# Generated by web-wizardry
# Config version: 4

worker_processes 1;
daemon off;
error_log $site_dir/nginx/error.log warn;
pid $site_dir/nginx/nginx.pid;

events {
    worker_connections 256;
}

http {
    include $nginx_conf_dir/mime.types;
    default_type application/octet-stream;
    
    # Use local temp directories instead of system paths
    client_body_temp_path $nginx_conf_dir/temp/client_body;
    proxy_temp_path $nginx_conf_dir/temp/proxy;
    fastcgi_temp_path $nginx_conf_dir/temp/fastcgi;
    uwsgi_temp_path $nginx_conf_dir/temp/uwsgi;
    scgi_temp_path $nginx_conf_dir/temp/scgi;
    
    access_log $site_dir/nginx/access.log;
    
    sendfile on;
    keepalive_timeout 65;
    
    # Allow larger file uploads (25MB)
    client_max_body_size 25M;
    
    server {
        listen $port;
        # Accept configured domain and any .onion address (for Tor hidden services)
        server_name $server_names;
        
        root $site_dir/build;

        # Agent runs can take minutes; keep FastCGI timeouts high globally.
        fastcgi_connect_timeout 30s;
        fastcgi_send_timeout 900s;
        fastcgi_read_timeout 900s;
        
        # Disable directory listing
        autoindex off;
        
        # Root path should always resolve to the app shell.
        # Using an exact-match block avoids "/" being treated as a
        # directory and returning 403 when autoindex is disabled.
        location = / {
$desk_host_root_rewrite
            try_files /pages/index.html /pages/blog.html =404;
        }

        # Artificer Web lives at /artificer while the temporary public host is
        # desk.andersaamodt.com. Keep it from being swallowed by the Desk host
        # catch-all rewrite.
        location = /artificer {
            try_files /pages/artificer.html =404;
        }

        location ^~ /artificer/ {
            try_files /pages/artificer.html =404;
        }

        # Serve pretty post URLs directly via CGI so post pages render
        # in a single server response (no client-side route repair).
        location ~ ^/posts/([A-Za-z0-9-]+)/?$ {
            rewrite ^/posts/([A-Za-z0-9-]+)/?$ /cgi/blog-open-post?path=posts/\$1.md last;
        }

        # Desk is a private spatial app with room URLs beneath /desk.
        # Serve the Desk shell for every Desk place and let the app load
        # the requested room from the path.
        location ~ ^/desk(?:/.*)?$ {
            try_files /pages/desk.html =404;
        }

        # Deep-link routing:
        # - serve real files when they exist
        # - map extensionless paths (e.g. /oeuvre) to /pages/<slug>.html
        # - finally fall back to the app shell for SPA-like routes
        location / {
$desk_host_path_rewrite
            try_files \$uri \$uri/ /pages\$uri /pages\$uri.html /pages\$uri/index.html /pages/index.html /pages/blog.html;
        }
        
        # Serve pages
        location /pages/ {
            index index.html;
            try_files \$uri \$uri.html \$uri/index.html =404;
        }
        
        # Serve static files
        location /static/ {
            alias $site_dir/build/static/;
        }

        # Authorized attachments are handed off from CGI using X-Accel-Redirect
        # so nginx serves the file bytes directly instead of shell CGI streaming them.
        location /__site-files/ {
            internal;
            alias $sites_dir/.sitedata/$site_name/files/;
        }
        
        # SSE endpoint - requires unbuffered streaming
        location ~ ^/cgi/chat-stream$ {
            # Resolve site-specific CGI first, then shared CGI
            set \$site_cgi "$site_cgi_dir/chat-stream";
            set \$shared_cgi "$cgi_dir/chat-stream";
            set \$cgi_path \$shared_cgi;
            if (-f \$site_cgi) {
                set \$cgi_path \$site_cgi;
            }
            if (!-f \$cgi_path) {
                return 404;
            }
            
            # Disable ALL buffering for Server-Sent Events (critical!)
            # These settings are required for real-time SSE delivery
            fastcgi_buffering off;           # Disable FastCGI buffering
            proxy_buffering off;             # Disable proxy buffering (if used)
            fastcgi_cache off;               # Disable FastCGI cache
            fastcgi_request_buffering off;   # Disable request buffering
            fastcgi_keep_conn on;            # Keep connection alive for streaming
            
            # Force immediate flush by disabling gzip
            gzip off;
            
            # Increase timeouts for long-lived SSE connections
            fastcgi_read_timeout 300s;
            fastcgi_send_timeout 300s;
            
            # FastCGI configuration
            fastcgi_pass unix:$site_dir/nginx/fcgiwrap.sock;
            fastcgi_param SCRIPT_FILENAME \$cgi_path;
            fastcgi_param QUERY_STRING \$query_string;
            fastcgi_param REQUEST_METHOD \$request_method;
            fastcgi_param CONTENT_TYPE \$content_type;
            fastcgi_param CONTENT_LENGTH \$content_length;
            fastcgi_param GATEWAY_INTERFACE CGI/1.1;
            fastcgi_param SERVER_SOFTWARE nginx;
            fastcgi_param REMOTE_ADDR \$remote_addr;
            fastcgi_param REMOTE_PORT \$remote_port;
            fastcgi_param SERVER_ADDR \$server_addr;
            fastcgi_param SERVER_PORT \$server_port;
            fastcgi_param SERVER_NAME \$server_name;
            fastcgi_param SERVER_PROTOCOL \$server_protocol;
            fastcgi_param WIZARDRY_DIR $WIZARDRY_DIR;
            fastcgi_param WIZARDRY_SITE_NAME $site_name;
        }
        
        # CGI execution (site-specific first, then shared)
        location ~ ^/cgi/(.+)$ {
            # Resolve site-specific CGI first, then shared CGI
            set \$cgi_script \$1;
            set \$site_cgi "$site_cgi_dir/\$cgi_script";
            set \$shared_cgi "$cgi_dir/\$cgi_script";
            set \$cgi_path \$shared_cgi;
            if (-f \$site_cgi) {
                set \$cgi_path \$site_cgi;
            }
            if (!-f \$cgi_path) {
                return 404;
            }

            # Allow long-running coding agent requests.
            fastcgi_connect_timeout 30s;
            fastcgi_send_timeout 900s;
            fastcgi_read_timeout 900s;
            
            # FastCGI configuration
            fastcgi_pass unix:$site_dir/nginx/fcgiwrap.sock;
            fastcgi_param SCRIPT_FILENAME \$cgi_path;
            fastcgi_param QUERY_STRING \$query_string;
            fastcgi_param REQUEST_METHOD \$request_method;
            fastcgi_param CONTENT_TYPE \$content_type;
            fastcgi_param CONTENT_LENGTH \$content_length;
            fastcgi_param GATEWAY_INTERFACE CGI/1.1;
            fastcgi_param SERVER_SOFTWARE nginx;
            fastcgi_param REMOTE_ADDR \$remote_addr;
            fastcgi_param REMOTE_PORT \$remote_port;
            fastcgi_param SERVER_ADDR \$server_addr;
            fastcgi_param SERVER_PORT \$server_port;
            fastcgi_param SERVER_NAME \$server_name;
            fastcgi_param SERVER_PROTOCOL \$server_protocol;
            fastcgi_param WIZARDRY_DIR $WIZARDRY_DIR;
            fastcgi_param WIZARDRY_SITE_NAME $site_name;
        }
    }
}
EOF

# Update site config only when values changed so preview restarts do not
# make Headquarters think a fresh build is immediately stale again.
current_port=$(config-get "$site_dir/site.conf" port 2>/dev/null || printf '')
if [ "$current_port" != "$port" ]; then
  config-set "$site_dir/site.conf" port "$port"
fi

current_domain=$(config-get "$site_dir/site.conf" domain 2>/dev/null || printf '')
if [ "$current_domain" != "$domain" ]; then
  config-set "$site_dir/site.conf" domain "$domain"
fi

current_domain_aliases=$(config-get "$site_dir/site.conf" domain-aliases 2>/dev/null || printf '')
if [ -n "$domain_aliases" ] || [ -n "$current_domain_aliases" ]; then
  if [ "$current_domain_aliases" != "$domain_aliases" ]; then
    config-set "$site_dir/site.conf" domain-aliases "$domain_aliases"
  fi
fi

current_https=$(config-get "$site_dir/site.conf" https 2>/dev/null || printf '')
if [ "$current_https" != "$use_https" ]; then
  config-set "$site_dir/site.conf" https "$use_https"
fi

# Update Tor hidden service port if Tor hosting is enabled for this site
if is-tor-installed; then
  tor_config_path=$(torrc-path 2>/dev/null || echo "")
  if [ -n "$tor_config_path" ] && [ -f "$tor_config_path" ]; then
    # Check if Tor hosting is enabled by looking for this site's HiddenServiceDir
    tor_hosting_enabled=0
    while IFS= read -r line; do
      if configure_nginx_hidden_service_line_matches_site "$line"; then
        tor_hosting_enabled=1
        break
      fi
    done < "$tor_config_path"
    if [ "$tor_hosting_enabled" -eq 1 ]; then
      # Tor hosting is enabled for this site - update the port
      step "Updating Tor hidden service port to $port..."
      
      temp_torrc=$(mktemp)
      in_site_block=0
      
      while IFS= read -r line; do
        # Check if we're entering this site's hidden service block
        if configure_nginx_hidden_service_line_matches_site "$line"; then
          in_site_block=1
          printf '%s\n' "$line" >> "$temp_torrc"
          continue
        fi
        
        # If we're in this site's block and hit HiddenServicePort, update it
        if [ "$in_site_block" -eq 1 ]; then
          if printf '%s' "$line" | grep -q "^HiddenServicePort"; then
            printf 'HiddenServicePort 80 127.0.0.1:%s\n' "$port" >> "$temp_torrc"
            in_site_block=0
            continue
          fi
        fi
        
        printf '%s\n' "$line" >> "$temp_torrc"
      done < "$tor_config_path"
      
      sudo cp "$temp_torrc" "$tor_config_path"
      # Preserve existing torrc permissions
      sudo chmod 644 "$tor_config_path"
      rm -f "$temp_torrc"
      
      # Restart Tor to apply changes
      info "Restarting Tor to apply port change..."
      restart-tor >/dev/null 2>&1 || warn "configure-nginx: failed to restart Tor"
    fi
  fi
fi

success "nginx configuration written to $nginx_conf"
info "Port: $port"
info "Domain: $domain"
if [ -n "$domain_aliases" ]; then
  info "Domain aliases: $domain_aliases"
fi

if [ "$use_https" = "true" ]; then
  info "HTTPS: enabled (requires Let's Encrypt setup)"
else
  info "HTTPS: disabled"
fi
