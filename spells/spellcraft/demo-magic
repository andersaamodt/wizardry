#!/bin/sh

# Guided demonstration of wizardry, level by level.
# Safe live casts run against disposable fixtures; unsafe or strongly
# interactive spells are skipped and listed per level.

demo_help_surface() {
  demo_spell=$1
  shift

  help_output=$(demo_run_spell "$demo_spell" "$@" --help 2>&1 || true)
  if [ -z "$help_output" ]; then
    return 0
  fi

  first_help_line=$(printf '%s\n' "$help_output" | sed -n '1p')
  case "$first_help_line" in
    Usage:*)
      printf '%s --help -> %s\n' "$demo_spell" "$first_help_line"
      demonstrated="$demonstrated $demo_spell"
      ;;
  esac
}

demo_help_group() {
  for demo_spell in "$@"; do
    demo_help_surface "$demo_spell"
  done
}

demo_run_spell() {
  demo_spell=$1
  shift

  demo_spell_path=$(command -v "$demo_spell" 2>/dev/null || printf '')
  if [ -z "$demo_spell_path" ]; then
    return 127
  fi

  sh "$demo_spell_path" "$@"
}

demo_level() {
  level=$1
  level_name=$(spell-levels "$level" name)
  spell_list=$(spell-levels "$level" spells)
  imp_list=$(spell-levels "$level" imps)
  demonstrated=""

  printf '\n'
  printf '=== Level %d: %s ===\n' "$level" "$level_name"
  printf '\n'

  case "$level" in
    0)
      printf 'Foundations first: shell, platform, and POSIX discipline.\n'

      detect_posix_output=$(detect-posix 2>&1 || true)
      if [ -n "$detect_posix_output" ]; then
        printf 'detect-posix:\n'
        printf '%s\n' "$detect_posix_output" | sed -n '1,3p'
        demonstrated="$demonstrated detect-posix"
      fi

      if distro_output=$(detect-distro 2>/dev/null); then
        printf 'detect-distro -> %s\n' "$distro_output"
        demonstrated="$demonstrated detect-distro"
      fi

      verify_output=$(verify-posix "$WIZARDRY_DIR/spells/spellcraft/demo-magic" 2>&1 || true)
      if [ -n "$verify_output" ]; then
        printf '%s\n' "$verify_output" | sed -n '1,2p'
        demonstrated="$demonstrated verify-posix"
      fi
      ;;

    1)
      printf 'Validation comes next: every higher art depends on clean discovery.\n'

      validate_output=$(validate-spells banish:wards validate-spells:.wizardry 2>&1 || true)
      if [ -n "$validate_output" ]; then
        printf '%s\n' "$validate_output" | sed -n '1,3p'
        demonstrated="$demonstrated validate-spells"
      fi

      imp_count=$(printf '%s\n' "$imp_list" | wc -w | tr -d ' ')
      printf 'Foundational imps at this tier: %s\n' "$imp_count"
      ;;

    2)
      printf 'The installation substrate stays modest: tiny helpers, clean paths, clear state.\n'

      probe_dir=$(temp-dir demo-magic-level2)
      printf 'temp-dir -> %s\n' "$probe_dir"
      cleanup-dir "$probe_dir"

      printf 'abs-path -> %s\n' "$(abs-path "$demo_workspace/scroll.txt")"
      printf 'env-or DEMO_MAGIC_SENTINEL -> %s\n' "$(env-or DEMO_MAGIC_SENTINEL fallback-value)"
      ;;

    3)
      printf 'Parsing and gloss generation give the command language its shape.\n'

      if generate-glosses --quiet --output "$demo_root/glosses.sh" >/dev/null 2>&1; then
        printf 'generate-glosses:\n'
        sed -n '1,3p' "$demo_root/glosses.sh"
        demonstrated="$demonstrated generate-glosses"
      fi
      ;;

    4)
      printf 'Menu spells stay interactive by design.\n'
      printf 'Only safe, non-interactive casts run here.\n'

      colors_path=$(command -v colors 2>/dev/null || printf '')
      if [ -n "$colors_path" ]; then
        colors_ready=$(
          sh -c '. "$1" >/dev/null 2>&1; printf "%s\n" "${WIZARDRY_COLORS_AVAILABLE-0}"' \
            sh "$colors_path" 2>/dev/null || printf '0'
        )
        case "$colors_ready" in
          1) printf 'colors -> palette ready\n' ;;
          *) printf 'colors -> palette disabled by terminal policy\n' ;;
        esac
        demonstrated="$demonstrated colors"
      fi

      demo_help_group await-keypress main-menu menu

      term_size=$(fathom-terminal 2>/dev/null || printf '')
      if [ -n "$term_size" ]; then
        term_cols=$(printf '%s\n' "$term_size" | sed -n '1p')
        term_rows=$(printf '%s\n' "$term_size" | sed -n '2p')
        if [ -n "$term_rows" ]; then
          printf 'fathom-terminal -> %sx%s\n' "$term_cols" "$term_rows"
        else
          printf 'fathom-terminal -> %s\n' "$term_cols"
        fi
        demonstrated="$demonstrated fathom-terminal"
      else
        printf 'fathom-terminal -> no live TTY in unattended mode\n'
      fi
      ;;

    5)
      printf 'Extended attributes are exercised on a disposable scroll, end to end.\n'

      scroll="$demo_workspace/scroll.txt"
      printf 'A short scroll for metadata.\n' > "$scroll"

      if enchant "$scroll" mood=calm >/dev/null 2>&1; then
        demonstrated="$demonstrated enchant"
        mood_value=$(read-magic "$scroll" mood 2>/dev/null || printf '')
        printf 'xattr round-trip -> mood=%s\n' "${mood_value:-missing}"

        if enchantment-to-yaml "$scroll" >/dev/null 2>&1; then
          demonstrated="$demonstrated enchantment-to-yaml"
          printf 'enchantment-to-yaml:\n'
          sed -n '1,4p' "$scroll"
        fi

        if yaml-to-enchantment "$scroll" >/dev/null 2>&1; then
          demonstrated="$demonstrated yaml-to-enchantment"
          mood_value=$(read-magic "$scroll" user.mood 2>/dev/null || printf '')
          printf 'yaml-to-enchantment -> mood=%s\n' "${mood_value:-missing}"
        fi

        if disenchant "$scroll" mood >/dev/null 2>&1; then
          demonstrated="$demonstrated disenchant"
          if read-magic "$scroll" user.mood >/dev/null 2>&1; then
            printf 'disenchant -> attribute still present\n'
          else
            printf 'disenchant -> attribute cleared\n'
          fi
        fi
      else
        printf 'xattr round-trip skipped: extended attributes unavailable on this host.\n'
      fi
      ;;

    6)
      printf 'Priority lookup is safe to show here.\n'
      printf 'Only fixture-local lookup runs live here.\n'

      priority_card="$demo_workspace/priority.card"
      printf 'priority sample\n' > "$priority_card"
      priority_hash=$(
        {
          printf '%s\n' "$(basename "$priority_card")"
          cat "$priority_card"
        } | cksum | awk '{printf "0x%X\n", $1}'
      )
      get_card_output=$(get-card "$priority_hash" "$demo_workspace" 2>&1 || true)
      if [ -n "$get_card_output" ]; then
        printf 'get-card -> %s\n' "$get_card_output"
        demonstrated="$demonstrated get-card"
      fi
      ;;

    7)
      printf 'Navigation magic should move with intention.\n'
      printf 'The demo records and replays a disposable route.\n'

      route_path="$demo_workspace/routes/alpha/beta"
      mkdir -p "$route_path"

      mark_output=$(mark-location hearth "$route_path" 2>&1 || true)
      if [ -n "$mark_output" ]; then
        printf '%s\n' "$mark_output" | sed -n '1p'
        demonstrated="$demonstrated mark-location"
      fi

      printf 'go-up -> %s\n' "$(go-up 2)"
      demonstrated="$demonstrated go-up"

      jump_script="$WIZARDRY_DIR/spells/translocation/jump-to-marker"
      jump_output=$(
        jump_to_marker_script=$jump_script sh -c '
          jump_script=$jump_to_marker_script
          cd / || exit 1
          set -- hearth
          . "$jump_script" >/dev/null
          pwd -P
        ' 2>&1 || true
      )
      if [ -n "$jump_output" ]; then
        printf 'jump-to-marker -> %s\n' "$jump_output"
        demonstrated="$demonstrated jump-to-marker"
      fi
      ;;

    8)
      printf 'Testing infrastructure proves wizardry can watch itself safely.\n'

      if pocket-dimension --check >/dev/null 2>&1; then
        printf 'pocket-dimension -> available\n'
        demonstrated="$demonstrated pocket-dimension"
      else
        printf 'pocket-dimension -> unavailable on this host\n'
      fi

      wizard_eyes_output=$(
        wizard-eyes "demo-magic keeps mutable work in disposable fixtures." 2>&1 || true
      )
      if [ -n "$wizard_eyes_output" ]; then
        printf '%s\n' "$wizard_eyes_output" | sed -n '1p'
        demonstrated="$demonstrated wizard-eyes"
      fi

      if spellbook-store add hearth "jump-to-marker hearth" >/dev/null 2>&1; then
        printf 'spellbook-store:\n'
        spellbook-store list 2>/dev/null | sed -n '1,2p'
        demonstrated="$demonstrated spellbook-store"
      fi
      ;;

    9)
      printf 'MUD basics read places as rooms, even in a temporary directory.\n'

      room="$demo_workspace/room"
      mkdir -p "$room"
      enchant "$room" title "Reading Nook" >/dev/null 2>&1 || true
      enchant "$room" description "A lantern-lit archive." >/dev/null 2>&1 || true

      look_output=$(look "$room" 2>&1 || true)
      if [ -n "$look_output" ]; then
        printf '%s\n' "$look_output" | sed -n '1,2p'
        demonstrated="$demonstrated look"
      fi

      if SHELL=/bin/zsh check-cd-hook >/dev/null 2>&1; then
        printf 'check-cd-hook -> installed\n'
        demonstrated="$demonstrated check-cd-hook"
      else
        printf 'check-cd-hook -> not installed\n'
      fi
      ;;

    10)
      printf 'Arcane file operations stay inside a throwaway workshop.\n'

      ops_dir="$demo_workspace/arcane"
      rm -rf "$ops_dir"
      mkdir -p "$ops_dir"
      printf 'brief notes\n' > "$ops_dir/brief.md"
      printf 'oak\n' > "$ops_dir/oak.txt"
      printf 'ash\n' > "$ops_dir/ash.txt"

      if enchant "$ops_dir/oak.txt" sigil=oak >/dev/null 2>&1; then
        sigil_value=$(read-magic "$ops_dir/oak.txt" sigil 2>/dev/null || printf '')
        printf 'read-magic -> sigil=%s\n' "${sigil_value:-missing}"
        demonstrated="$demonstrated read-magic"
      fi

      if file-to-folder "$ops_dir/brief.md" >/dev/null 2>&1; then
        printf 'file-to-folder:\n'
        find "$ops_dir/brief.md" -maxdepth 2 -print | sort
        demonstrated="$demonstrated file-to-folder"
      fi

      forall_output=$(cd "$ops_dir" && forall file 2>&1 || true)
      if [ -n "$forall_output" ]; then
        printf 'forall:\n'
        printf '%s\n' "$forall_output" | sed -n '1,4p'
        demonstrated="$demonstrated forall"
      fi

      jump_trash_script="$WIZARDRY_DIR/spells/arcane/jump-trash"
      jump_trash_output=$(
        sh -c 'cd / || exit 1; . "$1" >/dev/null; pwd -P' sh "$jump_trash_script" 2>&1 || true
      )
      if [ -n "$jump_trash_output" ]; then
        printf 'jump-trash -> %s\n' "$jump_trash_output"
        demonstrated="$demonstrated jump-trash"
      fi
      ;;

    11)
      printf 'Basic cantrips should feel small, legible, and immediate.\n'

      if printf 'y\n' | ask-yn "Proceed with cantrips?" yes >/dev/null 2>&1; then
        printf 'ask-yn -> yes\n'
        demonstrated="$demonstrated ask-yn"
      fi

      ask_number_output=$(printf '7\n' | ask-number "Lucky?" 1 9 2>/dev/null || true)
      if [ -n "$ask_number_output" ]; then
        printf 'ask-number -> %s\n' "$ask_number_output"
        demonstrated="$demonstrated ask-number"
      fi

      max_output=$(max-length -v "arcane rune wizardry" 2>&1 || true)
      if [ -n "$max_output" ]; then
        printf '%s\n' "$max_output" | sed -n '1,2p'
        demonstrated="$demonstrated max-length"
      fi

      list_output=$(list-files "$demo_workspace" -t f 2>&1 || true)
      if [ -n "$list_output" ]; then
        printf 'list-files:\n'
        printf '%s\n' "$list_output" | sed -n '1,3p'
        demonstrated="$demonstrated list-files"
      fi
      ;;

    12)
      printf 'Configuration spells should be direct, atomic, and reversible.\n'

      config_file="$demo_workspace/demo.conf"
      config set "$config_file" theme amber >/dev/null
      printf 'config get -> %s\n' "$(config get "$config_file" theme)"
      if config has "$config_file" theme >/dev/null 2>&1; then
        printf 'config has -> present\n'
      fi
      config del "$config_file" theme >/dev/null
      if config has "$config_file" theme >/dev/null 2>&1; then
        printf 'config del -> still present\n'
      else
        printf 'config del -> removed\n'
      fi
      demonstrated="$demonstrated config"

      package_manager_output=$(demo_run_spell package-managers 2>&1 || true)
      if [ -n "$package_manager_output" ]; then
        printf '%s\n' "$package_manager_output" | sed -n '1,2p'
        demonstrated="$demonstrated package-managers"
      fi
      ;;

    13)
      printf 'System maintenance spells mutate the host.\n'
      printf 'Only their help surfaces are shown here.\n'

      demo_help_group kill-process update-all update-wizardry
      ;;

    14)
      printf 'This tier holds demo-magic itself and the teaching wrapper around casts.\n'
      printf 'The spell currently speaking is demo-magic itself.\n'
      demonstrated="$demonstrated demo-magic"

      wizard_cast_output=$(wizard-cast printf 'spark\n' 2>&1 || true)
      if [ -n "$wizard_cast_output" ]; then
        printf '%s\n' "$wizard_cast_output" | sed -n '1,2p'
        demonstrated="$demonstrated wizard-cast"
      fi
      ;;

    15)
      printf 'Divination gathers signals from the fixture workspace.\n'

      divination_scroll="$demo_workspace/divination-scroll.txt"
      printf 'quiet ward\n' > "$divination_scroll"
      enchant "$divination_scroll" aura=quiet >/dev/null 2>&1 || true
      printf 'divination-scroll.txt -> prepared fixture\n'

      detect_magic_output=$(cd "$demo_workspace" && detect-magic 2>&1 || true)
      if [ -n "$detect_magic_output" ]; then
        printf 'detect-magic:\n'
        printf '%s\n' "$detect_magic_output" | sed -n '1,4p'
        demonstrated="$demonstrated detect-magic"
      fi

      rc_output=$(SHELL=/bin/zsh detect-rc-file 2>&1 || true)
      if [ -n "$rc_output" ]; then
        printf 'detect-rc-file:\n'
        printf '%s\n' "$rc_output" | sed -n '1,3p'
        demonstrated="$demonstrated detect-rc-file"
      fi

      room_output=$(identify-room "${TMPDIR:-/tmp}" 2>&1 || true)
      if [ -n "$room_output" ]; then
        printf 'identify-room:\n'
        printf '%s\n' "$room_output" | sed -n '1,2p'
        demonstrated="$demonstrated identify-room"
      fi
      ;;

    16)
      printf 'Advanced MUD features add state and character sheets inside the sandboxed fiction.\n'

      sanctum="$demo_workspace/sanctum"
      mkdir -p "$sanctum"
      if decorate "$sanctum" "A lantern-lit archive." >/dev/null 2>&1; then
        printf 'decorate -> description applied\n'
        demonstrated="$demonstrated decorate"
      fi

      avatar="$demo_workspace/avatar"
      : > "$avatar"
      enchant "$avatar" max_life=100 >/dev/null 2>&1 || true
      enchant "$avatar" damage=15 >/dev/null 2>&1 || true
      enchant "$avatar" mana=42 >/dev/null 2>&1 || true
      enchant "$avatar" max_mana=50 >/dev/null 2>&1 || true
      enchant "$avatar" experience=7 >/dev/null 2>&1 || true
      stats_output=$(stats "$avatar" 2>&1 || true)
      if [ -n "$stats_output" ]; then
        printf '%s\n' "$stats_output" | sed -n '1,5p'
        demonstrated="$demonstrated stats"
      fi
      printf 'Only fixture-local description and stat reads run here.\n'
      ;;

    17)
      printf 'Cryptography gets a live checksum and, when possible, a reversible search.\n'

      hash_output=$("$WIZARDRY_DIR/spells/crypto/hash" hash 2>&1 || true)
      hash_value=$(printf '%s\n' "$hash_output" | sed -n '2p')
      if [ -n "$hash_value" ]; then
        printf 'hash -> %s\n' "$hash_value"
        demonstrated="$demonstrated hash"
      fi

      hash_card="$demo_workspace/hash-card.txt"
      printf 'cipher text\n' > "$hash_card"
      hashchant_output=$(hashchant "$hash_card" 2>&1 || true)
      hashchant_value=$(
        printf '%s\n' "$hashchant_output" |
          sed -n 's/.*\(0x[0-9A-F][0-9A-F]*\).*/\1/p' |
          sed -n '1p'
      )
      if [ -n "$hashchant_value" ]; then
        printf 'hashchant -> %s\n' "$hashchant_value"
        demonstrated="$demonstrated hashchant"
      fi

      if [ -n "$hashchant_value" ]; then
        evoke_output=$(evoke-hash "$hashchant_value" "$demo_workspace" 2>&1 || true)
        case "$evoke_output" in
          ''|No\ file\ found*)
            printf 'evoke-hash skipped: hash attribute not visible on this host.\n'
            ;;
          *)
            printf 'evoke-hash -> %s\n' "$evoke_output"
            demonstrated="$demonstrated evoke-hash"
            ;;
        esac
      fi
      ;;

    18)
      printf 'Remote-access magic starts with input validation before any network side effects.\n'

      ssh_demo_key="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMagicDemoKey wizard@example"
      if demo_run_spell validate-ssh-key "$ssh_demo_key" >/dev/null 2>&1; then
        printf 'validate-ssh-key -> valid ed25519 public key\n'
        demonstrated="$demonstrated validate-ssh-key"
      fi
      demo_help_group close-portal enchant-portkey follow-portkey open-portal open-teletype
      printf 'Only key validation runs live here.\n'
      ;;

    19)
      printf 'Security wards are intentionally conservative here.\n'
      printf 'Only the help surface is shown here.\n'

      demo_help_group ssh-barrier
      ;;

    20)
      printf 'Task state is exercised directly.\n'
      printf 'Only reversible task-state casts run here.\n'

      task_file="$demo_workspace/checklist.txt"
      printf 'ritual\n' > "$task_file"

      if check "$task_file" >/dev/null 2>&1; then
        printf 'get-checked -> %s\n' "$(get-checked "$task_file" 2>/dev/null || printf '?')"
        demonstrated="$demonstrated check get-checked"
      fi

      if uncheck "$task_file" >/dev/null 2>&1; then
        printf 'get-checked -> %s\n' "$(get-checked "$task_file" 2>/dev/null || printf '?')"
        demonstrated="$demonstrated uncheck"
      fi
      ;;

    21)
      printf 'Spellcraft tools should verify and explain themselves with minimal ceremony.\n'

      lint_output=$(lint-magic "$WIZARDRY_DIR/spells/spellcraft/demo-magic" 2>&1 || true)
      if [ -n "$lint_output" ]; then
        printf '%s\n' "$lint_output" | sed -n '1,5p'
        demonstrated="$demonstrated lint-magic"
      fi

      compile_output=$(compile-spell hash 2>&1 || true)
      if [ -n "$compile_output" ]; then
        printf 'compile-spell:\n'
        printf '%s\n' "$compile_output" | sed -n '1,4p'
        demonstrated="$demonstrated compile-spell"
      fi
      ;;

    22)
      printf 'Core menu infrastructure is safest to sample through its view and discovery paths.\n'

      demo_help_group spell-menu

      spellbook_help=$(spellbook --help 2>&1 || true)
      if [ -n "$spellbook_help" ]; then
        printf 'spellbook --help -> %s\n' "$(printf '%s\n' "$spellbook_help" | sed -n '1p')"
        demonstrated="$demonstrated spellbook"
      fi

      cast_dir=$(cast --dir 2>&1 || true)
      if [ -n "$cast_dir" ]; then
        printf 'cast --dir -> %s\n' "$cast_dir"
        demonstrated="$demonstrated cast"
      fi
      ;;

    23)
      printf 'System and configuration menus are sampled through their stable help surfaces.\n'

      demo_help_group install-menu synonym-menu system-menu thesaurus
      ;;

    24)
      printf 'MUD administration menus are present.\n'
      printf 'Only stable help surfaces run here.\n'

      demo_help_group add-player mud mud-admin-menu mud-menu mud-settings new-player set-player
      ;;

    25)
      printf 'Domain-specific menus expose focused surfaces for services and networks.\n'

      demo_help_group \
        network-menu priority-menu profile-tests services-menu \
        shutdown-menu users-menu
      ;;

    26)
      printf 'Service management is represented through its non-mutating inspection surfaces.\n'

      demo_help_group \
        disable-service enable-service install-service-template is-service-installed \
        reload-ssh remove-service restart-service restart-ssh service-status \
        start-service stop-service
      ;;

    27)
      printf 'Arcana stays optional by design.\n'
      printf 'Extensions remain visible without being forced into the core ritual.\n'

      arcana_count=$(
        find "$WIZARDRY_DIR/spells/.arcana" -type f 2>/dev/null |
          awk 'END { print NR + 0 }'
      )
      printf 'Arcana files present -> %s\n' "$arcana_count"

      import_help=$(import-arcanum --help 2>&1 || true)
      if [ -n "$import_help" ]; then
        printf 'import-arcanum --help -> %s\n' "$(printf '%s\n' "$import_help" | sed -n '1p')"
        demonstrated="$demonstrated import-arcanum"
      fi
      ;;

    28)
      printf 'Web services are sampled through a throwaway site tree.\n'

      site_dir="$HOME/sites/demo-site"
      mkdir -p "$site_dir/build/pages"
      printf '<h1>Demo</h1>\n' > "$site_dir/build/pages/index.html"
      site_status_output=$(site-status demo-site 2>&1 || true)
      if [ -n "$site_status_output" ]; then
        printf 'site-status -> %s\n' "$site_status_output"
        demonstrated="$demonstrated site-status"
      fi
      demo_help_group \
        build change-site-port configure-nginx create-from-template create-site \
        create-site-prompt delete-site diagnose-sse https rename-site serve-site \
        site-autorebuild site-menu stop-site template-menu update-from-template \
        web-wizardry
      printf 'Only the fixture-local site status read runs here.\n'
      ;;
  esac

  if [ -n "$spell_list" ]; then
    printf '\n'
    printf '%s\n' '---'

    spell_names=$(printf '%s\n' "$spell_list" | tr ' ' '\n' | sed '/^$/d; s/:.*//')
    spell_count=$(printf '%s\n' "$spell_names" | awk 'NF { c++ } END { print c + 0 }')
    not_demonstrated=""

    for spell_name in $spell_names; do
      case " $demonstrated " in
        *" $spell_name "*) : ;;
        *) not_demonstrated="$not_demonstrated $spell_name" ;;
      esac
    done

    demonstrated_count=0
    for spell_name in $spell_names; do
      case " $demonstrated " in
        *" $spell_name "*)
          demonstrated_count=$((demonstrated_count + 1))
          ;;
      esac
    done
    printf 'Demonstrated safely: %s/%s\n' "$demonstrated_count" "$spell_count"

    if [ -n "$not_demonstrated" ]; then
      not_demo_list=$(printf '%s\n' "$not_demonstrated" | tr -s ' ' | sed 's/^ //; s/ /, /g')
      printf 'Skipped: %s\n' "$not_demo_list"
    fi
  elif [ -n "$imp_list" ]; then
    printf '\n'
    printf '%s\n' '---'
    printf 'Imps available at this level: %s\n' "$(printf '%s\n' "$imp_list" | wc -w | tr -d ' ')"
  fi

  return 0
}

# Detect WIZARDRY_DIR when the spell is executed directly.
if [ -z "${WIZARDRY_DIR-}" ]; then
  if command -v dirname >/dev/null 2>&1 \
    && command -v cd >/dev/null 2>&1 \
    && command -v pwd >/dev/null 2>&1; then
    script_dir=$(CDPATH= cd -- "$(dirname "$0")" 2>/dev/null && pwd -P) || script_dir=""
    if [ -n "$script_dir" ]; then
      wiz_root=$(CDPATH= cd -- "$script_dir/../.." 2>/dev/null && pwd -P) || wiz_root=""
      if [ -n "$wiz_root" ] && [ -d "$wiz_root/spells" ]; then
        WIZARDRY_DIR=$wiz_root
        export WIZARDRY_DIR
      fi
    fi
  fi

  if [ -z "${WIZARDRY_DIR-}" ] && [ -n "${HOME-}" ] && [ -d "${HOME}/.wizardry/spells" ]; then
    WIZARDRY_DIR="${HOME}/.wizardry"
    export WIZARDRY_DIR
  fi
fi

demo_levels_path=""
demo_max_level=28
if [ -n "${WIZARDRY_DIR-}" ] && [ -x "${WIZARDRY_DIR}/spells/.imps/sys/spell-levels" ]; then
  demo_levels_path="${WIZARDRY_DIR}/spells/.imps/sys/spell-levels"
  demo_probe_level=0
  demo_max_level=0
  while "$demo_levels_path" "$demo_probe_level" name >/dev/null 2>&1; do
    demo_max_level=$demo_probe_level
    demo_probe_level=$((demo_probe_level + 1))
  done
fi

case "${1-}" in
  --help|--usage|-h)
    cat <<USAGE
Usage: demo-magic [LEVEL|all]

Guide wizardry level by level with real casts against disposable fixtures.
Unsafe or strongly interactive spells are skipped and listed per level.

Arguments:
  LEVEL               Run levels 0 through LEVEL
  all                 Run every level (default)

Options:
  --demo-in-pocket    Internal flag used after pocket-dimension re-exec
  --help, --usage, -h Show this help text

Current level range: 0-$demo_max_level
USAGE
    exit 0
    ;;
esac

demo_exact_level=0
case "${DEMO_MAGIC_EXACT_LEVEL-0}" in
  1|yes|true)
    demo_exact_level=1
    ;;
esac

demo_no_bwrap=0
case "${WIZARDRY_DEMO_NO_BWRAP-0}" in
  1|yes|true)
    demo_no_bwrap=1
    ;;
esac

demo_no_sandbox=0
case "${WIZARDRY_DEMO_NO_SANDBOX-0}" in
  1|yes|true)
    demo_no_sandbox=1
    ;;
esac

demo_bwrap_install_attempted=0
case "${WIZARDRY_DEMO_BWRAP_INSTALL_ATTEMPTED-0}" in
  1|yes|true)
    demo_bwrap_install_attempted=1
    ;;
esac

demo_in_github_actions=0
case "${GITHUB_ACTIONS-}" in
  true|1|yes)
    demo_in_github_actions=1
    ;;
esac

set -eu
. env-clear

if [ -z "${WIZARDRY_DIR-}" ] || [ ! -d "${WIZARDRY_DIR}/spells" ]; then
  printf '%s\n' "demo-magic: WIZARDRY_DIR is not set to a wizardry installation" >&2
  exit 1
fi

imp_path="${WIZARDRY_DIR}/spells/.imps/sys"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/cond"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/out"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/fs"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/str"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/paths"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/text"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/input"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/lex"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/menu"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/pkg"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/test"
imp_path="$imp_path:${WIZARDRY_DIR}/spells/.imps/lang"
PATH="$imp_path:$PATH"

PATH="${WIZARDRY_DIR}/spells/.wizardry:$PATH"
for dir in "$WIZARDRY_DIR"/spells/*; do
  [ -d "$dir" ] || continue
  PATH="$dir:$PATH"
done
export PATH

demo_target_level=$demo_max_level
demo_in_pocket=0

while [ "$#" -gt 0 ]; do
  case "${1-}" in
    --demo-in-pocket)
      demo_in_pocket=1
      shift
      ;;
    all)
      demo_target_level=$demo_max_level
      shift
      ;;
    [0-9]|[0-9][0-9])
      demo_target_level=$1
      shift
      ;;
    -*)
      printf 'demo-magic: unknown option: %s\n' "$1" >&2
      exit 2
      ;;
    *)
      printf 'demo-magic: invalid level: %s\n' "$1" >&2
      exit 2
      ;;
  esac
done

if [ "$demo_target_level" -gt "$demo_max_level" ]; then
  printf 'demo-magic: level %s is out of range (0-%s)\n' "$demo_target_level" "$demo_max_level" >&2
  exit 2
fi

# Keep WIZARDRY_DEMO_NO_BWRAP for backward compatibility with existing callers.
if [ "$demo_in_pocket" -ne 1 ] \
  && [ "$demo_no_bwrap" -ne 1 ] \
  && [ "$demo_no_sandbox" -ne 1 ]; then
  if [ "$demo_in_github_actions" -ne 1 ]; then
    if command -v pocket-dimension >/dev/null 2>&1 && pocket-dimension --check >/dev/null 2>&1; then
      if [ "$demo_exact_level" -eq 1 ]; then
        exec env DEMO_MAGIC_EXACT_LEVEL=1 \
          pocket-dimension -- "$0" --demo-in-pocket "$demo_target_level"
      fi
      exec pocket-dimension -- "$0" --demo-in-pocket "$demo_target_level"
    fi

    printf 'demo-magic: pocket-dimension sandbox unavailable\n' >&2
    printf '%s\n' "demo-magic: disposable fixtures still contain every mutable cast." >&2
    printf '%s\n' "demo-magic: sandboxing remains preferred." >&2

    demo_interactive=0
    if { [ -t 0 ] || [ -t 1 ] || [ -t 2 ]; } \
      && [ -r /dev/tty ] && [ -w /dev/tty ]; then
      demo_interactive=1
    fi

    if [ "$demo_interactive" -eq 1 ] \
      && [ "$demo_bwrap_install_attempted" -ne 1 ] \
      && command -v ask-yn >/dev/null 2>&1 \
      && command -v pkg-install >/dev/null 2>&1; then
      demo_platform=$(uname -s 2>/dev/null || printf 'unknown')
      if [ "$demo_platform" = "Linux" ] \
        && ask-yn "Install bubblewrap now for pocket-dimension?" yes; then
        printf 'Installing bubblewrap...\n' >&2
        if pkg-install bubblewrap 2>/dev/null || pkg-install bwrap 2>/dev/null; then
          if command -v pocket-dimension >/dev/null 2>&1 \
            && pocket-dimension --check >/dev/null 2>&1; then
            printf 'Bubblewrap installed successfully. Re-running demo-magic...\n' >&2
            if [ "$demo_exact_level" -eq 1 ]; then
              exec env WIZARDRY_DEMO_BWRAP_INSTALL_ATTEMPTED=1 DEMO_MAGIC_EXACT_LEVEL=1 \
                "$0" "$demo_target_level"
            fi
            exec env WIZARDRY_DEMO_BWRAP_INSTALL_ATTEMPTED=1 "$0" "$demo_target_level"
          fi
          printf 'demo-magic: pocket-dimension still unavailable after install attempt\n' >&2
        else
          printf 'demo-magic: failed to install bubblewrap\n' >&2
        fi
      fi
    fi

    if [ "$demo_interactive" -eq 1 ] && command -v ask-yn >/dev/null 2>&1; then
      if ! ask-yn "Continue without sandbox?" no; then
        printf 'demo-magic: aborting\n' >&2
        exit 1
      fi
    else
      printf '%s\n' "demo-magic: non-interactive mode, continuing without sandbox" >&2
      printf '%s\n' "demo-magic: set WIZARDRY_DEMO_NO_SANDBOX=1" >&2
      printf '%s\n' "demo-magic: or WIZARDRY_DEMO_NO_BWRAP=1 to silence this" >&2
    fi
  fi
fi

demo_root=$(temp-dir demo-magic)
trap 'rm -rf "$demo_root"' EXIT HUP INT TERM
demo_home="$demo_root/home"
demo_spellbook="$demo_root/spellbook"
demo_workspace="$demo_root/workspace"

mkdir -p \
  "$demo_home" \
  "$demo_home/.Trash" \
  "$demo_home/.local/share/Trash/files" \
  "$demo_home/sites" \
  "$demo_spellbook" \
  "$demo_workspace" \
  "$demo_workspace/routes/alpha/beta" \
  "$demo_workspace/room" \
  "$demo_workspace/sanctum"

printf '# >>> wizardry cd cantrip >>>\n' > "$demo_home/.zshrc"
printf 'seed scroll\n' > "$demo_workspace/scroll.txt"
printf 'seed note\n' > "$demo_workspace/source.txt"

HOME=$demo_home
SPELLBOOK_DIR=$demo_spellbook
XDG_DATA_HOME=$demo_home/.local/share
export HOME SPELLBOOK_DIR XDG_DATA_HOME

printf '\n'
printf 'Wizardry Demo\n'
printf '=============\n'
printf 'Disposable fixtures: %s\n' "$demo_root"
printf 'Every mutable cast below runs inside that throwaway workspace.\n'
printf 'Unsafe or strongly interactive spells are skipped and listed per level.\n'

current_level=0
if [ "$demo_exact_level" -eq 1 ]; then
  current_level=$demo_target_level
fi
while [ "$current_level" -le "$demo_target_level" ]; do
  demo_level "$current_level"
  current_level=$((current_level + 1))
done

printf '\n'
printf 'The circle clears.\n'
printf 'Disposable fixtures removed on exit.\n'
exit 0
