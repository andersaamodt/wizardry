#!/bin/sh

# This spell merges YAML and text files with matching names in a directory.
# Use it to combine .yaml metadata with .txt content into single files.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: merge-yaml-text [directory] [-v|--verbose] [--dry-run]

Merge .yaml metadata and .txt content that share a basename into a single combined file. Works in the current directory by default, with verbose output or dry-run mode available for careful runs.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

dir='.'
dir_seen=0
verbose=0
dryrun=0

# Parse optional flags and at most one directory, accepting flags before or
# after the directory.
while [ "$#" -gt 0 ]; do
  case $1 in
    -v|--verbose)
      verbose=1
      ;;
    --dry-run)
      dryrun=1
      ;;
    -*)
      printf '%s\n' "merge-yaml-text: unknown option '$1'" >&2
      exit 2
      ;;
    *)
      if [ "$dir_seen" -eq 1 ]; then
        printf '%s\n' "merge-yaml-text: expected at most one directory" >&2
        exit 2
      fi
      dir=$1
      dir_seen=1
      ;;
  esac
  shift
done

# ensure directory ends with /
case "$dir" in
  */) ;;
  *) dir="$dir/" ;;
esac

# count total .yaml files in the directory
total_files=$(find "${dir}" -maxdepth 1 -name "*.yaml" 2>/dev/null | wc -l | tr -d ' ')

# loop through .yaml files
count=0
for yaml in "${dir}"*.yaml; do
  # Skip if no yaml files found
  [ -f "$yaml" ] || continue
  
  # Remove directory and extension from filename
  yaml_base=$(basename "$yaml" .yaml)
  
  # Formulate the .txt filename
  txt_filename="${yaml_base}.txt"
  
  # Find matching .txt file
  txt_file="${dir}${txt_filename}"
  
  # Check if .txt file exists
  if [ -f "$txt_file" ]; then
    # create temp file
    tmpfile=$(mktemp "${dir}merge-yaml-text.XXXXXX") || exit 1

    # Check if yaml file starts with '---'
    first_line=$(head -n 1 "$yaml")
    if [ "$first_line" != "---" ]; then
      printf '%s\n' '---' > "$tmpfile"
    fi

    # append the yaml content
    cat "$yaml" >> "$tmpfile"

    # Check if yaml file ends with '---'
    last_line=$(tail -n 1 "$yaml")
    if [ "$last_line" != "---" ]; then
      printf '%s\n' '---' >> "$tmpfile"
    fi

    # append the txt content
    cat "$txt_file" >> "$tmpfile"

    # if not a dry-run, replace original yaml with the new file and remove the txt file
    if [ "$dryrun" -ne 1 ]; then
      mv "$tmpfile" "$yaml"
      rm -f "$txt_file"
    else
      # if a dry-run, display the constructed content
      cat "$tmpfile"
      # delete the temporary file
      rm -f "$tmpfile"
    fi

    # increase count
    count=$((count + 1))

    # if verbose mode is on, print progress
    if [ "$verbose" -eq 1 ]; then
      info "($count/$total_files) Merged: $yaml"
    fi
  fi
done
