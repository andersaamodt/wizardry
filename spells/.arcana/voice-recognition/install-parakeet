#!/bin/sh

# Install the Parakeet backend for local dictation on Linux NVIDIA hosts.

case "${1-}" in
  --help|--usage|-h)
    cat <<'USAGE'
Usage: install-parakeet

Installs Parakeet in a local voice-recognition runtime.
USAGE
    exit 0
    ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
VR_ARCANA_DIR=$script_dir
export VR_ARCANA_DIR
# shellcheck source=/dev/null
. "$script_dir/voice-recognition-common"

vr_install_component "parakeet"
