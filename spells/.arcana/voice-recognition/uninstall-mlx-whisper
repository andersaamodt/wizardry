#!/bin/sh

# Remove the MLX-Whisper backend for local dictation.

case "${1-}" in
  --help|--usage|-h)
    cat <<'USAGE'
Usage: uninstall-mlx-whisper

Removes the local mlx-whisper runtime.
USAGE
    exit 0
    ;;
esac

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
if ! command -v require-wizardry >/dev/null 2>&1; then
  wizardry_dir=$(CDPATH= cd -- "$script_dir/../../.." && pwd -P)
  PATH="$wizardry_dir/spells/.imps/sys:$wizardry_dir/spells/.imps/out:$wizardry_dir/spells/.imps/cond:$wizardry_dir/spells/.imps/pkg:$wizardry_dir/spells/cantrips:$PATH"
  export PATH WIZARDRY_DIR="$wizardry_dir"
fi
require-wizardry || exit 1

set -eu
. env-clear

VR_ARCANA_DIR=$script_dir
export VR_ARCANA_DIR
# shellcheck source=/dev/null
. "$script_dir/voice-recognition-common"

vr_uninstall_component "mlx-whisper"
