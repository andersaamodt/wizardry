#!/bin/sh

# Install the CTranslate2 Whisper backend for local dictation.

case "${1-}" in
  --help|--usage|-h)
    cat <<'USAGE'
Usage: install-ctranslate2-whisper

Installs CTranslate2 Whisper (via whisper-ctranslate2)
in a local voice-recognition runtime.
USAGE
    exit 0
    ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
VR_ARCANA_DIR=$script_dir
export VR_ARCANA_DIR
# shellcheck source=/dev/null
. "$script_dir/voice-recognition-common"

vr_install_component "ctranslate2-whisper"
