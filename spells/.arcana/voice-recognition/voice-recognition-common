#!/bin/sh

# Shared helpers for the voice-recognition arcanum.

vr_root_dir=${WIZARDRY_VOICE_RECOGNITION_DIR:-$HOME/.wizardry/voice-recognition}
vr_hf_home=${WIZARDRY_VOICE_RECOGNITION_HF_HOME:-$vr_root_dir/huggingface}

vr_uname_s() {
  if [ -n "${WIZARDRY_VOICE_UNAME_S-}" ]; then
    printf '%s\n' "$WIZARDRY_VOICE_UNAME_S"
    return 0
  fi
  uname -s 2>/dev/null || printf 'unknown\n'
}

vr_uname_m() {
  if [ -n "${WIZARDRY_VOICE_UNAME_M-}" ]; then
    printf '%s\n' "$WIZARDRY_VOICE_UNAME_M"
    return 0
  fi
  uname -m 2>/dev/null || printf 'unknown\n'
}

vr_is_macos() {
  [ "$(vr_uname_s)" = "Darwin" ]
}

vr_is_linux() {
  [ "$(vr_uname_s)" = "Linux" ]
}

vr_is_macos_apple_silicon() {
  if ! vr_is_macos; then
    return 1
  fi

  case "$(vr_uname_m)" in
    arm64|aarch64) return 0 ;;
    *) return 1 ;;
  esac
}

vr_has_nvidia_gpu() {
  case "${WIZARDRY_VOICE_HAS_NVIDIA-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    0|false|FALSE|no|NO|off|OFF) return 1 ;;
  esac

  if ! vr_is_linux; then
    return 1
  fi

  if ! command -v nvidia-smi >/dev/null 2>&1; then
    return 1
  fi

  nvidia-smi -L >/dev/null 2>&1
}

vr_component_dir() {
  component=$1
  printf '%s/%s\n' "$vr_root_dir" "$component"
}

vr_component_venv() {
  component=$1
  printf '%s/venv\n' "$(vr_component_dir "$component")"
}

vr_component_python() {
  component=$1
  printf '%s/bin/python\n' "$(vr_component_venv "$component")"
}

vr_component_state_file() {
  component=$1
  printf '%s/installed\n' "$(vr_component_dir "$component")"
}

vr_component_known() {
  component=$1
  case "$component" in
    ctranslate2-whisper|mlx-whisper|parakeet)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

vr_component_model() {
  component=$1
  case "$component" in
    ctranslate2-whisper)
      printf '%s\n' "${WIZARDRY_VOICE_MODEL_CTRANSLATE2:-${WIZARDRY_VOICE_MODEL_FASTER:-small.en}}"
      ;;
    mlx-whisper)
      printf '%s\n' "${WIZARDRY_VOICE_MODEL_MLX:-mlx-community/whisper-small}"
      ;;
    parakeet)
      printf '%s\n' "${WIZARDRY_VOICE_MODEL_PARAKEET:-nvidia/parakeet-tdt-0.6b-v2}"
      ;;
    *)
      return 1
      ;;
  esac
}

vr_component_support_error() {
  component=$1
  case "$component" in
    mlx-whisper)
      printf '%s\n' "voice-recognition: mlx-whisper requires macOS on Apple Silicon"
      ;;
    parakeet)
      printf '%s\n' "voice-recognition: parakeet requires Linux with an NVIDIA GPU"
      ;;
    *)
      printf '%s\n' "voice-recognition: $component is unavailable on this host"
      ;;
  esac
}

vr_component_installed() {
  component=$1
  state_file=$(vr_component_state_file "$component") || return 1
  python_bin=$(vr_component_python "$component") || return 1

  [ -f "$state_file" ] && [ -x "$python_bin" ]
}

vr_component_supported_on_host() {
  component=$1

  case "$component" in
    ctranslate2-whisper)
      return 0
      ;;
    mlx-whisper)
      vr_is_macos_apple_silicon
      ;;
    parakeet)
      vr_has_nvidia_gpu
      ;;
    *)
      return 1
      ;;
  esac
}

vr_install_component() {
  component=$1

  if ! vr_component_known "$component"; then
    die 2 "voice-recognition: unknown component '$component'"
  fi

  if ! vr_component_supported_on_host "$component"; then
    die "$(vr_component_support_error "$component")"
  fi

  if vr_component_installed "$component"; then
    success "voice-recognition: $component is already installed"
    return 0
  fi

  success "voice-recognition: installing $component (this may take several minutes)"

  if ! vr_try_install_command python3; then
    die "voice-recognition: python3 is required"
  fi

  if ! vr_try_install_command ffmpeg; then
    die "voice-recognition: ffmpeg is required for microphone capture"
  fi

  component_dir=$(vr_component_dir "$component")
  venv_dir=$(vr_component_venv "$component")
  python_bin=$(vr_component_python "$component")
  state_file=$(vr_component_state_file "$component")
  model_name=$(vr_component_model "$component") || \
    die 2 "voice-recognition: unknown component '$component'"

  mkdir -p "$component_dir"

  if [ -d "$venv_dir" ]; then
    rm -rf "$venv_dir"
  fi

  step "voice-recognition: creating virtual environment for $component"
  python3 -m venv "$venv_dir" || \
    die "voice-recognition: could not create venv for $component"

  [ -x "$python_bin" ] || die "voice-recognition: missing python in $venv_dir"

  "$python_bin" -m ensurepip --upgrade >/dev/null 2>&1 || true
  "$python_bin" -m pip install --upgrade pip >/dev/null 2>&1 || \
    die "voice-recognition: pip upgrade failed for $component"

  step "voice-recognition: installing $component packages"
  case "$component" in
    ctranslate2-whisper)
      "$python_bin" -m pip install --upgrade whisper-ctranslate2 >/dev/null 2>&1 || \
        die "voice-recognition: whisper-ctranslate2 package installation failed"
      ;;
    mlx-whisper)
      "$python_bin" -m pip install --upgrade mlx-whisper huggingface-hub >/dev/null 2>&1 || \
        die "voice-recognition: mlx-whisper package installation failed"
      ;;
    parakeet)
      "$python_bin" -m pip install --upgrade "nemo_toolkit[asr]" >/dev/null 2>&1 || \
        die "voice-recognition: parakeet package installation failed"
      ;;
  esac

  mkdir -p "$vr_hf_home"
  export HF_HOME="$vr_hf_home"

  step "voice-recognition: preparing local model cache"
  case "$component" in
    ctranslate2-whisper)
      VR_MODEL="$model_name" "$python_bin" <<'PY'
import os
from faster_whisper import WhisperModel

model_name = os.environ.get("VR_MODEL", "small.en")
WhisperModel(model_name, device="cpu", compute_type="int8")
PY
      ;;
    mlx-whisper)
      VR_MODEL="$model_name" "$python_bin" <<'PY'
import os
from huggingface_hub import snapshot_download

model_name = os.environ.get("VR_MODEL", "mlx-community/whisper-small")
snapshot_download(repo_id=model_name)
PY
      ;;
    parakeet)
      VR_MODEL="$model_name" "$python_bin" <<'PY'
import os
import nemo.collections.asr as nemo_asr

model_name = os.environ.get("VR_MODEL", "nvidia/parakeet-tdt-0.6b-v2")
nemo_asr.models.ASRModel.from_pretrained(model_name=model_name)
PY
      ;;
  esac

  printf 'component=%s\nmodel=%s\ninstalled_at=%s\n' \
    "$component" \
    "$model_name" \
    "$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || printf unknown)" > "$state_file"

  success "voice-recognition: installed $component"
}

vr_uninstall_component() {
  component=$1

  if ! vr_component_known "$component"; then
    die 2 "voice-recognition: unknown component '$component'"
  fi

  component_dir=$(vr_component_dir "$component")

  if [ ! -d "$component_dir" ]; then
    info "voice-recognition: $component is not installed"
    return 0
  fi

  rm -rf "$component_dir"
  success "voice-recognition: removed $component"

  # Remove root only when it's empty.
  if [ -d "$vr_root_dir" ] && [ -z "$(ls -A "$vr_root_dir" 2>/dev/null || printf '')" ]; then
    rmdir "$vr_root_dir" 2>/dev/null || true
  fi
}

vr_find_manage_command() {
  manage_cmd=${MANAGE_SYSTEM_COMMAND:-manage-system-command}
  if command -v "$manage_cmd" >/dev/null 2>&1; then
    printf '%s\n' "$manage_cmd"
    return 0
  fi

  if [ -n "${VR_ARCANA_DIR-}" ] && [ -x "$VR_ARCANA_DIR/../core/manage-system-command" ]; then
    printf '%s\n' "$VR_ARCANA_DIR/../core/manage-system-command"
    return 0
  fi

  return 1
}

vr_try_install_command() {
  cmd_name=$1

  if command -v "$cmd_name" >/dev/null 2>&1; then
    return 0
  fi

  manage_cmd=$(vr_find_manage_command 2>/dev/null || printf '')
  if [ -z "$manage_cmd" ]; then
    return 1
  fi

  case "$cmd_name" in
    python3)
      case "$(vr_uname_s)" in
        Darwin)
          PKGIN_PACKAGE=python312 "$manage_cmd" python3 python3 >/dev/null 2>&1 || \
            PKGIN_PACKAGE=python311 "$manage_cmd" python3 python3 >/dev/null 2>&1 || \
            "$manage_cmd" python3 python3 >/dev/null 2>&1 || true
          ;;
        *)
          PACMAN_PACKAGE=python "$manage_cmd" python3 python3 >/dev/null 2>&1 || \
            "$manage_cmd" python3 python3 >/dev/null 2>&1 || true
          ;;
      esac
      ;;
    ffmpeg)
      "$manage_cmd" ffmpeg ffmpeg >/dev/null 2>&1 || true
      ;;
    *)
      "$manage_cmd" "$cmd_name" "$cmd_name" >/dev/null 2>&1 || true
      ;;
  esac

  command -v "$cmd_name" >/dev/null 2>&1
}

vr_select_backend() {
  if vr_is_macos && vr_component_installed "mlx-whisper"; then
    printf '%s\n' "mlx-whisper"
    return 0
  fi

  if vr_has_nvidia_gpu && vr_component_installed "parakeet"; then
    printf '%s\n' "parakeet"
    return 0
  fi

  if vr_component_installed "ctranslate2-whisper"; then
    printf '%s\n' "ctranslate2-whisper"
    return 0
  fi

  if vr_component_installed "mlx-whisper"; then
    printf '%s\n' "mlx-whisper"
    return 0
  fi

  if vr_component_installed "parakeet"; then
    printf '%s\n' "parakeet"
    return 0
  fi

  return 1
}
