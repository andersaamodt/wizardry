#!/bin/sh

# Uninstall yt-dlp when possible.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-yt-dlp

Attempts to uninstall yt-dlp from common package managers and user installs.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)

if ! "$script_dir/is-yt-dlp-installed"; then
  info "yt-dlp is not installed"
  exit 0
fi

run_with_priv() {
  if command -v sudo >/dev/null 2>&1; then
    sudo "$@"
  else
    "$@"
  fi
}

command -v pkgin >/dev/null 2>&1 && run_with_priv pkgin -y remove yt-dlp >/dev/null 2>&1 || true
command -v apt-get >/dev/null 2>&1 && run_with_priv apt-get -y remove yt-dlp >/dev/null 2>&1 || true
command -v pacman >/dev/null 2>&1 && run_with_priv pacman --noconfirm -R yt-dlp >/dev/null 2>&1 || true
command -v dnf >/dev/null 2>&1 && run_with_priv dnf -y remove yt-dlp >/dev/null 2>&1 || true
command -v yum >/dev/null 2>&1 && run_with_priv yum -y remove yt-dlp >/dev/null 2>&1 || true
command -v zypper >/dev/null 2>&1 && run_with_priv zypper -n remove yt-dlp >/dev/null 2>&1 || true
command -v brew >/dev/null 2>&1 && brew uninstall yt-dlp >/dev/null 2>&1 || true
command -v python3 >/dev/null 2>&1 && python3 -m pip uninstall -y yt-dlp >/dev/null 2>&1 || true

rm -f "$HOME/.local/bin/yt-dlp" >/dev/null 2>&1 || true

if "$script_dir/is-yt-dlp-installed"; then
  die "uninstall-yt-dlp: yt-dlp is still installed"
fi

success "Uninstalled yt-dlp"
