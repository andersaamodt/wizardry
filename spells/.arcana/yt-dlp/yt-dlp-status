#!/bin/sh

# Report installation status for yt-dlp.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: yt-dlp-status

Reports whether yt-dlp is installed.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

if command -v colors >/dev/null 2>&1; then
  . colors
else
  RESET=""
  THEME_SUCCESS=""
  GREY=""
fi

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
if "$script_dir/is-yt-dlp-installed"; then
  printf '%sinstalled%s\n' "$THEME_SUCCESS" "$RESET"
else
  printf '%snot installed%s\n' "$GREY" "$RESET"
fi
