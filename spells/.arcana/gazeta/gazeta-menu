#!/bin/sh

# Present the Gazeta management menu.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: gazeta-menu

Shows Gazeta install, update, and removal actions.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

if ! require menu "The gazeta-menu needs the 'menu' command to present options."; then
  exit 1
fi

trap 'exit 130' INT
trap 'exit 0' TERM

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$script_dir/gazeta-common"

while :; do
  unset menu_status

  if gazeta_installed; then
    toggle="[X] Gazeta%$script_dir/install-gazeta"
  else
    toggle="[ ] Gazeta%$script_dir/install-gazeta"
  fi

  exit_label=$(exit-label)
  exit_item="${exit_label}%kill -TERM \$PPID"

  menu "Gazeta:" \
    "$toggle" \
    "Status%$script_dir/gazeta-status" \
    "Uninstall%$script_dir/uninstall-gazeta" \
    "$exit_item" || menu_status=$?
  menu_status=${menu_status:-0}

  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi
done
