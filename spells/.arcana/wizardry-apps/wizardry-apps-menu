#!/bin/sh

# Present the wizardry-apps management menu.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: wizardry-apps-menu [--templates-only]

Displays install/uninstall toggles for wizardry-apps components.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear
. colors

if ! require menu "The wizardry-apps-menu needs the 'menu' command to present options."; then
  exit 1
fi

templates_only=0
case "${1-}" in
  --templates-only) templates_only=1 ;;
  "") ;;
  *) die 2 "wizardry-apps-menu: unknown option '$1'" ;;
esac

trap 'exit 130' INT
trap 'exit 0' TERM

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
# shellcheck source=/dev/null
. "$script_dir/wizardry-apps-common"

while :; do
  web_templates_installed=0
  apps_installed=0

  "$script_dir/is-wizardry-apps-component-installed" web-templates >/dev/null 2>&1 && web_templates_installed=1
  "$script_dir/is-wizardry-apps-component-installed" apps >/dev/null 2>&1 && apps_installed=1

  if [ "$web_templates_installed" -eq 1 ]; then
    web_templates_toggle="[X] web templates%$script_dir/uninstall-web-templates"
  else
    web_templates_toggle="[ ] web templates%$script_dir/install-web-templates"
  fi

  if [ "$apps_installed" -eq 1 ]; then
    apps_toggle="[X] desktop apps%$script_dir/uninstall-wizardry-desktop-apps"
  else
    apps_toggle="[ ] desktop apps%$script_dir/install-wizardry-desktop-apps"
  fi

  if [ "$web_templates_installed" -eq 1 ] && [ "$apps_installed" -eq 1 ]; then
    toggle_all="Disable all%$script_dir/toggle-all-wizardry-apps --disable"
  else
    toggle_all="Enable all%$script_dir/toggle-all-wizardry-apps --enable"
  fi

  exit_label=$(exit-label)
  exit_item="${exit_label}%kill -TERM \$PPID"

  if [ "$templates_only" -eq 1 ]; then
    set -- "$web_templates_toggle" "$exit_item"
    title="Install Web Templates:"
  else
    set --
    if wizardry_apps_repo_installed && wizardry_apps_forge_available; then
      set -- "$@" "Launch Forge (compile + run)%$script_dir/launch-forge" "---"
    fi
    set -- "$@" "$web_templates_toggle" "$apps_toggle" "$toggle_all" "$exit_item"
    title="Install wizardry-apps:"
  fi

  menu "$title" "$@" || menu_status=$?
  menu_status=${menu_status:-0}

  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi
done
