#!/bin/sh

# Uninstall all wizardry-apps managed components.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-wizardry-apps

Uninstalls both web templates and desktop apps.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

# shellcheck source=/dev/null
. "$script_dir/wizardry-apps-common"

wizardry_apps_uninstall_repo
