#!/bin/sh

# Remove the Wizardry-managed SimpleX Chat CLI runtime.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-simplex-chat

Removes the SimpleX CLI files installed by Wizardry. System package manager
installs and unrelated simplex-chat commands are left unchanged.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear
. colors

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$script_dir/simplex-chat-common"

simplex_chat_root=$(simplex_chat_root_dir)
simplex_chat_marker=$(simplex_chat_marker_file)
simplex_chat_link=$(simplex_chat_link_path)
removed=0

if simplex_chat_target_link_is_managed; then
  rm -f "$simplex_chat_link"
  removed=1
fi

if [ -f "$simplex_chat_marker" ]; then
  rm -rf "$simplex_chat_root"
  removed=1
elif [ -e "$simplex_chat_root" ]; then
  printf '%s\n' "uninstall-simplex-chat: $simplex_chat_root is not marked as a Wizardry SimpleX install; leaving it unchanged." >&2
fi

if [ "$removed" -eq 0 ]; then
  info "SimpleX CLI is not installed by Wizardry"
else
  success "Removed Wizardry-managed SimpleX CLI"
fi

if simplex_chat_binary_resolved >/dev/null 2>&1; then
  printf '%s\n' "Another simplex-chat command is still available at $(simplex_chat_binary_resolved)"
fi
