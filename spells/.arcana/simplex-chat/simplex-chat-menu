#!/bin/sh

# Present the SimpleX CLI management menu.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: simplex-chat-menu

Displays the SimpleX CLI management menu.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear
. colors
: "${BOLD:=}"
: "${CYAN:=}"

if ! require menu "The simplex-chat-menu needs the 'menu' command to present options."; then
  exit 1
fi

trap 'exit 130' INT
trap 'exit 0' TERM

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
exit_label=$(exit-label)
exit_option="${exit_label}%kill -TERM \$PPID"

while true; do
  unset menu_status
  status=$("$script_dir/simplex-chat-status")
  title="${BOLD}${CYAN}SimpleX: $status"

  if simplex_binary=$("$script_dir/simplex-chat-status" --path 2>/dev/null); then
    menu "$title" \
      "Run SimpleX CLI%$simplex_binary" \
      "Show SimpleX CLI path%$script_dir/simplex-chat-status --path" \
      "[X] Install SimpleX CLI%FORCE_INSTALL=1 $script_dir/install-simplex-chat" \
      "Uninstall SimpleX CLI%$script_dir/uninstall-simplex-chat" \
      "$exit_option" || menu_status=$?
  else
    menu "$title" \
      "[ ] Install SimpleX CLI%$script_dir/install-simplex-chat" \
      "$exit_option" || menu_status=$?
  fi

  menu_status=${menu_status:-0}
  if [ "$menu_status" -eq 130 ]; then
    exit 0
  fi
done
