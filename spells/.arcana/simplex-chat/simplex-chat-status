#!/bin/sh

# Report installation status for the Wizardry-managed SimpleX Chat CLI.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE' >&2
Usage: simplex-chat-status [--path]

Reports whether the SimpleX Chat CLI is installed and runnable.
Use --path to print the resolved CLI path only.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$script_dir/simplex-chat-common"

if command -v colors >/dev/null 2>&1; then
  . colors
else
  RESET=""
  THEME_SUCCESS=""
  THEME_ERROR=""
  GREY=""
fi
: "${RESET:=}"
: "${THEME_SUCCESS:=}"
: "${THEME_ERROR:=}"
: "${GREY:=}"

cmd=${1-}
if simplex_chat_binary=$(simplex_chat_binary_resolved 2>/dev/null); then
  if [ "$cmd" = "--path" ]; then
    printf '%s\n' "$simplex_chat_binary"
    exit 0
  fi
  simplex_chat_version=$(simplex_chat_config_get "$(simplex_chat_install_file)" version 2>/dev/null || printf '')
  if [ -n "$simplex_chat_version" ]; then
    printf '%sinstalled %s%s\n' "$THEME_SUCCESS" "$simplex_chat_version" "$RESET"
  else
    printf '%sinstalled%s\n' "$THEME_SUCCESS" "$RESET"
  fi
  exit 0
fi

if [ "$cmd" = "--path" ]; then
  exit 1
fi

if [ -f "$(simplex_chat_install_file)" ]; then
  printf '%sinstalled, error%s\n' "$THEME_ERROR" "$RESET"
else
  printf '%snot installed%s\n' "$GREY" "$RESET"
fi
