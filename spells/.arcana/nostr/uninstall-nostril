#!/bin/sh

# Uninstall nostril tooling.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-nostril

Removes the nostril CLI used for Nostr signature verification.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear
. colors

if ! command -v nostril >/dev/null 2>&1; then
  if [ -f "${XDG_BIN_HOME:-$HOME/.local/bin}/nostril" ]; then
    :
  else
    info "nostril is not installed"
    exit 0
  fi
fi

nostril_path=$(command -v nostril 2>/dev/null || printf '')
if [ -n "$nostril_path" ] && [ -f "$nostril_path" ]; then
  step "Removing nostril binary at $nostril_path"
  rm -f "$nostril_path"
fi

local_bin="${XDG_BIN_HOME:-$HOME/.local/bin}"
if [ -f "$local_bin/nostril" ]; then
  step "Removing nostril binary at $local_bin/nostril"
  rm -f "$local_bin/nostril"
fi
if [ -f "$local_bin/nostril-query" ]; then
  rm -f "$local_bin/nostril-query"
fi

if [ -f "/usr/local/bin/nostril" ]; then
  step "Removing nostril binary at /usr/local/bin/nostril"
  rm -f /usr/local/bin/nostril
fi
if [ -f "/usr/local/bin/nostril-query" ]; then
  rm -f /usr/local/bin/nostril-query
fi

if [ -f "/opt/homebrew/bin/nostril" ]; then
  step "Removing nostril binary at /opt/homebrew/bin/nostril"
  rm -f /opt/homebrew/bin/nostril
fi
if [ -f "/opt/homebrew/bin/nostril-query" ]; then
  rm -f /opt/homebrew/bin/nostril-query
fi

if command -v nostril >/dev/null 2>&1; then
  die "uninstall-nostril: nostril is still present on PATH"
fi

success "Uninstalled nostril"
