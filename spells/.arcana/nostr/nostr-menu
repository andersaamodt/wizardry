#!/bin/sh

# Present the Nostr tooling management menu.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: nostr-menu

Displays install and uninstall toggle for nostril.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

if ! require menu "The nostr-menu needs the 'menu' command to present options."; then
  exit 1
fi

trap 'exit 130' INT
trap 'exit 0' TERM

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)

while :; do
  unset menu_status

  if command -v nostril >/dev/null 2>&1; then
    toggle_item="[X] Install nostril%$script_dir/uninstall-nostril-arcana"
  else
    toggle_item="[ ] Install nostril%$script_dir/install-nostril-arcana"
  fi

  exit_label=$(exit-label)
  exit_item="${exit_label}%kill -TERM \$PPID"

  menu "Nostr:" "$toggle_item" "$exit_item" || menu_status=$?
  menu_status=${menu_status:-0}

  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi
done
