#!/bin/sh

# Report webcam tooling installation status.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: webcam-status

Reports whether FFmpeg and go2rtc are installed.
USAGE
  exit 0
  ;;
esac

set -eu

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)

if "$script_dir/is-ffmpeg-installed" && "$script_dir/is-go2rtc-installed"; then
  printf '%s\n' "ready"
elif "$script_dir/is-ffmpeg-installed" || "$script_dir/is-go2rtc-installed"; then
  printf '%s\n' "partial"
else
  printf '%s\n' "not installed"
fi
