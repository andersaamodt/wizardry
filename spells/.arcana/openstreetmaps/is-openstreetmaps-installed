#!/bin/sh

# Report whether OpenStreetMap web assets are installed.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: is-openstreetmaps-installed

Exits successfully when the shared Leaflet assets for OpenStreetMap pages are installed.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

install_root="${WIZARDRY_WEB_JS_DIR:-$HOME/.local/share/wizardry/web/js}"
leaflet_dir="$install_root/leaflet"

[ -s "$leaflet_dir/leaflet.css" ] &&
[ -s "$leaflet_dir/leaflet.js" ] &&
[ -s "$leaflet_dir/images/marker-icon.png" ] &&
[ -s "$leaflet_dir/images/marker-icon-2x.png" ] &&
[ -s "$leaflet_dir/images/marker-shadow.png" ]
