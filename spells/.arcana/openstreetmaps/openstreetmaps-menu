#!/bin/sh

# Present the OpenStreetMap management menu.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: openstreetmaps-menu

Displays install/uninstall controls for OpenStreetMap web assets.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

if ! require menu "The openstreetmaps-menu needs the 'menu' command to present options."; then
  exit 1
fi

trap 'exit 130' INT
trap 'exit 0' TERM

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)

while :; do
  unset menu_status

  if "$script_dir/is-openstreetmaps-installed" >/dev/null 2>&1; then
    asset_item="[X] OpenStreetMap web assets%$script_dir/uninstall-openstreetmaps"
  else
    asset_item="[ ] OpenStreetMap web assets%$script_dir/install-openstreetmaps"
  fi

  notes_item="Server sizing notes%$script_dir/openstreetmaps-server-notes"
  exit_label=$(exit-label)
  exit_item="${exit_label}%kill -TERM \$PPID"

  menu "OpenStreetMap:" "$asset_item" "$notes_item" "$exit_item" || menu_status=$?
  menu_status=${menu_status:-0}

  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi
done
