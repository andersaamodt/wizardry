#!/bin/sh

# Install Origin bridge HTTP clients from the official Origin source tree.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-origin-bridge-runtime

Installs the real origin-bridge-<platform> executables and shared helper from the Origin project source tree instead of generating local replacements.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear
. colors

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$script_dir/crossposting-common"

manifest_dir="${XDG_STATE_HOME:-$HOME/.local/state}/wizardry/crossposting"
manifest_path="$manifest_dir/origin-bridge-runtime.manifest"
origin_source=$(crossposting_origin_source_dir) || die "install-origin-bridge-runtime: could not locate official Origin source. Set ORIGIN_SOURCE_DIR or install origin first."

mkdir -p "$manifest_dir"
: >"$manifest_path"

install_one() {
  source_path=$1
  target_path=$2

  target_name=$(basename "$target_path")
  existing=$(command -v "$target_name" 2>/dev/null || true)
  if [ -n "$existing" ] && [ "$existing" != "$target_path" ]; then
    printf '%s\n' "Keeping existing $target_name at $existing"
    return 0
  fi

  crossposting_run_privileged install -d -m 755 "$(dirname "$target_path")"
  crossposting_run_privileged install -m 755 "$source_path" "$target_path"
  printf '%s\n' "$target_path" >>"$manifest_path"
}

lib_target_dir=$(crossposting_install_lib_dir)
lib_target_path="$lib_target_dir/origin-bridge-common"
install_one "$origin_source/spells/.imps/origin/origin-bridge-common" "$lib_target_path"

bin_target_dir=$(crossposting_install_bin_dir)
for platform in $(crossposting_bridge_platforms); do
  source_path="$origin_source/spells/.imps/origin/origin-bridge-$platform"
  [ -f "$source_path" ] || die "install-origin-bridge-runtime: missing $source_path in origin source"
  install_one "$source_path" "$bin_target_dir/origin-bridge-$platform"
done

success "Installed Origin bridge clients from $origin_source"
printf '%s\n' "Configure bridge endpoints with ORIGIN_BRIDGE_BASE_URL or ORIGIN_BRIDGE_<PLATFORM>_BASE_URL"
