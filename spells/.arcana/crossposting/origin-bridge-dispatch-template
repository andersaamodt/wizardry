#!/bin/sh

set -eu

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

script_name=$(basename "$0")
platform=

case "$script_name" in
  origin-bridge-dispatch)
    platform=${ORIGIN_PLATFORM-}
    ;;
  origin-bridge-*)
    platform=${script_name#origin-bridge-}
    ;;
esac

[ -n "$platform" ] || die "origin-bridge-dispatch: could not determine platform. Set ORIGIN_PLATFORM or invoke through origin-bridge-<platform>."

action=${1-}
[ -n "$action" ] || die "origin-bridge-dispatch: missing action (emit, edit, or fetch)"
shift

case "$action" in
  emit|edit|fetch)
    ;;
  *)
    die "origin-bridge-dispatch: unsupported action: $action"
    ;;
esac

command -v curl >/dev/null 2>&1 || die "origin-bridge-dispatch: curl is required"

env_value() {
  name=$1
  eval "printf '%s' \"\${$name-}\""
}

platform_upper=$(printf '%s' "$platform" | tr '[:lower:]-' '[:upper:]_')
action_upper=$(printf '%s' "$action" | tr '[:lower:]' '[:upper:]')
action_url=$(env_value "ORIGIN_BRIDGE_${platform_upper}_${action_upper}_URL")
if [ -z "$action_url" ]; then
  base_url=$(env_value "ORIGIN_BRIDGE_${platform_upper}_BASE_URL")
  if [ -n "$base_url" ]; then
    action_url=${base_url%/}/$action
  fi
fi
if [ -z "$action_url" ]; then
  base_url=${ORIGIN_BRIDGE_BASE_URL-}
  if [ -n "$base_url" ]; then
    action_url=${base_url%/}/$platform/$action
  fi
fi

[ -n "$action_url" ] || die "origin-bridge-dispatch: missing bridge URL for $platform. Set ORIGIN_BRIDGE_${platform_upper}_BASE_URL, ORIGIN_BRIDGE_${platform_upper}_${action_upper}_URL, or ORIGIN_BRIDGE_BASE_URL."

auth_header=$(env_value "ORIGIN_BRIDGE_${platform_upper}_AUTH_HEADER")
if [ -z "$auth_header" ]; then
  auth_header=${ORIGIN_BRIDGE_AUTH_HEADER-}
fi
if [ -z "$auth_header" ]; then
  token=$(env_value "ORIGIN_BRIDGE_${platform_upper}_TOKEN")
  if [ -z "$token" ]; then
    token=${ORIGIN_BRIDGE_TOKEN-}
  fi
  if [ -n "$token" ]; then
    auth_header="Authorization: Bearer $token"
  fi
fi

payload_file=$(mktemp "${TMPDIR:-/tmp}/origin-bridge-runtime.XXXXXX")
trap 'rm -f "$payload_file"' EXIT HUP INT TERM
cat >"$payload_file"

set -- curl -fsS -X POST \
  -H 'Accept: application/json' \
  -H 'Content-Type: application/json' \
  -H "X-Origin-Platform: $platform" \
  -H "X-Origin-Action: $action" \
  -H "X-Origin-Edit: ${ORIGIN_EDIT-0}" \
  -H "X-Origin-Remote-Id: ${ORIGIN_REMOTE_ID-}" \
  -H "X-Origin-Remote-Url: ${ORIGIN_REMOTE_URL-}" \
  --data-binary "@$payload_file"

if [ -n "$auth_header" ]; then
  set -- "$@" -H "$auth_header"
fi

"$@" "$action_url"
