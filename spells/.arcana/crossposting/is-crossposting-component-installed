#!/bin/sh

# Check if a crossposting component is installed.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: is-crossposting-component-installed COMPONENT

Returns 0 if installed, 1 otherwise.
Components: jq, pandoc, granary-runtime, bridge-runtime
USAGE
  exit 0
  ;;
esac

set +e
set +u

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$script_dir/crossposting-common"

component=${1:-}
[ -n "$component" ] || exit 1

case "$component" in
  jq)
    crossposting_has_cmd jq
    ;;
  pandoc)
    crossposting_has_cmd pandoc
    ;;
  granary-runtime)
    crossposting_granary_available
    ;;
  bridge-runtime)
    crossposting_bridge_runtime_available
    ;;
  *)
    exit 1
    ;;
esac
