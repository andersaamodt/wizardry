#!/bin/sh

# Remove Origin bridge runtime shims for bridge-backed targets.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-origin-bridge-runtime

Removes the managed origin-bridge-<platform> shims and shared origin-bridge-dispatch executable installed by Wizardry.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear
. colors

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$script_dir/crossposting-common"

manifest_path="${XDG_STATE_HOME:-$HOME/.local/state}/wizardry/crossposting/origin-bridge-runtime.manifest"
removed=0

if [ -f "$manifest_path" ]; then
  while IFS= read -r path; do
    [ -n "$path" ] || continue
    if [ -e "$path" ] || [ -L "$path" ]; then
      crossposting_run_privileged rm -f "$path"
      removed=1
    fi
  done <"$manifest_path"
  rm -f "$manifest_path"
fi

if [ "$removed" -eq 0 ]; then
  printf '%s\n' "Origin bridge runtime shims are not installed."
  exit 0
fi

success "Removed Origin bridge runtime shims"
