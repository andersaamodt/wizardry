#!/bin/sh

# Install pandoc for crossposting flows.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-crossposting-pandoc

Ensures pandoc is installed for Origin's deterministic markdown rendering.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
"$script_dir/../../web/install-pandoc"
