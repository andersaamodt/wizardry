#!/bin/sh

# Remove the managed Granary runtime for Origin.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-crossposting-granary

Removes the operator-local Granary runtime installed for Origin.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear
. colors

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$script_dir/crossposting-common"

venv_dir=$(crossposting_granary_venv_dir)
removed=0

if [ -d "$venv_dir" ]; then
  rm -rf "$venv_dir"
  removed=1
fi

for path in \
  /usr/local/bin/origin-granary-python \
  "${XDG_BIN_HOME:-$HOME/.local/bin}/origin-granary-python"
do
  if [ -e "$path" ] || [ -L "$path" ]; then
    crossposting_run_privileged rm -f "$path"
    removed=1
  fi
done

if [ "$removed" -eq 0 ]; then
  printf '%s\n' "Granary runtime is not installed."
  exit 0
fi

success "Removed Granary runtime"
if crossposting_granary_available; then
  printf '%s\n' "Granary is still available via another runtime."
fi
