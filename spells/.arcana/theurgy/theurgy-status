#!/bin/sh

# Print Theurgy installation status.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: theurgy-status

Reports Theurgy installation status.
USAGE
  exit 0
  ;;
esac

set -eu
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$script_dir/_theurgy"

if is_theurgy_installed; then
  printf 'installed\n'
else
  printf 'not installed\n'
fi
