#!/bin/sh

# Create a Core Lightning hsm_secret through the official lightning-hsmtool flow.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: generate-lightning-hsm-secret

Guides an official Core Lightning hsm_secret creation flow using lightning-hsmtool.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

find_hsmtool() {
  if command -v lightning-hsmtool >/dev/null 2>&1; then
    command -v lightning-hsmtool
    return 0
  fi
  if command -v hsmtool >/dev/null 2>&1; then
    command -v hsmtool
    return 0
  fi
  return 1
}

ask_yes_no() {
  prompt_text=$1
  default_answer=${2:-y}
  if command -v ask-yn >/dev/null 2>&1; then
    if ask-yn "$prompt_text" "$default_answer"; then
      return 0
    fi
    return 1
  fi
  case "$default_answer" in
    y|Y) prompt_suffix='[Y/n]' ;;
    *) prompt_suffix='[y/N]' ;;
  esac
  printf '%s %s: ' "$prompt_text" "$prompt_suffix"
  IFS= read -r reply
  case ${reply:-$default_answer} in
    y|Y|yes|YES|Yes) return 0 ;;
    *) return 1 ;;
  esac
}

prompt_value() {
  prompt_text=$1
  default_value=${2-}
  if [ -n "$default_value" ]; then
    printf '%s [%s]: ' "$prompt_text" "$default_value"
  else
    printf '%s: ' "$prompt_text"
  fi
  IFS= read -r reply
  if [ -n "$reply" ]; then
    printf '%s\n' "$reply"
  else
    printf '%s\n' "$default_value"
  fi
}

hsmtool_bin=$(find_hsmtool || printf '')
[ -n "$hsmtool_bin" ] || {
  printf '%s\n' 'Core Lightning hsmtool is not installed yet, so the secret wizard is not ready.'
  exit 1
}

printf '%s\n' 'Core Lightning root secret wizard'
printf '%s\n' 'This flow wraps the official lightning-hsmtool generatehsm command and leaves the mnemonic entry and optional passphrase entry inside the official interactive prompt.'
printf '%s\n' 'The strongest result usually comes from a local machine that is intentionally quiet, with networking disabled or otherwise understood while the mnemonic is handled.'
if ! ask_yes_no 'This session appears ready for that local secret-generation flow.' 'n'; then
  printf '%s\n' 'Secret generation stayed paused.'
  exit 0
fi

default_dir=$HOME/.lightning
lightning_dir=$(prompt_value 'Core Lightning directory' "$default_dir")
[ -n "$lightning_dir" ] || {
  printf '%s\n' 'An empty directory would leave the secret with no clear home.'
  exit 1
}

mkdir -p "$lightning_dir"
secret_path=$lightning_dir/hsm_secret
if [ -e "$secret_path" ]; then
  printf 'An hsm_secret already exists at %s, so the wizard left it untouched.\n' "$secret_path"
  exit 1
fi

printf '\n'
printf 'Secret destination: %s\n' "$secret_path"
printf '%s\n' 'The next screen comes from Core Lightning itself and asks for a BIP39 mnemonic plus an optional passphrase.'
"$hsmtool_bin" generatehsm "$secret_path"
chmod 600 "$secret_path" 2>/dev/null || true

printf '\n'
printf 'Core Lightning secret created: %s\n' "$secret_path"
printf '%s\n' 'The same mnemonic and passphrase recreate the same hsm_secret, so both pieces belong in the backup record.'
