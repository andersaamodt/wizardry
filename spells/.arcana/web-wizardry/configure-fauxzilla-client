#!/bin/sh
# Configure Firefox to use a Fauxzilla tokenserver URI.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: configure-fauxzilla-client [--config PATH] [--tokenserver-uri URI|HOST] [--domain DOMAIN] [--profile NAME|PATH] [--check] [--print-uri] [--non-interactive]

Resolves a Fauxzilla tokenserver URI, selects a Firefox profile, and writes
identity.sync.tokenserver.uri into that profile's user.js file.
USAGE
  exit 0
  ;;
esac

set -eu

pref_key='identity.sync.tokenserver.uri'
config_path=''
tokenserver_input=''
profile_selector=''
mode='apply'
non_interactive='no'

fauxzilla_client_die() {
  code=${2-1}
  printf 'configure-fauxzilla-client: %s\n' "$1" >&2
  exit "$code"
}

fauxzilla_client_has() {
  command -v "$1" >/dev/null 2>&1
}

fauxzilla_client_normalize_prefix() {
  raw_prefix=${1-}
  case "$raw_prefix" in
    ''|/) printf '\n' ;;
    /*)
      trimmed=${raw_prefix%/}
      if [ "$trimmed" = '/' ]; then
        printf '\n'
      else
        printf '%s\n' "$trimmed"
      fi
      ;;
    *)
      fauxzilla_client_die "Public prefix must start with '/'." 2
      ;;
  esac
}

fauxzilla_client_tokenserver_uri_from_parts() {
  scheme=${1-https}
  domain=${2-}
  raw_prefix=${3-/token}
  [ -n "$domain" ] || return 1
  prefix=$(fauxzilla_client_normalize_prefix "$raw_prefix")
  uri=$scheme://$domain
  if [ -n "$prefix" ]; then
    uri=$uri$prefix
  fi
  printf '%s/1.0/sync/1.5\n' "$uri"
}

fauxzilla_client_normalize_tokenserver_input() {
  raw_value=${1-}
  [ -n "$raw_value" ] || return 1
  case "$raw_value" in
    *://*) uri=$raw_value ;;
    *) uri=https://$raw_value ;;
  esac
  uri=${uri%/}
  case "$uri" in
    */1.0/sync/1.5) printf '%s\n' "$uri" ;;
    */token) printf '%s/1.0/sync/1.5\n' "$uri" ;;
    *) printf '%s/token/1.0/sync/1.5\n' "$uri" ;;
  esac
}

fauxzilla_client_local_config_uri() {
  config_candidate=${1-}
  [ -n "$config_candidate" ] || config_candidate=${FAUXZILLA_CONFIG_PATH:-/etc/fauxzilla/fauxzilla.conf}
  [ -r "$config_candidate" ] || return 1
  (
    unset FAUXZILLA_DOMAIN FAUXZILLA_PUBLIC_SCHEME FAUXZILLA_PUBLIC_PREFIX
    # shellcheck source=/dev/null
    . "$config_candidate"
    [ -n "${FAUXZILLA_DOMAIN-}" ] || exit 1
    fauxzilla_client_tokenserver_uri_from_parts \
      "${FAUXZILLA_PUBLIC_SCHEME-https}" \
      "$FAUXZILLA_DOMAIN" \
      "${FAUXZILLA_PUBLIC_PREFIX-/token}"
  )
}

fauxzilla_client_resolve_tokenserver_uri() {
  if [ -n "$tokenserver_input" ]; then
    fauxzilla_client_normalize_tokenserver_input "$tokenserver_input"
    return 0
  fi
  if [ -n "${FAUXZILLA_TOKENSERVER_URI-}" ]; then
    fauxzilla_client_normalize_tokenserver_input "$FAUXZILLA_TOKENSERVER_URI"
    return 0
  fi
  if [ -n "$config_path" ]; then
    fauxzilla_client_local_config_uri "$config_path" && return 0
  elif fauxzilla_client_local_config_uri "" >/dev/null 2>&1; then
    fauxzilla_client_local_config_uri ""
    return 0
  fi
  if [ -n "${HQ_SITE_DOMAIN-}" ]; then
    fauxzilla_client_tokenserver_uri_from_parts https "$HQ_SITE_DOMAIN" /token
    return 0
  fi
  if [ -n "${FAUXZILLA_DOMAIN-}" ]; then
    fauxzilla_client_tokenserver_uri_from_parts \
      "${FAUXZILLA_PUBLIC_SCHEME-https}" \
      "$FAUXZILLA_DOMAIN" \
      "${FAUXZILLA_PUBLIC_PREFIX-/token}"
    return 0
  fi
  if [ -n "${FAUXZILLA_DEFAULT_DOMAIN-}" ]; then
    fauxzilla_client_tokenserver_uri_from_parts \
      "${FAUXZILLA_PUBLIC_SCHEME-https}" \
      "$FAUXZILLA_DEFAULT_DOMAIN" \
      "${FAUXZILLA_PUBLIC_PREFIX-/token}"
    return 0
  fi
  if [ -n "${HQ_HOST-}" ]; then
    fauxzilla_client_tokenserver_uri_from_parts https "new.$HQ_HOST" /token
    return 0
  fi
  return 1
}

fauxzilla_client_prompt_text() {
  question=$1
  default_value=${2-}
  if fauxzilla_client_has ask-text; then
    ask-text "$question" "$default_value"
    return $?
  fi
  [ "$non_interactive" = no ] || return 1
  [ -r /dev/tty ] || return 1
  if [ -n "$default_value" ]; then
    printf '%s [%s]: ' "$question" "$default_value" > /dev/tty
  else
    printf '%s: ' "$question" > /dev/tty
  fi
  IFS= read -r answer < /dev/tty || return 1
  [ -n "$answer" ] || answer=$default_value
  printf '%s\n' "$answer"
}

fauxzilla_client_prompt_tokenserver_uri() {
  default_value=''
  if [ -n "${HQ_SITE_DOMAIN-}" ]; then
    default_value=$HQ_SITE_DOMAIN
  elif [ -n "${HQ_HOST-}" ]; then
    default_value=new.$HQ_HOST
  fi
  answer=$(fauxzilla_client_prompt_text "Fauxzilla domain or full tokenserver URI" "$default_value") || return 1
  fauxzilla_client_normalize_tokenserver_input "$answer"
}

fauxzilla_client_firefox_root() {
  if [ -n "${FAUXZILLA_FIREFOX_ROOT-}" ]; then
    printf '%s\n' "$FAUXZILLA_FIREFOX_ROOT"
    return 0
  fi
  if [ -d "$HOME/Library/Application Support/Firefox" ]; then
    printf '%s\n' "$HOME/Library/Application Support/Firefox"
    return 0
  fi
  if [ -d "$HOME/.mozilla/firefox" ]; then
    printf '%s\n' "$HOME/.mozilla/firefox"
    return 0
  fi
  case "$(uname -s 2>/dev/null || printf 'unknown')" in
    Darwin) printf '%s\n' "$HOME/Library/Application Support/Firefox" ;;
    *) printf '%s\n' "$HOME/.mozilla/firefox" ;;
  esac
}

fauxzilla_client_emit_profile() {
  section_name=$1
  profile_name=${2-}
  raw_path=${3-}
  is_relative=${4-1}
  default_flag=${5-0}
  firefox_root=$6
  [ -n "$raw_path" ] || return 0
  case "$section_name" in
    Profile*) ;;
    *) return 0 ;;
  esac
  resolved_path=$raw_path
  if [ "$is_relative" = '1' ]; then
    resolved_path=$firefox_root/$raw_path
  fi
  if [ -z "$profile_name" ]; then
    profile_name=$(basename "$resolved_path")
  fi
  printf '%s\t%s\t%s\t%s\t%s\n' \
    "$section_name" \
    "$profile_name" \
    "$raw_path" \
    "$resolved_path" \
    "$default_flag"
}

fauxzilla_client_collect_profiles() {
  firefox_root=$1
  output_path=$2
  profiles_ini=$firefox_root/profiles.ini

  : > "$output_path"

  if [ -r "$profiles_ini" ]; then
    current_section=''
    current_name=''
    current_path=''
    current_is_relative='1'
    current_default='0'
    while IFS= read -r line || [ -n "$line" ]; do
      line=${line%}
      case "$line" in
        \[*\])
          fauxzilla_client_emit_profile \
            "$current_section" \
            "$current_name" \
            "$current_path" \
            "$current_is_relative" \
            "$current_default" \
            "$firefox_root" >> "$output_path"
          current_section=${line#\[}
          current_section=${current_section%\]}
          current_name=''
          current_path=''
          current_is_relative='1'
          current_default='0'
          ;;
        Name=*) current_name=${line#Name=} ;;
        Path=*) current_path=${line#Path=} ;;
        IsRelative=*) current_is_relative=${line#IsRelative=} ;;
        Default=*) current_default=${line#Default=} ;;
      esac
    done < "$profiles_ini"
    fauxzilla_client_emit_profile \
      "$current_section" \
      "$current_name" \
      "$current_path" \
      "$current_is_relative" \
      "$current_default" \
      "$firefox_root" >> "$output_path"
  fi

  if [ ! -s "$output_path" ]; then
    for candidate in "$firefox_root"/Profiles/* "$firefox_root"/profiles/*; do
      [ -d "$candidate" ] || continue
      printf 'ProfileScan\t%s\t%s\t%s\t0\n' \
        "$(basename "$candidate")" \
        "$(basename "$candidate")" \
        "$candidate" >> "$output_path"
    done
  fi
}

fauxzilla_client_select_profile() {
  profiles_path=$1
  if [ ! -s "$profiles_path" ]; then
    fauxzilla_client_die "No Firefox profiles were found. Start Firefox once, or set FAUXZILLA_FIREFOX_ROOT." 1
  fi

  if [ -n "$profile_selector" ]; then
    while IFS='	' read -r section_name profile_name raw_path resolved_path default_flag; do
      base_name=$(basename "$resolved_path")
      case "$profile_selector" in
        "$profile_name"|"$raw_path"|"$resolved_path"|"$base_name")
          printf '%s\t%s\t%s\t%s\t%s\n' \
            "$section_name" \
            "$profile_name" \
            "$raw_path" \
            "$resolved_path" \
            "$default_flag"
          return 0
          ;;
      esac
    done < "$profiles_path"
    fauxzilla_client_die "Firefox profile not found: $profile_selector" 1
  fi

  profile_count=$(awk 'END { print NR + 0 }' "$profiles_path")
  if [ "$profile_count" -eq 1 ]; then
    sed -n '1p' "$profiles_path"
    return 0
  fi

  default_line=$(awk -F '\t' '$5 == "1" { print; exit }' "$profiles_path")
  if [ -n "$default_line" ]; then
    printf '%s\n' "$default_line"
    return 0
  fi

  [ "$non_interactive" = no ] || fauxzilla_client_die "Multiple Firefox profiles were found. Re-run with --profile." 1
  [ -r /dev/tty ] || fauxzilla_client_die "Multiple Firefox profiles were found. Re-run with --profile." 1

  printf '%s\n' "Multiple Firefox profiles were found:" > /dev/tty
  profile_number=1
  while IFS='	' read -r section_name profile_name raw_path resolved_path default_flag; do
    printf '  %s. %s (%s)\n' "$profile_number" "$profile_name" "$resolved_path" > /dev/tty
    profile_number=$((profile_number + 1))
  done < "$profiles_path"

  choice=$(fauxzilla_client_prompt_text "Choose Firefox profile number" "1") || {
    fauxzilla_client_die "A Firefox profile choice is required." 1
  }
  case "$choice" in
    ''|*[!0-9]*)
      fauxzilla_client_die "Profile choice must be a positive integer." 2
      ;;
  esac
  selected_line=$(sed -n "${choice}p" "$profiles_path")
  [ -n "$selected_line" ] || fauxzilla_client_die "Profile choice is out of range: $choice" 2
  printf '%s\n' "$selected_line"
}

fauxzilla_client_pref_value_from_file() {
  file_path=$1
  pref_name=$2
  [ -f "$file_path" ] || return 1
  awk -v pref="$pref_name" '
    /^[[:space:]]*user_pref\("/ {
      line = $0
      name = line
      sub(/^[[:space:]]*user_pref\("/, "", name)
      sub(/".*$/, "", name)
      if (name == pref) {
        sub(/^[[:space:]]*user_pref\("[^"]+",[[:space:]]*"/, "", line)
        sub(/"\);[[:space:]]*$/, "", line)
        value = line
      }
    }
    END {
      if (value != "") {
        print value
      } else {
        exit 1
      }
    }
  ' "$file_path"
}

fauxzilla_client_current_pref_value() {
  profile_path=$1
  fauxzilla_client_pref_value_from_file "$profile_path/user.js" "$pref_key" && return 0
  fauxzilla_client_pref_value_from_file "$profile_path/prefs.js" "$pref_key" && return 0
  return 1
}

fauxzilla_client_write_user_pref() {
  user_js_path=$1
  pref_name=$2
  pref_value=$3
  tmp_path=$(mktemp "${TMPDIR:-/tmp}/fauxzilla-userjs.XXXXXX")
  if [ -f "$user_js_path" ]; then
    awk -v pref="$pref_name" '
      $0 == "// Fauxzilla managed Firefox Sync tokenserver override" { next }
      $0 ~ "^[[:space:]]*user_pref\\(\"" pref "\"," { next }
      { print }
    ' "$user_js_path" > "$tmp_path"
  else
    : > "$tmp_path"
  fi
  if [ -s "$tmp_path" ]; then
    printf '\n' >> "$tmp_path"
  fi
  printf '%s\n' "// Fauxzilla managed Firefox Sync tokenserver override" >> "$tmp_path"
  printf 'user_pref("%s", "%s");\n' "$pref_name" "$pref_value" >> "$tmp_path"
  mkdir -p "$(dirname "$user_js_path")"
  mv "$tmp_path" "$user_js_path"
}

fauxzilla_client_firefox_running() {
  if fauxzilla_client_has pgrep; then
    pgrep -x Firefox >/dev/null 2>&1 || \
    pgrep -x firefox >/dev/null 2>&1 || \
    pgrep -x firefox-esr >/dev/null 2>&1
    return $?
  fi
  ps -ax 2>/dev/null | grep -E '[F]irefox|[f]irefox-esr' >/dev/null 2>&1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --config)
      [ $# -ge 2 ] || fauxzilla_client_die "--config requires a path." 2
      config_path=$2
      shift 2
      ;;
    --tokenserver-uri)
      [ $# -ge 2 ] || fauxzilla_client_die "--tokenserver-uri requires a value." 2
      tokenserver_input=$2
      shift 2
      ;;
    --domain)
      [ $# -ge 2 ] || fauxzilla_client_die "--domain requires a value." 2
      tokenserver_input=$2
      shift 2
      ;;
    --profile)
      [ $# -ge 2 ] || fauxzilla_client_die "--profile requires a value." 2
      profile_selector=$2
      shift 2
      ;;
    --check)
      mode='check'
      shift
      ;;
    --print-uri)
      mode='print-uri'
      shift
      ;;
    --non-interactive|--yes)
      non_interactive='yes'
      shift
      ;;
    *)
      fauxzilla_client_die "Unknown argument: $1" 2
      ;;
  esac
done

tokenserver_uri=$(fauxzilla_client_resolve_tokenserver_uri 2>/dev/null || true)
if [ -z "$tokenserver_uri" ]; then
  if [ "$non_interactive" = yes ]; then
    fauxzilla_client_die "Unable to resolve a Fauxzilla tokenserver URI. Re-run with --tokenserver-uri or --domain." 1
  fi
  tokenserver_uri=$(fauxzilla_client_prompt_tokenserver_uri) || {
    fauxzilla_client_die "A Fauxzilla tokenserver URI is required." 1
  }
fi

if [ "$mode" = 'print-uri' ]; then
  printf '%s\n' "$tokenserver_uri"
  exit 0
fi

firefox_root=$(fauxzilla_client_firefox_root)
profiles_file=$(mktemp "${TMPDIR:-/tmp}/fauxzilla-profiles.XXXXXX")
trap 'rm -f "$profiles_file"' EXIT HUP INT TERM
fauxzilla_client_collect_profiles "$firefox_root" "$profiles_file"
selected_profile=$(fauxzilla_client_select_profile "$profiles_file")
IFS='	' read -r profile_section profile_name profile_raw_path profile_path profile_default <<EOF
$selected_profile
EOF

current_uri=$(fauxzilla_client_current_pref_value "$profile_path" 2>/dev/null || true)
user_js_path=$profile_path/user.js

if [ "$mode" = 'check' ]; then
  if [ "$current_uri" = "$tokenserver_uri" ]; then
    printf 'status=ok\n'
    printf 'summary=%s\n' "Firefox profile '$profile_name' already points at Fauxzilla."
  else
    printf 'status=bad\n'
    if [ -n "$current_uri" ]; then
      printf 'summary=%s\n' "Firefox profile '$profile_name' points at $current_uri instead of $tokenserver_uri."
    else
      printf 'summary=%s\n' "Firefox profile '$profile_name' has no Fauxzilla tokenserver override yet."
    fi
  fi
  printf 'profile_name=%s\n' "$profile_name"
  printf 'profile_path=%s\n' "$profile_path"
  printf 'tokenserver_uri=%s\n' "$tokenserver_uri"
  exit 0
fi

fauxzilla_client_write_user_pref "$user_js_path" "$pref_key" "$tokenserver_uri"

restart_required='no'
if fauxzilla_client_firefox_running; then
  restart_required='yes'
fi

printf 'configured=yes\n'
printf 'profile_name=%s\n' "$profile_name"
printf 'profile_path=%s\n' "$profile_path"
printf 'user_js=%s\n' "$user_js_path"
printf 'tokenserver_uri=%s\n' "$tokenserver_uri"
printf 'restart_required=%s\n' "$restart_required"
if [ "$current_uri" = "$tokenserver_uri" ]; then
  printf 'summary=%s\n' "Firefox profile '$profile_name' was already set and is now persisted in user.js."
else
  printf 'summary=%s\n' "Firefox profile '$profile_name' is configured for Fauxzilla."
fi
