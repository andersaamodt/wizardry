#!/bin/sh

# Start the Tabby daemon container.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: start-tabby-daemon

Starts the Tabby daemon container.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

if ! has docker; then
  die "start-tabby-daemon: docker is not installed"
fi

if ! docker info >/dev/null 2>&1; then
  die "start-tabby-daemon: could not connect to the docker daemon. docker daemon must be running to start the tabby daemon."
fi

if ! "$script_dir/is-tabby-daemon-installed" >/dev/null 2>&1; then
  "$script_dir/install-tabby-daemon"
fi

if "$script_dir/is-tabby-daemon-running" >/dev/null 2>&1; then
  success "tabby daemon is already running"
  exit 0
fi

printf '%s\n' "Starting tabby daemon..."
if ! docker start tabby >/dev/null; then
  die "start-tabby-daemon: failed to start tabby daemon container"
fi

tries=0
while [ "$tries" -lt 40 ]; do
  if "$script_dir/is-tabby-daemon-running" >/dev/null 2>&1; then
    success "tabby daemon started"
    exit 0
  fi
  tries=$((tries + 1))
  sleep 0.25
done

die "start-tabby-daemon: tabby daemon did not enter running state"
