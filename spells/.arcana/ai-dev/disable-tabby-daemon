#!/bin/sh

# Disable automatic startup for the Tabby daemon container.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: disable-tabby-daemon

Disables automatic startup for the Tabby daemon container.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

if ! has docker; then
  success "tabby daemon is not installed"
  exit 0
fi

if ! "$script_dir/is-tabby-daemon-installed" >/dev/null 2>&1; then
  success "tabby daemon is not installed"
  exit 0
fi

if ! docker update --restart no tabby >/dev/null; then
  die "disable-tabby-daemon: failed to disable tabby daemon startup"
fi

success "tabby daemon disabled at startup"
