#!/bin/sh

# Check if the Tabby daemon container is configured to start automatically.

set -eu
. env-clear

probe_timeout_tenths=${TABBY_DOCKER_CHECK_TIMEOUT_TENTHS:-20}

run_with_timeout_capture() {
  out_file=${TMPDIR:-/tmp}/tabby-probe-$$.out
  rm -f "$out_file" 2>/dev/null || :
  (
    "$@" >"$out_file" 2>/dev/null
  ) &
  probe_pid=$!
  ticks=0
  while kill -0 "$probe_pid" 2>/dev/null; do
    ticks=$((ticks + 1))
    if [ "$ticks" -ge "$probe_timeout_tenths" ]; then
      kill "$probe_pid" >/dev/null 2>&1 || :
      rm -f "$out_file" 2>/dev/null || :
      return 124
    fi
    sleep 0.1
  done
  wait "$probe_pid"
  probe_rc=$?
  if [ "$probe_rc" -ne 0 ]; then
    rm -f "$out_file" 2>/dev/null || :
    return "$probe_rc"
  fi
  cat "$out_file"
  rm -f "$out_file" 2>/dev/null || :
}

if ! has docker; then
  exit 1
fi

restart_policy=$(run_with_timeout_capture docker container inspect -f '{{.HostConfig.RestartPolicy.Name}}' tabby || printf '')
if [ -n "$restart_policy" ] && [ "$restart_policy" != "no" ]; then
  exit 0
fi

exit 1
