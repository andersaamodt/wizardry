#!/bin/sh

# Uninstall AnythingLLM.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-anythingllm

Uninstalls AnythingLLM.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

# Check if installed
if ! "$script_dir/is-ai-component-installed" anythingllm 2>/dev/null; then
  success "AnythingLLM is not installed"
  exit 0
fi

say "Uninstalling AnythingLLM..."

OS=$(uname -s 2>/dev/null)

case "$OS" in
Darwin)
  # Remove macOS app bundle variants from /Applications and ~/Applications.
  for app_path in /Applications/*AnythingLLM*.app "$HOME/Applications/"*AnythingLLM*.app; do
    [ -e "$app_path" ] || continue
    rm -rf "$app_path" 2>/dev/null || warn "uninstall-anythingllm: failed to remove $app_path"
  done
  ;;
Linux)
  # Remove Linux launcher/binary and managed AppImage install
  for path in \
    /usr/local/bin/anythingllm \
    "$HOME/.local/bin/anythingllm" \
    /opt/anythingllm/anythingllm \
    "$HOME/.local/lib/anythingllm/AnythingLLM.AppImage" \
    "$HOME/.local/lib/anythingllm/AnythingLLMDesktop.AppImage" \
    "$HOME/AnythingLLMDesktop.AppImage" \
    "$HOME/.local/share/applications/anythingllm.desktop"; do
    if [ -f "$path" ]; then
      rm -f "$path" 2>/dev/null || \
        warn "uninstall-anythingllm: failed to remove $path"
    fi
  done
  if [ -d "$HOME/.local/lib/anythingllm" ]; then
    rmdir "$HOME/.local/lib/anythingllm" 2>/dev/null || :
  fi
  ;;
esac

# Remove AnythingLLM data directory
if [ -d "$HOME/.config/anythingllm-desktop" ]; then
  say "Removing AnythingLLM data directory..."
  rm -rf "$HOME/.config/anythingllm-desktop" 2>/dev/null || warn "uninstall-anythingllm: failed to remove data directory"
fi

# Verify uninstallation
if "$script_dir/is-ai-component-installed" anythingllm 2>/dev/null; then
  die "uninstall-anythingllm: uninstallation verification failed"
fi

success "AnythingLLM uninstalled successfully"
