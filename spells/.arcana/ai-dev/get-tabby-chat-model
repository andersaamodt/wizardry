#!/bin/sh

# Print current Tabby chat model from config.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: get-tabby-chat-model

Prints the configured Tabby chat model name.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

config_file="$HOME/.tabby/config.toml"
if [ ! -f "$config_file" ]; then
  exit 1
fi

awk -F'"' '
  /^\[model\.chat\.http\]/ { in_chat=1; next }
  /^\[/ && !/^\[model\.chat\.http\]/ { in_chat=0 }
  in_chat && /^[[:space:]]*model_name[[:space:]]*=/ { print $2; exit }
' "$config_file"

