#!/bin/sh

# Install the Tabby daemon container definition.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-tabby-daemon

Installs the Tabby daemon container definition using Docker.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

if ! has docker; then
  die "install-tabby-daemon: docker is not installed"
fi

if ! docker info >/dev/null 2>&1; then
  die "install-tabby-daemon: could not connect to the docker daemon. docker daemon must be running to install the tabby daemon."
fi

if "$script_dir/is-tabby-daemon-installed" >/dev/null 2>&1; then
  success "tabby daemon is already installed"
  exit 0
fi

printf '%s\n' "Installing tabby daemon..."
printf '%s\n' "Downloading Tabby daemon image..."

arch=$(uname -m 2>/dev/null || printf '')
pull_platform=""
case "$arch" in
  arm64|aarch64)
    # Upstream image does not currently publish a native arm64 manifest.
    pull_platform="linux/amd64"
    warn "install-tabby-daemon: no native arm64 image is published; using linux/amd64 image via emulation"
    ;;
esac

if [ -n "$pull_platform" ]; then
  if ! docker pull --platform "$pull_platform" tabbyml/tabby; then
    die "install-tabby-daemon: failed to download tabby daemon image"
  fi
else
  if ! docker pull tabbyml/tabby; then
    die "install-tabby-daemon: failed to download tabby daemon image"
  fi
fi

mkdir -p "$HOME/.tabby"
if [ -n "$pull_platform" ]; then
  if ! docker create \
    --name tabby \
    --platform "$pull_platform" \
    --restart unless-stopped \
    -p 8080:8080 \
    -v "$HOME/.tabby:/data" \
    tabbyml/tabby >/dev/null; then
    die "install-tabby-daemon: failed to create tabby daemon container"
  fi
else
  if ! docker create \
    --name tabby \
    --restart unless-stopped \
    -p 8080:8080 \
    -v "$HOME/.tabby:/data" \
    tabbyml/tabby >/dev/null; then
    die "install-tabby-daemon: failed to create tabby daemon container"
  fi
fi

success "tabby daemon installed"
