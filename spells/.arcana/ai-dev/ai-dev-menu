#!/bin/sh

# Present the AI development management menu.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: ai-dev-menu

Displays the AI development management menu with install/uninstall toggles for each component.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear
. colors

if ! require menu "The ai-dev-menu needs the 'menu' command to present options."; then
  exit 1
fi

# Catch Ctrl-C and TERM signal to exit cleanly
trap 'exit 130' INT
trap 'exit 0' TERM

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

loop_limit=${MENU_LOOP_LIMIT:-}
SELECTION_FILE=$(temp-file ai-dev-menu-selection)
export SELECTION_FILE
status_check_timeout_tenths=${MENU_STATUS_CHECK_TIMEOUT_TENTHS:-20}

trap 'cleanup-file "$SELECTION_FILE" 2>/dev/null || true; exit 130' INT
trap 'cleanup-file "$SELECTION_FILE" 2>/dev/null || true; exit 0' TERM
trap 'cleanup-file "$SELECTION_FILE" 2>/dev/null || true' EXIT

wrap_cmd() {
  item_label=$1
  cmd=$2
  safe_label=$(printf '%s' "$item_label" | sed "s/'/'\\\\''/g")
  printf "%s; printf '%%s' '%s' > \"\$SELECTION_FILE\"" "$cmd" "$safe_label"
}

normalize_label() {
  label=$1
  case "$label" in
    "[X] "*) printf '%s\n' "${label#"[X] "}" ;;
    "[ ] "*) printf '%s\n' "${label#"[ ] "}" ;;
    *) printf '%s\n' "$label" ;;
  esac
}

# Run status probes in the background with a short timeout so one unhealthy
# subsystem cannot block rendering the whole menu.
fast_check() {
  (
    "$@"
  ) >/dev/null 2>&1 &
  probe_pid=$!
  ticks=0
  while kill -0 "$probe_pid" 2>/dev/null; do
    ticks=$((ticks + 1))
    if [ "$ticks" -ge "$status_check_timeout_tenths" ]; then
      kill "$probe_pid" >/dev/null 2>&1 || :
      return 1
    fi
    sleep 0.1
  done
  wait "$probe_pid"
}

while true; do
  # Clear menu_status from previous iteration
  unset menu_status

  # Read the last selected label and restore by label (not old numeric index).
  if [ -f "$SELECTION_FILE" ]; then
    saved_label=$(cat "$SELECTION_FILE" 2>/dev/null || printf '')
  else
    saved_label=""
  fi

  # Capture current state before building menu
  tabby_installed=0
  ollama_installed=0
  anythingllm_installed=0
  ollama_daemon_installed=0
  ollama_daemon_enabled=0
  ollama_daemon_running=0
  tabby_daemon_installed=0
  tabby_daemon_enabled=0
  tabby_daemon_running=0

  fast_check "$script_dir/is-ai-component-installed" tabby && tabby_installed=1
  fast_check "$script_dir/is-ai-component-installed" ollama && ollama_installed=1
  fast_check "$script_dir/is-ai-component-installed" anythingllm && anythingllm_installed=1

  # Check ollama daemon state (only if ollama is installed)
  if [ "$ollama_installed" -eq 1 ]; then
    if has systemctl; then
      [ -f "/etc/systemd/system/ollama.service" ] && ollama_daemon_installed=1
    elif [ "$(uname -s 2>/dev/null)" = "Darwin" ] && has launchctl; then
      [ -f "/Library/LaunchDaemons/com.ollama.service.plist" ] && ollama_daemon_installed=1
    fi

    fast_check "$script_dir/is-ollama-daemon-enabled" && ollama_daemon_enabled=1
    fast_check "$script_dir/is-ollama-daemon-running" && ollama_daemon_running=1
  fi

  # Build menu entries based on installation state
  set --

  # Check if we should show Manage LLMs menu
  show_manage_llms=0
  if [ "$ollama_installed" -eq 1 ]; then
    show_manage_llms=1
  fi

  # On macOS with ollama installed, show daemon toggles section
  is_macos=0
  [ "$(uname -s 2>/dev/null)" = "Darwin" ] && is_macos=1
  show_ollama_daemon_section=0
  if [ "$is_macos" -eq 1 ] && [ "$ollama_installed" -eq 1 ]; then
    show_ollama_daemon_section=1
  fi

  # Tabby daemon section (self-hosted web service via Docker).
  show_tabby_daemon_section=0
  fast_check "$script_dir/is-tabby-daemon-installed" && tabby_daemon_installed=1
  fast_check "$script_dir/is-tabby-daemon-enabled" && tabby_daemon_enabled=1
  fast_check "$script_dir/is-tabby-daemon-running" && tabby_daemon_running=1
  if [ "$tabby_installed" -eq 1 ] || [ "$tabby_daemon_installed" -eq 1 ] || [ "$tabby_daemon_enabled" -eq 1 ] || [ "$tabby_daemon_running" -eq 1 ]; then
    show_tabby_daemon_section=1
  fi

  # Section 1: Manage LLMs
  if [ "$show_manage_llms" -eq 1 ]; then
    manage_llms_label="Manage LLMs"
    manage_llms_cmd="$script_dir/manage-llms"
    set -- "$@" "$manage_llms_label%$(wrap_cmd "$manage_llms_label" "$manage_llms_cmd")"
    if [ "$tabby_installed" -eq 1 ]; then
      set_tabby_model_label="Set Tabby model"
      set_tabby_model_cmd="$script_dir/select-tabby-llm"
      set -- "$@" "$set_tabby_model_label%$(wrap_cmd "$set_tabby_model_label" "$set_tabby_model_cmd")"
    fi
    deploy_artificer_label="Deploy Artificer (daimon)"
    deploy_artificer_cmd="$script_dir/deploy-artificer daimon"
    set -- "$@" "$deploy_artificer_label%$(wrap_cmd "$deploy_artificer_label" "$deploy_artificer_cmd")"
    set -- "$@" "---"
  fi

  # Section 2: ollama daemon
  if [ "$show_ollama_daemon_section" -eq 1 ]; then
    # Daemon install/uninstall toggle (placed last in this section)
    if [ "$ollama_daemon_installed" -eq 1 ]; then
      daemon_install_label="[X] ollama daemon"
      daemon_install_cmd="$script_dir/uninstall-ollama-daemon"
    else
      daemon_install_label="[ ] ollama daemon"
      daemon_install_cmd="$script_dir/install-ollama-daemon"
    fi
    daemon_install_toggle="$daemon_install_label%$(wrap_cmd "$daemon_install_label" "$daemon_install_cmd")"

    # Only show start/stop and enable/disable if daemon is installed
    if [ "$ollama_daemon_installed" -eq 1 ]; then
      # Start/stop toggle
      if [ "$ollama_daemon_running" -eq 1 ]; then
        daemon_start_label="[X] ollama daemon running"
        daemon_start_cmd="$script_dir/stop-ollama-daemon"
      else
        daemon_start_label="[ ] ollama daemon running"
        daemon_start_cmd="$script_dir/start-ollama-daemon"
      fi
      daemon_start_toggle="$daemon_start_label%$(wrap_cmd "$daemon_start_label" "$daemon_start_cmd")"
      set -- "$@" "$daemon_start_toggle"

      # Enable/disable at startup toggle
      if [ "$ollama_daemon_enabled" -eq 1 ]; then
        daemon_enable_label="[X] ollama daemon at startup"
        daemon_enable_cmd="$script_dir/disable-ollama-daemon"
      else
        daemon_enable_label="[ ] ollama daemon at startup"
        daemon_enable_cmd="$script_dir/enable-ollama-daemon"
      fi
      daemon_enable_toggle="$daemon_enable_label%$(wrap_cmd "$daemon_enable_label" "$daemon_enable_cmd")"
      set -- "$@" "$daemon_enable_toggle"
    fi

    # Daemon install/uninstall appears last in this section.
    set -- "$@" "$daemon_install_toggle"

    # Separator before the final section
    set -- "$@" "---"
  fi

  # Section 3: Tabby daemon
  if [ "$show_tabby_daemon_section" -eq 1 ]; then
    # Daemon install/uninstall toggle (placed last in this section)
    if [ "$tabby_daemon_installed" -eq 1 ]; then
      tabby_daemon_install_label="[X] tabby daemon"
      tabby_daemon_install_cmd="$script_dir/uninstall-tabby-daemon"
    else
      tabby_daemon_install_label="[ ] tabby daemon"
      tabby_daemon_install_cmd="$script_dir/install-tabby-daemon"
    fi
    tabby_daemon_install_toggle="$tabby_daemon_install_label%$(wrap_cmd "$tabby_daemon_install_label" "$tabby_daemon_install_cmd")"

    if [ "$tabby_daemon_installed" -eq 1 ]; then
      tabby_daemon_status_label="tabby daemon status"
      tabby_daemon_status_cmd="$script_dir/tabby-daemon-status"
      set -- "$@" "$tabby_daemon_status_label%$(wrap_cmd "$tabby_daemon_status_label" "$tabby_daemon_status_cmd")"
      tabby_daemon_repair_label="repair tabby daemon"
      tabby_daemon_repair_cmd="$script_dir/repair-tabby-daemon"
      set -- "$@" "$tabby_daemon_repair_label%$(wrap_cmd "$tabby_daemon_repair_label" "$tabby_daemon_repair_cmd")"

      if [ "$tabby_daemon_running" -eq 1 ]; then
        tabby_daemon_running_label="[X] tabby daemon running"
        tabby_daemon_running_cmd="$script_dir/stop-tabby-daemon"
      else
        tabby_daemon_running_label="[ ] tabby daemon running"
        tabby_daemon_running_cmd="$script_dir/start-tabby-daemon"
      fi
      set -- "$@" "$tabby_daemon_running_label%$(wrap_cmd "$tabby_daemon_running_label" "$tabby_daemon_running_cmd")"

      if [ "$tabby_daemon_enabled" -eq 1 ]; then
        tabby_daemon_enabled_label="[X] tabby daemon at startup"
        tabby_daemon_enabled_cmd="$script_dir/disable-tabby-daemon"
      else
        tabby_daemon_enabled_label="[ ] tabby daemon at startup"
        tabby_daemon_enabled_cmd="$script_dir/enable-tabby-daemon"
      fi
      set -- "$@" "$tabby_daemon_enabled_label%$(wrap_cmd "$tabby_daemon_enabled_label" "$tabby_daemon_enabled_cmd")"
    fi

    # Daemon install/uninstall appears last in this section.
    set -- "$@" "$tabby_daemon_install_toggle"

    # Separator before the final section
    set -- "$@" "---"
  fi

  # Section 4 (final): component toggles and global actions
  # Tabby toggle (first in the list as it's standalone and self-contained)
  if [ "$tabby_installed" -eq 1 ]; then
    tabby_label="[X] Tabby"
    tabby_cmd="$script_dir/uninstall-tabby"
  else
    tabby_label="[ ] Tabby"
    tabby_cmd="$script_dir/install-tabby"
  fi
  tabby_toggle="$tabby_label%$(wrap_cmd "$tabby_label" "$tabby_cmd")"
  set -- "$@" "$tabby_toggle"

  # Ollama toggle
  if [ "$ollama_installed" -eq 1 ]; then
    ollama_label="[X] ollama"
    ollama_cmd="$script_dir/uninstall-ollama"
  else
    ollama_label="[ ] ollama"
    ollama_cmd="$script_dir/install-ollama"
  fi
  ollama_toggle="$ollama_label%$(wrap_cmd "$ollama_label" "$ollama_cmd")"
  set -- "$@" "$ollama_toggle"

  # AnythingLLM toggle
  if [ "$anythingllm_installed" -eq 1 ]; then
    anythingllm_label="[X] AnythingLLM"
    anythingllm_cmd="$script_dir/uninstall-anythingllm"
  else
    anythingllm_label="[ ] AnythingLLM"
    anythingllm_cmd="$script_dir/install-anythingllm"
  fi
  anythingllm_toggle="$anythingllm_label%$(wrap_cmd "$anythingllm_label" "$anythingllm_cmd")"
  set -- "$@" "$anythingllm_toggle"

  # Repair link (only if both are installed)
  if [ "$ollama_installed" -eq 1 ] && [ "$anythingllm_installed" -eq 1 ]; then
    repair_label="Repair link"
    repair_cmd="$script_dir/repair-ai-link"
    set -- "$@" "$repair_label%$(wrap_cmd "$repair_label" "$repair_cmd")"
  fi

  # Enable/Disable all toggle
  all_installed=1
  if ! fast_check "$script_dir/is-ai-component-installed" tabby; then
    all_installed=0
  fi
  if ! fast_check "$script_dir/is-ai-component-installed" ollama; then
    all_installed=0
  fi
  if ! fast_check "$script_dir/is-ai-component-installed" anythingllm; then
    all_installed=0
  fi
  
  if [ "$all_installed" -eq 1 ]; then
    toggle_all_label="Disable all"
    toggle_all_cmd="$script_dir/toggle-all-ai-dev --disable"
  else
    toggle_all_label="Enable all"
    toggle_all_cmd="$script_dir/toggle-all-ai-dev --enable"
  fi
  toggle_all="$toggle_all_label%$(wrap_cmd "$toggle_all_label" "$toggle_all_cmd")"
  set -- "$@" "$toggle_all"

  # Exit button
  exit_label=$(exit-label)
  exit_item="${exit_label}%kill -TERM \$PPID"
  set -- "$@" "$exit_item"

  # Restore selection by label. This survives menu item count changes.
  search_label="$saved_label"
  case "$saved_label" in
    "Disable all")
      [ "$all_installed" -eq 1 ] || search_label="Enable all"
      ;;
    "Enable all")
      [ "$all_installed" -eq 0 ] || search_label="Disable all"
      ;;
  esac

  start_selection=1
  if [ -n "$search_label" ]; then
    search_normalized=$(normalize_label "$search_label")
    position=0
    for item in "$@"; do
      position=$((position + 1))
      item_label=${item%%\%*}
      if [ "$item_label" = "$search_label" ]; then
        start_selection=$position
        break
      fi
      if [ "$(normalize_label "$item_label")" = "$search_normalized" ]; then
        start_selection=$position
        break
      fi
    done
  fi

  menu --start-selection "$start_selection" "AI Development:" "$@" || menu_status=$?
  menu_status=${menu_status:-0}

  # ESC causes menu to exit with 130 - handle gracefully by exiting
  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi

  # Support MENU_LOOP_LIMIT for testing
  if [ -n "$loop_limit" ]; then
    loop_limit=$((loop_limit - 1))
    if [ "$loop_limit" -le 0 ]; then
      break
    fi
  fi
done
