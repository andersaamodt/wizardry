#!/bin/sh

# Stop the Tabby daemon container.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: stop-tabby-daemon

Stops the Tabby daemon container.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

if ! has docker; then
  success "tabby daemon is not running"
  exit 0
fi

if ! "$script_dir/is-tabby-daemon-running" >/dev/null 2>&1; then
  success "tabby daemon is not running"
  exit 0
fi

if ! docker stop tabby >/dev/null; then
  die "stop-tabby-daemon: failed to stop tabby daemon container"
fi

success "tabby daemon stopped"
