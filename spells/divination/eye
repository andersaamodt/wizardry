#!/bin/sh

# First-class Wizardry entrypoint for the Eye camera viewer.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: eye [COMMAND] [ARGUMENTS]

Delegates to the Eye app CLI when the Eye project is available.
Common commands: list, add NAME, cameras, view NAME, web, snap NAME, record NAME, url NAME.
USAGE
  exit 0
  ;;
esac

set -eu

eye_find_project() {
  if [ "${EYE_PROJECT_ROOT-}" ]; then
    printf '%s\n' "$EYE_PROJECT_ROOT"
    return 0
  fi
  for eye_find_project_candidate in "$HOME/git/eye" "$HOME/Code/eye" "$HOME/src/eye"; do
    if [ -x "$eye_find_project_candidate/spells/eye" ]; then
      printf '%s\n' "$eye_find_project_candidate"
      return 0
    fi
  done
  return 1
}

eye_project=$(eye_find_project) || {
  printf '%s\n' "eye: Eye project checkout was not found" >&2
  exit 1
}

if [ ! -x "$eye_project/spells/eye" ]; then
  printf '%s\n' "eye: Eye CLI is not executable at $eye_project/spells/eye" >&2
  exit 1
fi

exec "$eye_project/spells/eye" "$@"
