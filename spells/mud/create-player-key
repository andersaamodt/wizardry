#!/bin/sh

# Create a public/private keypair for an existing player name.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: create-player-key PLAYER

Create PLAYER's SSH key pair at ~/.ssh/PLAYER and print the public key.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

player=${1-}
if [ -z "$player" ]; then
  printf '%s\n' "create-player-key: PLAYER required" >&2
  exit 2
fi

if ! validate-player-name "$player" 2>/dev/null; then
  validate-player-name "$player" || exit 1
fi

private_key="$HOME/.ssh/$player"
public_key="${private_key}.pub"
if [ -e "$private_key" ] || [ -e "$public_key" ]; then
  printf '%s\n' "create-player-key: player key already exists: $private_key" >&2
  exit 1
fi

mkdir -p "$HOME/.ssh"
ssh-keygen -t ed25519 -C "${player}@MUD" -f "$private_key" -q -N ""
cat "$public_key"
