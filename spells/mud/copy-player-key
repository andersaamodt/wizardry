#!/bin/sh

# Copy a player's public key to the system clipboard.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: copy-player-key PLAYER

Copy PLAYER's public SSH key to the clipboard.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

player=${1-}
if [ -z "$player" ]; then
  printf '%s\n' "copy-player-key: PLAYER required" >&2
  exit 2
fi

key_path="$HOME/.ssh/${player}.pub"
if [ ! -f "$key_path" ]; then
  printf '%s\n' "copy-player-key: key not found: $key_path" >&2
  exit 1
fi

clip-copy "$(cat "$key_path")"
